{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Database=dotnetcloud;Username=postgres;Password=postgres"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "DotNetCloud": "Information"
    }
  },
  "Serilog": {
    "ConsoleMinimumLevel": "Information",
    "FileMinimumLevel": "Warning",
    "FilePath": "logs/dotnetcloud-.log",
    "RollingDaily": true,
    "RetainedFileCountLimit": 31,
    "FileSizeLimitBytes": 104857600,
    "UseStructuredFormat": true,
    "ExcludedModules": [],
    "ModuleLogLevels": {}
  },
  "Auth": {
    "AccessTokenLifetime": 3600,
    "RefreshTokenLifetime": 604800
  },
  "Kestrel": {
    "HttpPort": 5080,
    "HttpsPort": 5443,
    "EnableHttps": true,
    "EnableHttp2": true,
    "MaxRequestBodySize": 52428800,
    "RequestHeaderTimeoutSeconds": 30,
    "KeepAliveTimeoutSeconds": 120,
    "ListenAddresses": []
  },
  "ApiVersioning": {
    "CurrentVersion": "1",
    "MinimumVersion": "1",
    "DeprecatedVersions": [],
    "RoutePrefix": "api/v{version}"
  },
  "Cors": {
    "AllowedOrigins": [],
    "AllowedMethods": [ "GET", "POST", "PUT", "PATCH", "DELETE", "OPTIONS", "HEAD" ],
    "AllowedHeaders": [ "Authorization", "Content-Type", "Accept", "X-Requested-With", "X-Api-Version" ],
    "ExposedHeaders": [ "X-Api-Version", "X-Api-Deprecated", "X-RateLimit-Limit", "X-RateLimit-Remaining", "X-RateLimit-Reset", "Retry-After" ],
    "AllowCredentials": true,
    "PreflightMaxAgeSeconds": 600
  },
  "RateLimiting": {
    "Enabled": true,
    "GlobalPermitLimit": 100,
    "GlobalWindowSeconds": 60,
    "AuthenticatedPermitLimit": 200,
    "AuthenticatedWindowSeconds": 60,
    "IncludeHeaders": true,
    "QueueLimit": 0,
    "ModuleLimits": {}
  },
  "Security": {
    "SecurityHeaders": {
      "ContentSecurityPolicy": "default-src 'self'",
      "XFrameOptions": "SAMEORIGIN"
    }
  },
  "SignalR": {
    "HubPath": "/hubs/core",
    "KeepAliveIntervalSeconds": 15,
    "ClientTimeoutSeconds": 30,
    "HandshakeTimeoutSeconds": 15,
    "MaximumParallelInvocationsPerClient": 10,
    "MaximumReceiveMessageSize": 32768,
    "MaxConnections": 0,
    "EnableDetailedErrors": false,
    "WebSocketKeepAliveSeconds": 30,
    "EnableWebSockets": true,
    "EnableServerSentEvents": true,
    "EnableLongPolling": true,
    "PresenceCleanupIntervalSeconds": 60
  },
  "Telemetry": {
    "ServiceName": "DotNetCloud",
    "ServiceVersion": "1.0.0",
    "EnableMetrics": true,
    "EnableTracing": true,
    "EnableConsoleExporter": false,
    "EnablePrometheusExporter": false,
    "OtlpEndpoint": "",
    "AdditionalSources": [],
    "AdditionalMeters": []
  }
}
