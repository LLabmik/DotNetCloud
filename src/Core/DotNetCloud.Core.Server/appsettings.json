{
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Database=dotnetcloud;Username=postgres;Password=postgres"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "DotNetCloud": "Information"
    }
  },
  "Serilog": {
    "ConsoleMinimumLevel": "Information",
    "FileMinimumLevel": "Information",
    "FilePath": "logs/dotnetcloud-.log",
    "RollingDaily": true,
    "RetainedFileCountLimit": 31,
    "FileSizeLimitBytes": 104857600,
    "UseStructuredFormat": true,
    "ExcludedModules": [],
    "ModuleLogLevels": {}
  },
  "Auth": {
    "AccessTokenLifetimeMinutes": 60,
    "RefreshTokenLifetimeDays": 14
  },
  "Kestrel": {
    "HttpPort": 5080,
    "HttpsPort": 5443,
    "EnableHttps": true,
    "EnableHttp2": true,
    "CertificatePath": "certs/dotnetcloud-localhost.pfx",
    "MaxRequestBodySize": 52428800,
    "RequestHeaderTimeoutSeconds": 30,
    "KeepAliveTimeoutSeconds": 120,
    "ListenAddresses": []
  },
  "ApiVersioning": {
    "CurrentVersion": "1",
    "MinimumVersion": "1",
    "DeprecatedVersions": [],
    "RoutePrefix": "api/v{version}"
  },
  "Cors": {
    "AllowedOrigins": [],
    "AllowedMethods": [
      "GET",
      "POST",
      "PUT",
      "PATCH",
      "DELETE",
      "OPTIONS",
      "HEAD"
    ],
    "AllowedHeaders": [
      "Authorization",
      "Content-Type",
      "Accept",
      "X-Requested-With",
      "X-Api-Version"
    ],
    "ExposedHeaders": [
      "X-Api-Version",
      "X-Api-Deprecated",
      "X-RateLimit-Limit",
      "X-RateLimit-Remaining",
      "X-RateLimit-Reset",
      "Retry-After"
    ],
    "AllowCredentials": true,
    "PreflightMaxAgeSeconds": 600
  },
  "RateLimiting": {
    "Enabled": true,
    "GlobalPermitLimit": 100,
    "GlobalWindowSeconds": 60,
    "AuthenticatedPermitLimit": 10000,
    "AuthenticatedWindowSeconds": 60,
    "IncludeHeaders": true,
    "QueueLimit": 0,
    "ModuleLimits": {
      "sync-changes": {
        "PermitLimit": 60,
        "WindowSeconds": 60,
        "PerDevice": true
      },
      "sync-tree": {
        "PermitLimit": 10,
        "WindowSeconds": 60,
        "PerDevice": true
      },
      "sync-reconcile": {
        "PermitLimit": 30,
        "WindowSeconds": 60,
        "PerDevice": true
      },
      "sync-stream": {
        "PermitLimit": 5,
        "WindowSeconds": 60,
        "PerDevice": true
      },
      "upload-initiate": {
        "PermitLimit": 30,
        "WindowSeconds": 60,
        "PerDevice": true
      },
      "upload-chunks": {
        "PermitLimit": 300,
        "WindowSeconds": 60,
        "PerDevice": true
      },
      "download": {
        "PermitLimit": 600,
        "WindowSeconds": 60,
        "PerDevice": true
      },
      "chunks": {
        "PermitLimit": 10000,
        "WindowSeconds": 60
      },
      "video-call-initiate": {
        "PermitLimit": 1,
        "WindowSeconds": 5
      }
    }
  },
  "Security": {
    "SecurityHeaders": {
      "ContentSecurityPolicy": "default-src 'self'",
      "XFrameOptions": "SAMEORIGIN"
    }
  },
  "FileUpload": {
    "MaxFileSizeBytes": 16106127360
  },
  "FileSystem": {
    "EnforceCaseInsensitiveUniqueness": true,
    "MaxPathWarningThreshold": 250,
    "EnforceWindowsFilenameCompatibility": true
  },
  "SignalR": {
    "HubPath": "/hubs/core",
    "KeepAliveIntervalSeconds": 15,
    "ClientTimeoutSeconds": 30,
    "HandshakeTimeoutSeconds": 15,
    "MaximumParallelInvocationsPerClient": 10,
    "MaximumReceiveMessageSize": 32768,
    "MaxConnections": 0,
    "EnableDetailedErrors": false,
    "WebSocketKeepAliveSeconds": 30,
    "EnableWebSockets": true,
    "EnableServerSentEvents": true,
    "EnableLongPolling": true,
    "PresenceCleanupIntervalSeconds": 60
  },
  "Telemetry": {
    "ServiceName": "DotNetCloud",
    "ServiceVersion": "1.0.0",
    "EnableMetrics": true,
    "EnableTracing": true,
    "EnableConsoleExporter": false,
    "EnablePrometheusExporter": false,
    "OtlpEndpoint": "",
    "AdditionalSources": [],
    "AdditionalMeters": []
  },
  "AI": {
    "Provider": "ollama",
    "Ollama": {
      "BaseUrl": "http://monolith.kimball.home:11434",
      "DefaultModel": "gpt-oss:20b"
    }
  },
  "Chat": {
    "IceServers": {
      "EnableBuiltInStun": true,
      "StunPort": 3478,
      "StunPublicHost": "",
      "AdditionalStunUrls": [],
      "EnableTurn": false,
      "TurnUrls": [],
      "TurnUsername": "",
      "TurnCredential": "",
      "EnableEphemeralCredentials": false,
      "TurnSharedSecret": "",
      "CredentialTtlSeconds": 86400,
      "IceTransportPolicy": "all"
    },
    "LiveKit": {
      "Enabled": false,
      "ServerUrl": "",
      "ApiKey": "",
      "ApiSecret": "",
      "DefaultMaxParticipants": 50,
      "TokenTtlSeconds": 3600,
      "MaxP2PParticipants": 3,
      "EmptyRoomTimeoutSeconds": 300
    }
  },
  "Email": {
    "Gmail": {
      "ClientId": "",
      "ClientSecret": "",
      "RedirectUri": "https://mint22:5443/api/v1/email/gmail/oauth/complete"
    }
  }
}
