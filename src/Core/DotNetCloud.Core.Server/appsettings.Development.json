{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Database=dotnetcloud_dev;Username=postgres;Password=postgres"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft": "Information",
      "DotNetCloud": "Debug"
    }
  },
  "Serilog": {
    "ConsoleMinimumLevel": "Debug",
    "FileMinimumLevel": "Information",
    "FilePath": "logs/dotnetcloud-dev-.log",
    "RetainedFileCountLimit": 7,
    "UseStructuredFormat": true
  },
  "Auth": {
    "AccessTokenLifetime": 3600,
    "RefreshTokenLifetime": 604800
  },
  "Kestrel": {
    "HttpPort": 5080,
    "HttpsPort": 5443,
    "EnableHttps": true,
    "EnableHttp2": true
  },
  "Cors": {
    "AllowedOrigins": [
      "https://localhost:7200",
      "http://localhost:3000"
    ],
    "AllowCredentials": true
  },
  "RateLimiting": {
    "Enabled": true,
    "GlobalPermitLimit": 500,
    "GlobalWindowSeconds": 60,
    "AuthenticatedPermitLimit": 1000,
    "AuthenticatedWindowSeconds": 60
  },
  "SignalR": {
    "EnableDetailedErrors": true
  },
  "Telemetry": {
    "EnableMetrics": true,
    "EnableTracing": true,
    "EnableConsoleExporter": false,
    "EnablePrometheusExporter": false
  }
}
