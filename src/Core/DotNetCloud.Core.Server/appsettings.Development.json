{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Database=dotnetcloud_dev;Username=dotnetcloud;Password=dotnetcloud_dev_password"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft": "Information",
      "DotNetCloud": "Debug"
    }
  },
  "Serilog": {
    "ConsoleMinimumLevel": "Debug",
    "FileMinimumLevel": "Information",
    "FilePath": "logs/dotnetcloud-dev-.log",
    "RetainedFileCountLimit": 7,
    "UseStructuredFormat": true
  },
  "Auth": {
    "AccessTokenLifetimeMinutes": 60,
    "RefreshTokenLifetimeDays": 14
  },
  "Kestrel": {
    "HttpPort": 5080,
    "HttpsPort": 5443,
    "EnableHttps": true,
    "EnableHttp2": true,
    "CertificatePath": "certs/dotnetcloud-localhost.pfx"
  },
  "Cors": {
    "AllowedOrigins": [
      "https://localhost:7200",
      "http://localhost:3000"
    ],
    "AllowCredentials": true
  },
  "RateLimiting": {
    "Enabled": true,
    "GlobalPermitLimit": 500,
    "GlobalWindowSeconds": 60,
    "AuthenticatedPermitLimit": 1000,
    "AuthenticatedWindowSeconds": 60
  },
  "SignalR": {
    "EnableDetailedErrors": true
  },
  "Telemetry": {
    "EnableMetrics": true,
    "EnableTracing": true,
    "EnableConsoleExporter": false,
    "EnablePrometheusExporter": false
  },
  "DotNetCloud": {
    "AdminEmail": "",
    "AdminPassword": ""
  }
}
