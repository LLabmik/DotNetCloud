@using System.Globalization
@using DotNetCloud.Core.Localization
@inject IJSRuntime JS
@inject NavigationManager Navigation

<div class="culture-selector">
    <label>
        <select class="input culture-select" @bind="selectedCulture" @bind:after="ApplySelectedCultureAsync">
            @foreach (var culture in supportedCultures)
            {
                <option value="@culture">@SupportedCultures.DisplayNames.GetValueOrDefault(culture.Name, culture.DisplayName)</option>
            }
        </select>
    </label>
</div>

@code {
    private readonly CultureInfo[] supportedCultures = SupportedCultures.GetCultureInfos();
    private CultureInfo? selectedCulture;

    /// <inheritdoc />
    protected override void OnInitialized()
    {
        selectedCulture = CultureInfo.CurrentCulture;
    }

    private async Task ApplySelectedCultureAsync()
    {
        if (CultureInfo.CurrentCulture == selectedCulture)
        {
            return;
        }

        // Persist in browser local storage (for WASM startup)
        await JS.InvokeVoidAsync("blazorCulture.set", selectedCulture!.Name);

        // Redirect through CultureController to set the server-side cookie
        var uri = new Uri(Navigation.Uri)
            .GetComponents(UriComponents.PathAndQuery, UriFormat.Unescaped);
        var cultureEscaped = Uri.EscapeDataString(selectedCulture.Name);
        var uriEscaped = Uri.EscapeDataString(uri);

        Navigation.NavigateTo(
            $"Culture/Set?culture={cultureEscaped}&redirectUri={uriEscaped}",
            forceLoad: true);
    }
}
