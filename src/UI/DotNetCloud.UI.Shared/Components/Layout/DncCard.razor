<div class="dnc-card @CssClass">
    @if (Header is not null || !string.IsNullOrWhiteSpace(Title))
    {
        <div class="dnc-card-header">
            @if (Header is not null)
            {
                @Header
            }
            else
            {
                <h3>@Title</h3>
            }
        </div>
    }
    <div class="dnc-card-body">
        @ChildContent
    </div>
    @if (Footer is not null)
    {
        <div class="dnc-card-footer">
            @Footer
        </div>
    }
</div>

@code {
    /// <summary>Card title displayed in the header.</summary>
    [Parameter]
    public string? Title { get; set; }

    /// <summary>Custom header content (overrides Title).</summary>
    [Parameter]
    public RenderFragment? Header { get; set; }

    /// <summary>Card body content.</summary>
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    /// <summary>Optional footer content.</summary>
    [Parameter]
    public RenderFragment? Footer { get; set; }

    /// <summary>Additional CSS class.</summary>
    [Parameter]
    public string? CssClass { get; set; }
}
