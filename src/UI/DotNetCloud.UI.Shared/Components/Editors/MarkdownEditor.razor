@namespace DotNetCloud.UI.Shared.Components.Editors
@using DotNetCloud.UI.Shared.Services
@inject IJSRuntime JS

@*
    Markdown editor component with toolbar and live preview.
    Provides formatting buttons for common Markdown syntax
    and a split-pane view with live-rendered preview.
*@

<div class="markdown-editor @(PreviewOnly ? "preview-only" : "") @(Compact ? "compact" : "")">
    <div class="markdown-editor-toolbar">
        <div class="toolbar-group">
            <button type="button" class="toolbar-btn" title="Bold (Ctrl+B)" @onclick="InsertBold">
                <strong>B</strong>
            </button>
            <button type="button" class="toolbar-btn" title="Italic (Ctrl+I)" @onclick="InsertItalic">
                <em>I</em>
            </button>
            <button type="button" class="toolbar-btn" title="Strikethrough" @onclick="InsertStrikethrough">
                <s>S</s>
            </button>
        </div>
        <div class="toolbar-separator"></div>
        @if (!Compact)
        {
        <div class="toolbar-group">
            <button type="button" class="toolbar-btn" title="Heading 1" @onclick="() => InsertHeading(1)">
                H1
            </button>
            <button type="button" class="toolbar-btn" title="Heading 2" @onclick="() => InsertHeading(2)">
                H2
            </button>
            <button type="button" class="toolbar-btn" title="Heading 3" @onclick="() => InsertHeading(3)">
                H3
            </button>
        </div>
        <div class="toolbar-separator"></div>
        }
        <div class="toolbar-group">
            <button type="button" class="toolbar-btn" title="Unordered list" @onclick="InsertUnorderedList">
                &bull; List
            </button>
            @if (!Compact)
            {
            <button type="button" class="toolbar-btn" title="Ordered list" @onclick="InsertOrderedList">
                1. List
            </button>
            <button type="button" class="toolbar-btn" title="Task list" @onclick="InsertTaskList">
                ☑ Task
            </button>
            }
        </div>
        <div class="toolbar-separator"></div>
        <div class="toolbar-group">
            <button type="button" class="toolbar-btn" title="Link" @onclick="InsertLink">
                🔗
            </button>
            @if (!Compact)
            {
            <button type="button" class="toolbar-btn" title="Image" @onclick="InsertImage">
                🖼
            </button>
            }
            <button type="button" class="toolbar-btn" title="Code block" @onclick="InsertCodeBlock">
                &lt;/&gt;
            </button>
            @if (!Compact)
            {
            <button type="button" class="toolbar-btn" title="Blockquote" @onclick="InsertBlockquote">
                ❝
            </button>
            <button type="button" class="toolbar-btn" title="Horizontal rule" @onclick="InsertHorizontalRule">
                ―
            </button>
            <button type="button" class="toolbar-btn" title="Table" @onclick="InsertTable">
                ⊞
            </button>
            }
        </div>
        @if (Compact)
        {
        <div class="toolbar-group compact-more-group">
            <button type="button" class="toolbar-btn compact-more-btn" title="More formatting" @onclick="ToggleCompactMenu">
                ☰
            </button>
            @if (_showCompactMenu)
            {
            <div class="compact-more-menu">
                <button type="button" class="compact-menu-item" @onclick="() => { InsertHeading(1); _showCompactMenu = false; }">
                    <span class="compact-menu-icon">H1</span> Heading 1
                </button>
                <button type="button" class="compact-menu-item" @onclick="() => { InsertHeading(2); _showCompactMenu = false; }">
                    <span class="compact-menu-icon">H2</span> Heading 2
                </button>
                <button type="button" class="compact-menu-item" @onclick="() => { InsertHeading(3); _showCompactMenu = false; }">
                    <span class="compact-menu-icon">H3</span> Heading 3
                </button>
                <div class="compact-menu-divider"></div>
                <button type="button" class="compact-menu-item" @onclick="() => { InsertOrderedList(); _showCompactMenu = false; }">
                    <span class="compact-menu-icon">1.</span> Ordered List
                </button>
                <button type="button" class="compact-menu-item" @onclick="() => { InsertTaskList(); _showCompactMenu = false; }">
                    <span class="compact-menu-icon">☑</span> Task List
                </button>
                <div class="compact-menu-divider"></div>
                <button type="button" class="compact-menu-item" @onclick="() => { InsertImage(); _showCompactMenu = false; }">
                    <span class="compact-menu-icon">🖼</span> Image
                </button>
                <button type="button" class="compact-menu-item" @onclick="() => { InsertBlockquote(); _showCompactMenu = false; }">
                    <span class="compact-menu-icon">❝</span> Blockquote
                </button>
                <button type="button" class="compact-menu-item" @onclick="() => { InsertHorizontalRule(); _showCompactMenu = false; }">
                    <span class="compact-menu-icon">―</span> Horizontal Rule
                </button>
                <button type="button" class="compact-menu-item" @onclick="() => { InsertTable(); _showCompactMenu = false; }">
                    <span class="compact-menu-icon">⊞</span> Table
                </button>
            </div>
            }
        </div>
        }
        <div class="toolbar-separator"></div>
        <div class="toolbar-group toolbar-group-right">
            <button type="button"
                    class="toolbar-btn @(_activeView == EditorView.Edit ? "active" : "")"
                    title="Edit"
                    @onclick="() => SetView(EditorView.Edit)">
                ✏ Edit
            </button>
            @if (!Compact)
            {
            <button type="button"
                    class="toolbar-btn @(_activeView == EditorView.Split ? "active" : "")"
                    title="Split view"
                    @onclick="() => SetView(EditorView.Split)">
                ⬓ Split
            </button>
            }
            <button type="button"
                    class="toolbar-btn @(_activeView == EditorView.Preview ? "active" : "")"
                    title="Preview"
                    @onclick="() => SetView(EditorView.Preview)">
                👁 Preview
            </button>
        </div>
    </div>

    <div class="markdown-editor-body view-@_activeView.ToString().ToLowerInvariant()">
        @if (_activeView != EditorView.Preview)
        {
            <div class="editor-pane">
                <textarea @ref="_textareaRef"
                          class="editor-textarea"
                          placeholder="@(Placeholder ?? "Write your note in Markdown…")"
                          rows="@Rows"
                          @bind="Content"
                          @bind:event="oninput"
                          @bind:after="OnContentChanged"
                          spellcheck="true"></textarea>
            </div>
        }
        @if (_activeView != EditorView.Edit)
        {
            <div class="preview-pane">
                <div class="preview-content markdown-body">
                    @((MarkupString)_renderedHtml)
                </div>
            </div>
        }
    </div>
</div>

@code {
    private string _renderedHtml = string.Empty;
    private EditorView _activeView = EditorView.Split;
    private ElementReference _textareaRef;
    private bool _showCompactMenu;

    /// <summary>
    /// The raw Markdown content being edited.
    /// </summary>
    [Parameter]
    public string Content { get; set; } = string.Empty;

    /// <summary>
    /// Callback fired when the content changes.
    /// </summary>
    [Parameter]
    public EventCallback<string> ContentChanged { get; set; }

    /// <summary>
    /// The Markdown renderer service injected from DI.
    /// </summary>
    [Parameter]
    public IMarkdownRenderer? Renderer { get; set; }

    /// <summary>
    /// When true, hides the editor pane and toolbar and shows only the rendered preview.
    /// </summary>
    [Parameter]
    public bool PreviewOnly { get; set; }

    /// <summary>
    /// When true, initializes the editor in preview view instead of split view.
    /// Useful in contexts where rendered output should be emphasized first.
    /// </summary>
    [Parameter]
    public bool StartInPreview { get; set; }

    /// <summary>
    /// When true, renders a compact toolbar with essential formatting buttons only.
    /// Hides headings, tables, images, blockquotes, horizontal rules, and split view.
    /// </summary>
    [Parameter]
    public bool Compact { get; set; }

    /// <summary>
    /// Custom placeholder text for the editor textarea.
    /// </summary>
    [Parameter]
    public string? Placeholder { get; set; }

    /// <summary>
    /// Number of visible rows in the editor textarea. Defaults to 0 (auto/flex).
    /// </summary>
    [Parameter]
    public int Rows { get; set; }

    private bool _viewInitialized;

    /// <inheritdoc />
    protected override void OnParametersSet()
    {
        if (!_viewInitialized)
        {
            _activeView = PreviewOnly || StartInPreview
                ? EditorView.Preview
                : Compact ? EditorView.Edit : EditorView.Split;
            _viewInitialized = true;
        }
        else if (PreviewOnly)
        {
            _activeView = EditorView.Preview;
        }

        RenderPreview();
    }

    private void SetView(EditorView view)
    {
        if (PreviewOnly) return;
        _activeView = view;
        _showCompactMenu = false;
        if (view != EditorView.Edit)
        {
            RenderPreview();
        }
    }

    private void ToggleCompactMenu()
    {
        _showCompactMenu = !_showCompactMenu;
    }

    private async Task OnContentChanged()
    {
        RenderPreview();
        await ContentChanged.InvokeAsync(Content);
    }

    private void RenderPreview()
    {
        if (Renderer is not null && !string.IsNullOrEmpty(Content))
        {
            _renderedHtml = Renderer.RenderToHtml(Content);
        }
        else
        {
            _renderedHtml = string.Empty;
        }
    }

    // ─── Toolbar actions ─────────────────────────────────────────────
    // These use JS interop to wrap selected text or insert at cursor.

    private Task InsertBold() => ApplyWrapFormat("**", "**", "bold text");
    private Task InsertItalic() => ApplyWrapFormat("*", "*", "italic text");
    private Task InsertStrikethrough() => ApplyWrapFormat("~~", "~~", "strikethrough");

    private Task InsertHeading(int level) =>
        InsertAtCursor($"\n{new string('#', level)} Heading\n");

    private Task InsertUnorderedList() =>
        InsertAtCursor("\n- Item 1\n- Item 2\n- Item 3\n");

    private Task InsertOrderedList() =>
        InsertAtCursor("\n1. Item 1\n2. Item 2\n3. Item 3\n");

    private Task InsertTaskList() =>
        InsertAtCursor("\n- [ ] Task 1\n- [ ] Task 2\n- [x] Completed task\n");

    private Task InsertLink() => ApplyWrapFormat("[", "](https://example.com)", "link text");
    private Task InsertImage() => InsertAtCursor("![alt text](image-url)");

    private Task InsertCodeBlock() =>
        ApplyWrapFormat("\n```\n", "\n```\n", "code here");

    private Task InsertBlockquote() =>
        InsertAtCursor("\n> Quoted text\n");

    private Task InsertHorizontalRule() =>
        InsertAtCursor("\n---\n");

    private Task InsertTable() =>
        InsertAtCursor("\n| Header 1 | Header 2 | Header 3 |\n|----------|----------|----------|\n| Cell 1   | Cell 2   | Cell 3   |\n");

    private async Task ApplyWrapFormat(string prefix, string suffix, string fallbackText)
    {
        var fallback = prefix + fallbackText + suffix;
        var newValue = await JS.InvokeAsync<string?>("dotnetcloudMarkdownEditor.applyFormat",
            _textareaRef, prefix, suffix, fallback);
        if (newValue is not null)
        {
            Content = newValue;
            RenderPreview();
            await ContentChanged.InvokeAsync(Content);
        }
    }

    private async Task InsertAtCursor(string text)
    {
        var newValue = await JS.InvokeAsync<string?>("dotnetcloudMarkdownEditor.insertAtCursor",
            _textareaRef, text);
        if (newValue is not null)
        {
            Content = newValue;
            RenderPreview();
            await ContentChanged.InvokeAsync(Content);
        }
    }

    private enum EditorView
    {
        Edit,
        Split,
        Preview
    }
}
