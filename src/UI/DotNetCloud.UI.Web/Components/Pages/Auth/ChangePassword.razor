@page "/auth/change-password"
@using Microsoft.AspNetCore.Identity
@using DotNetCloud.Core.Data.Entities.Identity
@layout AuthLayout

<PageTitle>Change Password - DotNetCloud</PageTitle>

<div class="auth-container">
    <div class="auth-card">
        <div class="auth-header">
            <img class="auth-logo" src="/_content/DotNetCloud.UI.Web/logo.png" alt="DotNetCloud" />
            <h1>DotNetCloud</h1>
            <p>You must change your password before continuing</p>
        </div>

        <form method="post" action="/auth/session/change-password">
            <div class="form-group">
                <label for="currentPassword">Current Password</label>
                <input id="currentPassword" name="currentPassword" class="input" type="password" required />
            </div>

            <div class="form-group">
                <label for="newPassword">New Password</label>
                <input id="newPassword" name="newPassword" class="input" type="password" required />
                <small class="form-hint">Must be at least 6 characters and contain a mix of letters, numbers, and symbols.</small>
            </div>

            <div class="form-group">
                <label for="confirmNewPassword">Confirm New Password</label>
                <input id="confirmNewPassword" name="confirmNewPassword" class="input" type="password" required />
            </div>

            <input type="hidden" name="returnUrl" value="@SafeReturnUrl" />

            @if (!string.IsNullOrWhiteSpace(Error))
            {
                <div class="alert alert-danger">@Error</div>
            }

            @if (Changed)
            {
                <div class="alert alert-success">Password changed successfully. Redirecting...</div>
                <script>
                    (function () {
                        var returnUrl = '@SafeReturnUrl';
                        setTimeout(function () { window.location.href = returnUrl; }, 1500);
                    })();
                </script>
            }

            <div class="form-actions">
                <button type="submit" class="btn btn-primary btn-full">Change Password</button>
            </div>
        </form>

        <div class="auth-footer">
            <a href="/auth/logout">Cancel and sign out</a>
        </div>
    </div>
</div>

@code {
    [SupplyParameterFromQuery]
    private string? ReturnUrl { get; set; }

    [SupplyParameterFromQuery]
    private string? Error { get; set; }

    [SupplyParameterFromQuery(Name = "changed")]
    private bool Changed { get; set; }

    private string SafeReturnUrl => IsSafeLocalReturnUrl(ReturnUrl) ? ReturnUrl! : "/";

    private static bool IsSafeLocalReturnUrl(string? returnUrl)
    {
        return !string.IsNullOrWhiteSpace(returnUrl)
            && returnUrl.StartsWith("/", StringComparison.Ordinal)
            && !returnUrl.StartsWith("//", StringComparison.Ordinal);
    }
}
