@page "/auth/forgot-password"
@using Microsoft.AspNetCore.Identity
@using Microsoft.Extensions.Logging
@using DotNetCloud.Core.Data.Entities.Identity
@layout AuthLayout

<PageTitle>Forgot Password - DotNetCloud</PageTitle>

<div class="auth-container">
    <div class="auth-card">
        <div class="auth-header">
            <span class="brand-icon">☁</span>
            <h1>Forgot Password</h1>
            <p>Enter your email to receive a reset link</p>
        </div>

        <EditForm Model="_model" OnValidSubmit="SubmitAsync" FormName="forgot-password">
            <DataAnnotationsValidator />

            <div class="form-group">
                <label for="email">Email</label>
                <InputText id="email" class="input" @bind-Value="_model!.Email" placeholder="you@example.com" />
                <ValidationMessage For="() => _model!.Email" />
            </div>

            @if (_submitted)
            {
                <div class="alert alert-success">
                    If an account exists with that email, a reset link has been sent.
                </div>
            }

            <div class="form-actions">
                <button type="submit" class="btn btn-primary btn-full" disabled="@_submitting">
                    @(_submitting ? "Sending..." : "Send Reset Link")
                </button>
            </div>
        </EditForm>

        <div class="auth-footer">
            <a href="/auth/login">Back to login</a>
        </div>
    </div>
</div>

@code {
    [Inject] private UserManager<ApplicationUser> UserManager { get; set; } = default!;
    [Inject] private ILogger<ForgotPassword> Logger { get; set; } = default!;

    [SupplyParameterFromForm]
    private ForgotPasswordModel? _model { get; set; }

    private bool _submitting;
    private bool _submitted;

    protected override void OnInitialized()
    {
        _model ??= new();
    }

    private async Task SubmitAsync()
    {
        _model ??= new();
        _submitting = true;
        try
        {
            var user = await UserManager.FindByEmailAsync(_model.Email);
            if (user is not null)
            {
                var token = await UserManager.GeneratePasswordResetTokenAsync(user);
                Logger.LogInformation("Password reset token generated for {Email}: {Token}", _model.Email, token);
            }
            _submitted = true;
        }
        finally
        {
            _submitting = false;
        }
    }

    private sealed class ForgotPasswordModel
    {
        public string Email { get; set; } = string.Empty;
    }
}
