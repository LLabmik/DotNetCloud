@page "/auth/mfa-verify"
@layout AuthLayout

<PageTitle>MFA Verification - DotNetCloud</PageTitle>

<div class="auth-container">
    <div class="auth-card">
        <div class="auth-header">
            <img class="auth-logo" src="/_content/DotNetCloud.UI.Web/logo.png" alt="DotNetCloud" />
            <h1>Two-Factor Authentication</h1>
            <p>Enter the code from your authenticator app</p>
        </div>

        <form method="post" action="/auth/session/mfa-verify" data-enhance-nav="false">
            <div class="form-group">
                <label for="code">Verification Code</label>
                <input id="code" name="code" class="input input-code" type="text"
                       inputmode="numeric" pattern="[0-9]*" maxlength="6"
                       placeholder="000000" required autofocus />
            </div>

            <input type="hidden" name="returnUrl" value="@SafeReturnUrl" />

            @if (!string.IsNullOrWhiteSpace(Error))
            {
                <div class="alert alert-danger">@Error</div>
            }

            <div class="form-actions">
                <button type="submit" class="btn btn-primary btn-full">Verify</button>
            </div>
        </form>

        <div class="session-info">
            Sessions expire after 24 hours of inactivity.
        </div>

        <div class="auth-footer">
            <a href="/auth/login">Back to login</a>
        </div>
    </div>
</div>

@code {
    [SupplyParameterFromQuery]
    private string? ReturnUrl { get; set; }

    [SupplyParameterFromQuery]
    private string? Error { get; set; }

    private string SafeReturnUrl => IsSafeLocalReturnUrl(ReturnUrl) ? ReturnUrl! : "/";

    private static bool IsSafeLocalReturnUrl(string? returnUrl)
    {
        return !string.IsNullOrWhiteSpace(returnUrl)
            && returnUrl.StartsWith("/", StringComparison.Ordinal)
            && !returnUrl.StartsWith("//", StringComparison.Ordinal);
    }
}
