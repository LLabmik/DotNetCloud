@page "/auth/mfa-verify"
@using Microsoft.AspNetCore.Identity
@using DotNetCloud.Core.Data.Entities.Identity
@layout AuthLayout

<PageTitle>MFA Verification - DotNetCloud</PageTitle>

<div class="auth-container">
    <div class="auth-card">
        <div class="auth-header">
            <span class="brand-icon">☁</span>
            <h1>Two-Factor Authentication</h1>
            <p>Enter the code from your authenticator app</p>
        </div>

        <EditForm Model="_model" OnValidSubmit="VerifyAsync" FormName="mfa-verify">
            <div class="form-group">
                <label for="code">Verification Code</label>
                <InputText id="code" class="input input-code" @bind-Value="_model!.Code"
                           placeholder="000000" maxlength="6" />
            </div>

            @if (!string.IsNullOrWhiteSpace(_errorMessage))
            {
                <div class="alert alert-danger">@_errorMessage</div>
            }

            <div class="form-actions">
                <button type="submit" class="btn btn-primary btn-full" disabled="@_submitting">
                    @(_submitting ? "Verifying..." : "Verify")
                </button>
            </div>
        </EditForm>

        <div class="auth-footer">
            <a href="/auth/login">Back to login</a>
        </div>
    </div>
</div>

@code {
    [Inject] private SignInManager<ApplicationUser> SignInManager { get; set; } = default!;
    [Inject] private NavigationManager Navigation { get; set; } = default!;

    [SupplyParameterFromForm]
    private MfaModel? _model { get; set; }

    private bool _submitting;
    private string? _errorMessage;

    protected override void OnInitialized()
    {
        _model ??= new();
    }

    private async Task VerifyAsync()
    {
        _model ??= new();
        _errorMessage = null;
        _submitting = true;
        try
        {
            var result = await SignInManager.TwoFactorAuthenticatorSignInAsync(
                _model.Code, isPersistent: true, rememberClient: true);

            if (result.Succeeded)
            {
                Navigation.NavigateTo("/admin", forceLoad: true);
                return;
            }

            if (result.IsLockedOut)
            {
                _errorMessage = "Account locked. Please try again later.";
            }
            else
            {
                _errorMessage = "Invalid verification code.";
            }
        }
        finally
        {
            _submitting = false;
        }
    }

    private sealed class MfaModel
    {
        public string Code { get; set; } = string.Empty;
    }
}
