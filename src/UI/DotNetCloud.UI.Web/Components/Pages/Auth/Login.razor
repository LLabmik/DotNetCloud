@page "/auth/login"
@layout AuthLayout

<PageTitle>Login - DotNetCloud</PageTitle>

<div class="auth-container">
    <div class="auth-card">
        <div class="auth-header">
            <img class="auth-logo" src="/_content/DotNetCloud.UI.Web/logo.png" alt="DotNetCloud" />
            <h1>DotNetCloud</h1>
            <p>Sign in to your account</p>
        </div>

        <form method="post" action="/auth/session/login">
            <div class="form-group">
                <label for="email">Email</label>
                <input id="email" name="email" class="input" type="email" required value="@Email" placeholder="you@example.com" />
            </div>

            <div class="form-group">
                <label for="password">Password</label>
                <input id="password" name="password" class="input" type="password" required />
            </div>

            <input type="hidden" name="returnUrl" value="@SafeReturnUrl" />

            @if (!string.IsNullOrWhiteSpace(Error))
            {
                <div class="alert alert-danger">@Error</div>
            }

            <div class="form-actions">
                <button type="submit" class="btn btn-primary btn-full">Sign In</button>
            </div>
        </form>

        <div class="auth-footer">
            <a href="/auth/forgot-password">Forgot password?</a>
            <span class="separator">|</span>
            <a href="/auth/register">Create an account</a>
        </div>
    </div>
</div>

@code {
    [SupplyParameterFromQuery]
    private string? ReturnUrl { get; set; }

    [SupplyParameterFromQuery]
    private string? Error { get; set; }

    [SupplyParameterFromQuery]
    private string? Email { get; set; }

    private string SafeReturnUrl => IsSafeLocalReturnUrl(ReturnUrl) ? ReturnUrl! : "/";

    protected override void OnParametersSet()
    {
        Email ??= string.Empty;
    }

    private static bool IsSafeLocalReturnUrl(string? returnUrl)
    {
        return !string.IsNullOrWhiteSpace(returnUrl)
            && returnUrl.StartsWith("/", StringComparison.Ordinal)
            && !returnUrl.StartsWith("//", StringComparison.Ordinal);
    }

}
