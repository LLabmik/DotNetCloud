@page "/"
@using Microsoft.AspNetCore.Authorization

<PageTitle>DotNetCloud</PageTitle>

<AuthorizeView>
    <Authorized>
        <div class="dashboard">
            <h1>Welcome to DotNetCloud</h1>
            <p>Your self-hosted cloud platform.</p>
        </div>
    </Authorized>
    <NotAuthorized>
        <RedirectToLogin />
    </NotAuthorized>
</AuthorizeView>

@code {
    [Inject] private NavigationManager Navigation { get; set; } = default!;
}
