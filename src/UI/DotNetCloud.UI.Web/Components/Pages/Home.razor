@page "/"
@using Microsoft.AspNetCore.Authorization

<PageTitle>DotNetCloud</PageTitle>

<AuthorizeView>
    <Authorized>
        <RedirectToDashboard />
    </Authorized>
    <NotAuthorized>
        <RedirectToLogin />
    </NotAuthorized>
</AuthorizeView>

@code {
    [Inject] private NavigationManager Navigation { get; set; } = default!;
}
