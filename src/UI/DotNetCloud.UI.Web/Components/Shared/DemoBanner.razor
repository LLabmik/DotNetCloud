@using System.Security.Claims
@using DotNetCloud.UI.Web.Client.Services
@using DotNetCloud.Core.DTOs
@inject AuthenticationStateProvider AuthStateProvider
@inject DotNetCloudApiClient ApiClient

@if (_showBanner)
{
    var daysRemaining = _daysRemaining;
    var alertClass = daysRemaining switch
    {
        0 => "alert alert-danger demo-banner",
        <= 1 => "alert alert-danger demo-banner",
        <= 2 => "alert alert-warning demo-banner",
        _ => "alert alert-info demo-banner"
    };
    var expiryDate = _expiresAt?.ToString("MMMM d, yyyy") ?? "soon";

    <div class="@alertClass" role="alert">
        <div class="demo-banner-content">
            <span class="demo-banner-icon">
                @(daysRemaining switch
                {
                    0 => "⚠️",
                    <= 1 => "🔴",
                    <= 2 => "🟡",
                    _ => "⏳"
                })
            </span>
            <span class="demo-banner-text">
                @if (daysRemaining == 0)
                {
                    <strong>Your demo account has expired</strong>
                    <span> and will be deleted soon. All your data will be permanently removed.</span>
                }
                else
                {
                    <strong>Demo Account — @daysRemaining day@(daysRemaining == 1 ? "" : "s") remaining</strong>
                    <span>. Your account and all data will be deleted on @expiryDate. Upgrade to keep your data.</span>
                }
            </span>
        </div>
    </div>
}

@code {
    private bool _showBanner;
    private int _daysRemaining;
    private DateTime? _expiresAt;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;

            if (user.Identity?.IsAuthenticated == true)
            {
                var userIdClaim = user.FindFirst(ClaimTypes.NameIdentifier)
                    ?? user.FindFirst("sub");

                if (userIdClaim is not null && Guid.TryParse(userIdClaim.Value, out var userId))
                {
                    var userDto = await ApiClient.GetUserAsync(userId);
                    if (userDto?.IsDemoUser == true)
                    {
                        _showBanner = true;
                        _expiresAt = userDto.DemoExpiresAt;
                        _daysRemaining = _expiresAt.HasValue
                            ? Math.Max(0, (int)(_expiresAt.Value - DateTime.UtcNow).TotalDays)
                            : 0;
                    }
                }
            }
        }
        catch
        {
            // If we can't determine demo status, don't show the banner
            _showBanner = false;
        }
    }
}
