@using DotNetCloud.Core.DTOs.Search
@using Microsoft.AspNetCore.Components

<button class="result-card" @onclick="OnClick">
    <div class="result-card-icon">
        <span class="result-module-icon">@GetModuleIcon(Item.ModuleId)</span>
    </div>
    <div class="result-card-body">
        <div class="result-card-header">
            <span class="result-title">@((MarkupString)SanitizeHighlight(Item.Title))</span>
            <span class="result-module-badge">@FormatModuleName(Item.ModuleId)</span>
        </div>
        @if (!string.IsNullOrWhiteSpace(Item.Snippet))
        {
            <p class="result-snippet">@((MarkupString)SanitizeHighlight(Item.Snippet))</p>
        }
        <div class="result-meta">
            @switch (Item.ModuleId)
            {
                case "files":
                    @if (Item.Metadata.TryGetValue("MimeType", out var mimeType))
                    {
                        <span class="meta-tag">@GetFileTypeLabel(mimeType)</span>
                    }
                    @if (Item.Metadata.TryGetValue("Path", out var path))
                    {
                        <span class="meta-path">@path</span>
                    }
                    @if (Item.Metadata.TryGetValue("Size", out var size) && long.TryParse(size, out var sizeBytes))
                    {
                        <span class="meta-tag">@FormatFileSize(sizeBytes)</span>
                    }
                    break;

                case "notes":
                    @if (Item.Metadata.TryGetValue("Format", out var noteFormat))
                    {
                        <span class="meta-tag">@noteFormat</span>
                    }
                    @if (Item.Metadata.TryGetValue("FolderId", out var folderId) && folderId != Guid.Empty.ToString())
                    {
                        <span class="meta-tag">📂 In folder</span>
                    }
                    break;

                case "chat":
                    <span class="meta-tag">💬 Message</span>
                    @if (Item.Metadata.TryGetValue("ChannelId", out _))
                    {
                        <span class="meta-tag">In channel</span>
                    }
                    break;

                case "contacts":
                    @if (Item.Metadata.TryGetValue("ContactType", out var contactType))
                    {
                        <span class="meta-tag">@contactType</span>
                    }
                    break;

                case "calendar":
                    @if (Item.Metadata.TryGetValue("StartUtc", out var startUtc) && DateTimeOffset.TryParse(startUtc, out var start))
                    {
                        <span class="meta-tag">📅 @start.LocalDateTime.ToString("MMM d, yyyy h:mm tt")</span>
                    }
                    @if (Item.Metadata.TryGetValue("Location", out var location) && !string.IsNullOrWhiteSpace(location))
                    {
                        <span class="meta-tag">📍 @location</span>
                    }
                    break;

                case "photos":
                    @if (Item.Metadata.TryGetValue("AlbumId", out _))
                    {
                        <span class="meta-tag">📷 In album</span>
                    }
                    @if (Item.Metadata.TryGetValue("Camera", out var camera) && !string.IsNullOrWhiteSpace(camera))
                    {
                        <span class="meta-tag">📸 @camera</span>
                    }
                    break;

                case "music":
                    @if (Item.Metadata.TryGetValue("Genre", out var genre) && !string.IsNullOrWhiteSpace(genre))
                    {
                        <span class="meta-tag">🎵 @genre</span>
                    }
                    @if (Item.Metadata.TryGetValue("Year", out var year) && !string.IsNullOrWhiteSpace(year))
                    {
                        <span class="meta-tag">@year</span>
                    }
                    break;

                case "video":
                    @if (Item.Metadata.TryGetValue("Duration", out var duration) && !string.IsNullOrWhiteSpace(duration))
                    {
                        <span class="meta-tag">🎬 @duration</span>
                    }
                    break;

                case "tracks":
                    @if (Item.Metadata.TryGetValue("Status", out var cardStatus))
                    {
                        <span class="meta-tag status-badge">@cardStatus</span>
                    }
                    @if (Item.Metadata.TryGetValue("Labels", out var labels) && !string.IsNullOrWhiteSpace(labels))
                    {
                        @foreach (var label in labels.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries).Take(3))
                        {
                            <span class="meta-tag label-badge">@label</span>
                        }
                    }
                    break;

                case "ai":
                    <span class="meta-tag">🤖 Conversation</span>
                    break;
            }
            <span class="meta-date">@FormatDate(Item.UpdatedAt)</span>
        </div>
    </div>
</button>

@code {
    /// <summary>The search result item to render.</summary>
    [Parameter, EditorRequired]
    public SearchResultItem Item { get; set; } = default!;

    /// <summary>Click callback.</summary>
    [Parameter]
    public EventCallback OnClick { get; set; }

    /// <summary>
    /// Sanitizes highlight markup. Only allows &lt;mark&gt; tags, strips everything else.
    /// The input is already HTML-encoded by SnippetGenerator (XSS-safe), so we only need
    /// to preserve the <c>&lt;mark&gt;</c> tags that were applied after encoding.
    /// </summary>
    private static string SanitizeHighlight(string html)
    {
        if (string.IsNullOrEmpty(html)) return html;

        // The SnippetGenerator already HTML-encodes content before inserting <mark> tags,
        // so the only raw HTML present should be <mark>...</mark> pairs.
        // Strip any tags that are NOT <mark> or </mark> to prevent XSS.
        return StripNonMarkTags(html);
    }

    /// <summary>Removes all HTML tags except &lt;mark&gt; and &lt;/mark&gt;.</summary>
    private static string StripNonMarkTags(string input)
    {
        // Replace <mark> tags with placeholders, strip all other tags, restore marks
        var result = input
            .Replace("<mark>", "\x01MO\x01")
            .Replace("</mark>", "\x01MC\x01");

        // Remove any remaining HTML tags (shouldn't exist if SnippetGenerator is correct)
        result = System.Text.RegularExpressions.Regex.Replace(result, @"<[^>]+>", string.Empty);

        return result
            .Replace("\x01MO\x01", "<mark>")
            .Replace("\x01MC\x01", "</mark>");
    }

    private static string FormatDate(DateTimeOffset date)
    {
        var diff = DateTimeOffset.UtcNow - date;
        if (diff.TotalMinutes < 1) return "Just now";
        if (diff.TotalHours < 1) return $"{(int)diff.TotalMinutes}m ago";
        if (diff.TotalDays < 1) return $"{(int)diff.TotalHours}h ago";
        if (diff.TotalDays < 7) return $"{(int)diff.TotalDays}d ago";
        return date.LocalDateTime.ToString("MMM d, yyyy");
    }

    private static string FormatFileSize(long bytes)
    {
        if (bytes < 1024) return $"{bytes} B";
        if (bytes < 1024 * 1024) return $"{bytes / 1024.0:F1} KB";
        if (bytes < 1024 * 1024 * 1024) return $"{bytes / (1024.0 * 1024.0):F1} MB";
        return $"{bytes / (1024.0 * 1024.0 * 1024.0):F1} GB";
    }

    private static string GetFileTypeLabel(string mimeType) => mimeType switch
    {
        "application/pdf" => "PDF",
        "application/vnd.openxmlformats-officedocument.wordprocessingml.document" => "DOCX",
        "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet" => "XLSX",
        "text/plain" => "Text",
        "text/markdown" => "Markdown",
        "text/csv" => "CSV",
        _ when mimeType.StartsWith("image/") => "Image",
        _ when mimeType.StartsWith("video/") => "Video",
        _ when mimeType.StartsWith("audio/") => "Audio",
        _ => mimeType.Split('/').LastOrDefault() ?? "File"
    };

    private static string GetModuleIcon(string moduleId) => moduleId switch
    {
        "files" => "📁",
        "notes" => "📝",
        "chat" => "💬",
        "contacts" => "👤",
        "calendar" => "📅",
        "photos" => "📷",
        "music" => "🎵",
        "video" => "🎬",
        "tracks" => "📋",
        "ai" => "🤖",
        _ => "🔍"
    };

    private static string FormatModuleName(string moduleId) => moduleId switch
    {
        "files" => "Files",
        "notes" => "Notes",
        "chat" => "Chat",
        "contacts" => "Contacts",
        "calendar" => "Calendar",
        "photos" => "Photos",
        "music" => "Music",
        "video" => "Video",
        "tracks" => "Tracks",
        "ai" => "AI",
        _ => moduleId
    };
}
