@using DotNetCloud.Core.DTOs.Search
@using DotNetCloud.UI.Web.Client.Services
@inject DotNetCloudApiClient Api
@inject NavigationManager Navigation
@inject IJSRuntime JS
@implements IAsyncDisposable

<div class="search-trigger-wrapper">
    <button class="search-trigger" @onclick="OpenSearch" title="Search (Ctrl+K)">
        <span class="search-trigger-icon">🔍</span>
        <span class="search-trigger-text">Search…</span>
        <kbd class="search-trigger-kbd">Ctrl+K</kbd>
    </button>
</div>

@if (_isOpen)
{
    <div class="search-overlay" @onclick="CloseSearch" @onkeydown="OnOverlayKeyDown">
        <div class="search-modal" @onclick:stopPropagation="true">
            <div class="search-input-wrapper">
                <span class="search-input-icon">🔍</span>
                <input id="global-search-input"
                       type="text"
                       class="search-input"
                       placeholder="Search files, notes, messages, contacts…"
                       autocomplete="off"
                       @bind="_query"
                       @bind:event="oninput"
                       @bind:after="OnQueryChanged"
                       @onkeydown="OnInputKeyDown" />
                @if (!string.IsNullOrEmpty(_query))
                {
                    <button class="search-clear-btn" @onclick="ClearQuery" title="Clear">✕</button>
                }
                <kbd class="search-esc-hint">ESC</kbd>
            </div>

            <div class="search-body">
                @if (_isLoading)
                {
                    <div class="search-loading">
                        <div class="search-spinner"></div>
                        <span>Searching…</span>
                    </div>
                }
                else if (_suggestions is not null && _suggestions.Count > 0)
                {
                    <div class="search-suggestions">
                        <div class="search-section-label">Results</div>
                        @for (var i = 0; i < _suggestions.Count; i++)
                        {
                            var item = _suggestions[i];
                            var idx = i;
                            <button class="search-suggestion-item @(idx == _selectedIndex ? "selected" : "")"
                                    @onclick="() => NavigateToResult(item)"
                                    @onmouseenter="() => _selectedIndex = idx">
                                <span class="suggestion-icon">@GetModuleIcon(item.ModuleId)</span>
                                <div class="suggestion-content">
                                    <span class="suggestion-title">@StripHighlight(item.Title)</span>
                                    @if (!string.IsNullOrWhiteSpace(item.Snippet))
                                    {
                                        <span class="suggestion-snippet">@StripHighlight(item.Snippet)</span>
                                    }
                                </div>
                                <span class="suggestion-badge">@FormatModuleName(item.ModuleId)</span>
                            </button>
                        }
                        @if (!string.IsNullOrWhiteSpace(_query))
                        {
                            <button class="search-view-all" @onclick="ViewAllResults">
                                View all results for "<strong>@_query</strong>" →
                            </button>
                        }
                    </div>
                }
                else if (!string.IsNullOrWhiteSpace(_query) && _hasSearched)
                {
                    <div class="search-empty">
                        <span class="search-empty-icon">🔎</span>
                        <p>No results found for "<strong>@_query</strong>"</p>
                        <p class="search-empty-hint">Try different keywords or check spelling</p>
                    </div>
                }
                else if (_recentSearches.Count > 0)
                {
                    <div class="search-recent">
                        <div class="search-section-header">
                            <span class="search-section-label">Recent searches</span>
                            <button class="search-clear-recent" @onclick="ClearRecentSearches">Clear</button>
                        </div>
                        @foreach (var recent in _recentSearches)
                        {
                            <button class="search-recent-item" @onclick="() => UseRecentSearch(recent)">
                                <span class="recent-icon">🕓</span>
                                <span class="recent-text">@recent</span>
                            </button>
                        }
                    </div>
                }
                else
                {
                    <div class="search-empty">
                        <span class="search-empty-icon">🔍</span>
                        <p>Start typing to search across all modules</p>
                        <p class="search-empty-hint">Files, notes, messages, contacts, calendar events, and more</p>
                    </div>
                }
            </div>

            <div class="search-footer">
                <span class="search-footer-hint">
                    <kbd>↵</kbd> to select
                    <kbd>↑↓</kbd> to navigate
                    <kbd>ESC</kbd> to close
                </span>
            </div>
        </div>
    </div>
}

@code {
    private string _query = string.Empty;
    private bool _isOpen;
    private bool _isLoading;
    private bool _hasSearched;
    private int _selectedIndex = -1;
    private IReadOnlyList<SearchResultItem>? _suggestions;
    private List<string> _recentSearches = [];
    private DotNetObjectReference<GlobalSearchBar>? _dotNetRef;
    private CancellationTokenSource? _debounceCts;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _dotNetRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("DotNetCloudSearch.registerShortcut", _dotNetRef);
        }
    }

    /// <summary>Invoked from JavaScript when Ctrl+K is pressed.</summary>
    [JSInvokable]
    public async Task OnSearchShortcut()
    {
        await OpenSearch();
        StateHasChanged();
    }

    private async Task OpenSearch()
    {
        _isOpen = true;
        _query = string.Empty;
        _suggestions = null;
        _hasSearched = false;
        _selectedIndex = -1;
        await LoadRecentSearches();
        StateHasChanged();
        // Focus the input after render
        await Task.Yield();
        await JS.InvokeVoidAsync("DotNetCloudSearch.focusElement", "#global-search-input");
    }

    private void CloseSearch()
    {
        _isOpen = false;
        _query = string.Empty;
        _suggestions = null;
        _hasSearched = false;
        _selectedIndex = -1;
    }

    private void ClearQuery()
    {
        _query = string.Empty;
        _suggestions = null;
        _hasSearched = false;
        _selectedIndex = -1;
    }

    private async Task OnQueryChanged()
    {
        _debounceCts?.Cancel();
        _debounceCts = new CancellationTokenSource();
        var token = _debounceCts.Token;
        _selectedIndex = -1;

        if (string.IsNullOrWhiteSpace(_query) || _query.Length < 2)
        {
            _suggestions = null;
            _hasSearched = false;
            return;
        }

        try
        {
            await Task.Delay(300, token);
        }
        catch (TaskCanceledException)
        {
            return;
        }

        _isLoading = true;
        StateHasChanged();

        try
        {
            _suggestions = await Api.SearchSuggestAsync(_query, token);
            _hasSearched = true;
        }
        catch (TaskCanceledException)
        {
            return;
        }
        catch
        {
            _suggestions = null;
            _hasSearched = true;
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void OnInputKeyDown(KeyboardEventArgs e)
    {
        switch (e.Key)
        {
            case "Escape":
                CloseSearch();
                break;
            case "ArrowDown":
                if (_suggestions is not null && _suggestions.Count > 0)
                    _selectedIndex = Math.Min(_selectedIndex + 1, _suggestions.Count - 1);
                break;
            case "ArrowUp":
                if (_suggestions is not null)
                    _selectedIndex = Math.Max(_selectedIndex - 1, 0);
                break;
            case "Enter":
                if (_suggestions is not null && _selectedIndex >= 0 && _selectedIndex < _suggestions.Count)
                    NavigateToResult(_suggestions[_selectedIndex]);
                else if (!string.IsNullOrWhiteSpace(_query))
                    ViewAllResults();
                break;
        }
    }

    private void OnOverlayKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Escape")
            CloseSearch();
    }

    private void NavigateToResult(SearchResultItem item)
    {
        SaveRecentSearch(_query);
        CloseSearch();
        var url = GetResultUrl(item);
        Navigation.NavigateTo(url);
    }

    private void ViewAllResults()
    {
        if (string.IsNullOrWhiteSpace(_query)) return;
        SaveRecentSearch(_query);
        CloseSearch();
        Navigation.NavigateTo($"/search?q={Uri.EscapeDataString(_query)}");
    }

    private async Task UseRecentSearch(string query)
    {
        _query = query;
        await OnQueryChanged();
    }

    private async Task LoadRecentSearches()
    {
        try
        {
            var searches = await JS.InvokeAsync<string[]>("DotNetCloudSearch.getRecentSearches");
            _recentSearches = searches?.ToList() ?? [];
        }
        catch
        {
            _recentSearches = [];
        }
    }

    private async void SaveRecentSearch(string query)
    {
        if (string.IsNullOrWhiteSpace(query)) return;
        try
        {
            await JS.InvokeVoidAsync("DotNetCloudSearch.addRecentSearch", query);
        }
        catch
        {
            // Ignore localStorage errors
        }
    }

    private async Task ClearRecentSearches()
    {
        _recentSearches.Clear();
        try
        {
            await JS.InvokeVoidAsync("DotNetCloudSearch.clearRecentSearches");
        }
        catch
        {
            // Ignore
        }
    }

    private static string GetResultUrl(SearchResultItem item)
    {
        var nav = DateTimeOffset.UtcNow.ToUnixTimeMilliseconds();
        return item.ModuleId switch
        {
            "files" => $"/apps/files?fileId={item.EntityId}&_nav={nav}",
        "notes" => $"/apps/notes?noteId={item.EntityId}",
        "chat" => item.Metadata.TryGetValue("ChannelId", out var channelId)
            ? $"/apps/chat?channelId={channelId}&messageId={item.EntityId}"
            : $"/apps/chat?messageId={item.EntityId}",
        "contacts" => $"/apps/contacts?contactId={item.EntityId}",
        "calendar" => $"/apps/calendar?eventId={item.EntityId}",
        "photos" => $"/apps/photos?photoId={item.EntityId}",
        "music" => $"/apps/music?trackId={item.EntityId}",
        "video" => $"/apps/video?videoId={item.EntityId}",
        "tracks" => $"/apps/tracks?cardId={item.EntityId}",
            "ai" => $"/apps/ai?conversationId={item.EntityId}",
            _ => $"/search?q={item.Title}"
        };
    }

    private static string GetModuleIcon(string moduleId) => moduleId switch
    {
        "files" => "📁",
        "notes" => "📝",
        "chat" => "💬",
        "contacts" => "👤",
        "calendar" => "📅",
        "photos" => "📷",
        "music" => "🎵",
        "video" => "🎬",
        "tracks" => "📋",
        "ai" => "🤖",
        _ => "🔍"
    };

    private static string FormatModuleName(string moduleId) => moduleId switch
    {
        "files" => "Files",
        "notes" => "Notes",
        "chat" => "Chat",
        "contacts" => "Contacts",
        "calendar" => "Calendar",
        "photos" => "Photos",
        "music" => "Music",
        "video" => "Video",
        "tracks" => "Tracks",
        "ai" => "AI",
        _ => moduleId
    };

    /// <summary>Strips HTML highlight tags and decodes HTML entities for plain-text display in the modal.</summary>
    private static string StripHighlight(string text)
    {
        if (string.IsNullOrEmpty(text)) return text;
        var plain = text.Replace("<mark>", "").Replace("</mark>", "");
        return System.Web.HttpUtility.HtmlDecode(plain);
    }

    async ValueTask IAsyncDisposable.DisposeAsync()
    {
        _debounceCts?.Cancel();
        _debounceCts?.Dispose();
        _dotNetRef?.Dispose();
    }
}
