@inherits LayoutComponentBase
@using System.Security.Claims
@using DotNetCloud.Core.DTOs
@using DotNetCloud.Core.Services
@inject IUserSettingsService UserSettingsService
@inject AuthenticationStateProvider AuthStateProvider
@inject PersistentComponentState PersistentState
@implements IDisposable

<div class="app-container">
    <nav class="sidebar @(_collapsed ? "collapsed" : "")">
        <div class="sidebar-header">
            <a href="/" class="brand">
                <img class="brand-logo" src="/_content/DotNetCloud.UI.Web/logo.png" alt="DotNetCloud" />
            </a>
            <button class="sidebar-toggle" @onclick="ToggleSidebarAsync" title="Toggle sidebar">
                <span class="toggle-icon">@(_collapsed ? "▶" : "◀")</span>
            </button>
        </div>
        <NavMenu Collapsed="_collapsed" />
    </nav>

    <div class="main-content">
        <header class="topbar">
            <div class="topbar-left">
                <h1 class="page-title">@_pageTitle</h1>
            </div>
            <div class="topbar-center">
                <AuthorizeView>
                    <Authorized>
                        <GlobalSearchBar @rendermode="InteractiveServer" />
                    </Authorized>
                </AuthorizeView>
            </div>
            <div class="topbar-right">
                <CultureSelector @rendermode="InteractiveAuto" />
                <NotificationBell @rendermode="InteractiveAuto" />
                <button
                    id="theme-toggle-button"
                    class="theme-toggle"
                    type="button"
                    title="Toggle theme"
                    aria-label="Toggle theme">
                    ☾
                </button>
                <AuthorizeView>
                    <Authorized>
                        <div class="user-menu">
                            <a href="profile" class="user-name-link">@context.User.Identity?.Name</a>
                            <a href="auth/logout" class="btn btn-sm btn-outline">Logout</a>
                        </div>
                    </Authorized>
                </AuthorizeView>
            </div>
        </header>

        <main class="page-content">
            <article class="content-area">
                <ErrorBoundary @ref="_errorBoundary">
                    <ChildContent>
                        @Body
                    </ChildContent>
                    <ErrorContent Context="ex">
                        <ErrorDisplay Exception="ex" OnDismiss="RecoverError" />
                    </ErrorContent>
                </ErrorBoundary>
            </article>
        </main>

        <ToastContainer />
    </div>
</div>

@code {
    private const string UiSettingsModule = "dotnetcloud.ui";
    private const string NavbarCollapsedKey = "navbar.collapsed";

    private bool _collapsed;
    private string _pageTitle = "DotNetCloud";
    private ErrorBoundary? _errorBoundary;
    private PersistingComponentStateSubscription _persistingSubscription;

    protected override async Task OnInitializedAsync()
    {
        _persistingSubscription = PersistentState.RegisterOnPersisting(PersistState);

        if (PersistentState.TryTakeFromJson<bool>(NavbarCollapsedKey, out var restored))
        {
            _collapsed = restored;
        }
        else
        {
            await LoadSidebarPreferenceAsync();
        }
    }

    private Task PersistState()
    {
        PersistentState.PersistAsJson(NavbarCollapsedKey, _collapsed);
        return Task.CompletedTask;
    }

    private async Task ToggleSidebarAsync()
    {
        _collapsed = !_collapsed;
        await SaveSidebarPreferenceAsync();
    }

    private async Task LoadSidebarPreferenceAsync()
    {
        var userId = await GetAuthenticatedUserIdAsync();
        if (userId is null)
        {
            return;
        }

        try
        {
            var setting = await UserSettingsService.GetSettingAsync(userId.Value, UiSettingsModule, NavbarCollapsedKey);
            _collapsed = setting is not null && bool.TryParse(setting.Value, out var isCollapsed) && isCollapsed;
        }
        catch
        {
            _collapsed = false;
        }
    }

    private async Task SaveSidebarPreferenceAsync()
    {
        var userId = await GetAuthenticatedUserIdAsync();
        if (userId is null)
        {
            return;
        }

        try
        {
            await UserSettingsService.UpsertSettingAsync(
                userId.Value,
                UiSettingsModule,
                NavbarCollapsedKey,
                new UpsertUserSettingDto
                {
                    Value = _collapsed.ToString().ToLowerInvariant(),
                    Description = "Whether the user prefers the left navigation collapsed.",
                    IsSensitive = false,
                });
        }
        catch
        {
            // Intentionally ignored so the UI remains responsive if preference persistence fails.
        }
    }

    private async Task<Guid?> GetAuthenticatedUserIdAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        var claimValue = user.FindFirst(ClaimTypes.NameIdentifier)?.Value
            ?? user.FindFirst("sub")?.Value;

        return Guid.TryParse(claimValue, out var userId) ? userId : null;
    }

    private void RecoverError() => _errorBoundary?.Recover();

    public void Dispose() => _persistingSubscription.Dispose();
}
