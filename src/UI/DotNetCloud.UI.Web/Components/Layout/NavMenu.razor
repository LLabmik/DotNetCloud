@using Microsoft.AspNetCore.Components.Routing
@using DotNetCloud.UI.Web.Services

@inject ModuleUiRegistry ModuleRegistry
@implements IDisposable

<nav class="nav-menu">
    <AuthorizeView>
        <Authorized>
            <ul class="nav-list">
                <li class="nav-item">
                    <NavLink href="/"
                             Match="NavLinkMatch.All"
                             class="nav-link"
                             title="Home"
                             aria-label="Home">
                        <span class="nav-icon">🏠</span>
                        @if (!Collapsed)
                        {
                            <span class="nav-text">Home</span>
                        }
                    </NavLink>
                </li>
            </ul>

            <AuthorizeView Policy="RequireAdmin">
                <Authorized Context="adminContext">
                    <div class="nav-separator"></div>
                    <ul class="nav-list">
                        <li class="nav-item">
                            <NavLink href="/admin"
                                     Match="NavLinkMatch.All"
                                     class="nav-link"
                                     title="Dashboard"
                                     aria-label="Dashboard">
                                <span class="nav-icon">📊</span>
                                @if (!Collapsed)
                                {
                                    <span class="nav-text">Dashboard</span>
                                }
                            </NavLink>
                        </li>
                        <li class="nav-item">
                            <NavLink href="/admin/users"
                                     Match="NavLinkMatch.Prefix"
                                     class="nav-link"
                                     title="Users"
                                     aria-label="Users">
                                <span class="nav-icon">👥</span>
                                @if (!Collapsed)
                                {
                                    <span class="nav-text">Users</span>
                                }
                            </NavLink>
                        </li>
                        <li class="nav-item">
                            <NavLink href="/admin/organizations"
                                     Match="NavLinkMatch.Prefix"
                                     class="nav-link"
                                     title="Organizations"
                                     aria-label="Organizations">
                                <span class="nav-icon">🏢</span>
                                @if (!Collapsed)
                                {
                                    <span class="nav-text">Organizations</span>
                                }
                            </NavLink>
                        </li>
                        <li class="nav-item">
                            <NavLink href="/admin/modules"
                                     Match="NavLinkMatch.Prefix"
                                     class="nav-link"
                                     title="Modules"
                                     aria-label="Modules">
                                <span class="nav-icon">📦</span>
                                @if (!Collapsed)
                                {
                                    <span class="nav-text">Modules</span>
                                }
                            </NavLink>
                        </li>
                        <li class="nav-item">
                            <NavLink href="/admin/settings"
                                     Match="NavLinkMatch.Prefix"
                                     class="nav-link"
                                     title="Settings"
                                     aria-label="Settings">
                                <span class="nav-icon">⚙</span>
                                @if (!Collapsed)
                                {
                                    <span class="nav-text">Settings</span>
                                }
                            </NavLink>
                        </li>
                        <li class="nav-item">
                            <NavLink href="/admin/health"
                                     Match="NavLinkMatch.Prefix"
                                     class="nav-link"
                                     title="Health"
                                     aria-label="Health">
                                <span class="nav-icon">💚</span>
                                @if (!Collapsed)
                                {
                                    <span class="nav-text">Health</span>
                                }
                            </NavLink>
                        </li>
                        <li class="nav-item">
                            <NavLink href="/admin/search"
                                     Match="NavLinkMatch.Prefix"
                                     class="nav-link"
                                     title="Search"
                                     aria-label="Search">
                                <span class="nav-icon">🔍</span>
                                @if (!Collapsed)
                                {
                                    <span class="nav-text">Search</span>
                                }
                            </NavLink>
                        </li>
                        <li class="nav-item">
                            <NavLink href="/admin/sync-devices"
                                     Match="NavLinkMatch.Prefix"
                                     class="nav-link"
                                     title="Sync Devices"
                                     aria-label="Sync Devices">
                                <span class="nav-icon">🔄</span>
                                @if (!Collapsed)
                                {
                                    <span class="nav-text">Sync Devices</span>
                                }
                            </NavLink>
                        </li>
                        <li class="nav-item">
                            <NavLink href="/admin/backup"
                                     Match="NavLinkMatch.Prefix"
                                     class="nav-link"
                                     title="Backup"
                                     aria-label="Backup">
                                <span class="nav-icon">💾</span>
                                @if (!Collapsed)
                                {
                                    <span class="nav-text">Backup</span>
                                }
                            </NavLink>
                        </li>
                        <li class="nav-item">
                            <NavLink href="/admin/updates"
                                     Match="NavLinkMatch.Prefix"
                                     class="nav-link"
                                     title="Updates"
                                     aria-label="Updates">
                                <span class="nav-icon">⬆</span>
                                @if (!Collapsed)
                                {
                                    <span class="nav-text">Updates</span>
                                }
                            </NavLink>
                        </li>
                    </ul>
                </Authorized>
            </AuthorizeView>

            @if (ModuleRegistry.NavItems.Count > 0)
            {
                <div class="nav-separator"></div>
                <ul class="nav-list">
                    @foreach (var item in ModuleRegistry.NavItems)
                    {
                        <li class="nav-item">
                            <NavLink href="@item.Href"
                                     Match="NavLinkMatch.Prefix"
                                     class="nav-link"
                                     title="@item.Label"
                                     aria-label="@item.Label">
                                <span class="nav-icon">@item.Icon</span>
                                @if (!Collapsed)
                                {
                                    <span class="nav-text">@item.Label</span>
                                }
                            </NavLink>
                        </li>
                    }
                </ul>
            }
        </Authorized>
        <NotAuthorized>
            <ul class="nav-list">
                <li class="nav-item">
                    <NavLink href="/auth/login"
                             class="nav-link"
                             title="Login"
                             aria-label="Login">
                        <span class="nav-icon">🔑</span>
                        @if (!Collapsed)
                        {
                            <span class="nav-text">Login</span>
                        }
                    </NavLink>
                </li>
            </ul>
        </NotAuthorized>
    </AuthorizeView>
</nav>

@code {
    [Parameter]
    public bool Collapsed { get; set; }

    protected override void OnInitialized()
    {
        ModuleRegistry.OnChange += StateHasChanged;
    }

    public void Dispose()
    {
        ModuleRegistry.OnChange -= StateHasChanged;
    }
}
