<Project Sdk="Microsoft.NET.Sdk.Razor">

  <PropertyGroup>
    <TargetFramework>net10.0-android</TargetFramework>
    <OutputType>Exe</OutputType>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>DotNetCloud.UI.Android</RootNamespace>
    <AssemblyName>DotNetCloud.UI.Android</AssemblyName>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>

    <!-- Android manifest settings -->
    <ApplicationId>cloud.dotnet.app</ApplicationId>
    <ApplicationDisplayVersion>1.0</ApplicationDisplayVersion>
    <ApplicationVersion>1</ApplicationVersion>
    <SupportedOSPlatformVersion>24</SupportedOSPlatformVersion>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Maui.Controls" />
    <PackageReference Include="Microsoft.Maui.Controls.Compatibility" />
    <PackageReference Include="Microsoft.AspNetCore.Components.WebView.Maui" />
    <PackageReference Include="Microsoft.AspNetCore.SignalR.Client" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\Core\DotNetCloud.Core\DotNetCloud.Core.csproj" />
    <ProjectReference Include="..\DotNetCloud.UI.Shared\DotNetCloud.UI.Shared.csproj" />
    <ProjectReference Include="..\..\Modules\Chat\DotNetCloud.Modules.Chat\DotNetCloud.Modules.Chat.csproj" />
  </ItemGroup>

</Project>
