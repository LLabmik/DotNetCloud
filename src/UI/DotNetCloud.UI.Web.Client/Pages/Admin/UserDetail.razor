@page "/admin/users/{UserId:guid}"
@rendermode @(new Microsoft.AspNetCore.Components.Web.InteractiveAutoRenderMode(prerender: false))
@attribute [Authorize(Policy = "RequireAdmin")]

<PageTitle>User Details - DotNetCloud</PageTitle>

@if (_loading)
{
    <LoadingIndicator Message="Loading user..." />
}
else if (_user is null)
{
    <div class="empty-state">
        <p>User not found.</p>
        <a href="/admin/users" class="btn btn-primary">Back to Users</a>
    </div>
}
else
{
    <div class="page-header">
        <h1>@_user.DisplayName</h1>
        <div class="header-actions">
            <a href="/admin/users/@_user.Id/edit" class="btn btn-outline">Edit</a>
            <a href="/admin/users" class="btn btn-outline">Back</a>
        </div>
    </div>

    <div class="detail-grid">
        <div class="detail-section">
            <h2>Profile</h2>
            <dl class="detail-list">
                <dt>Email</dt>
                <dd>@_user.Email</dd>
                <dt>Display Name</dt>
                <dd>@_user.DisplayName</dd>
                <dt>Status</dt>
                <dd>
                    <span class="badge badge-@(_user.IsActive ? "success" : "muted")">
                        @(_user.IsActive ? "Active" : "Disabled")
                    </span>
                </dd>
                <dt>Email Confirmed</dt>
                <dd>@(_user.EmailConfirmed ? "Yes" : "No")</dd>
                <dt>Locale</dt>
                <dd>@_user.Locale</dd>
                <dt>Timezone</dt>
                <dd>@_user.Timezone</dd>
                <dt>Created</dt>
                <dd>@_user.CreatedAt.ToString("yyyy-MM-dd HH:mm")</dd>
                <dt>Last Login</dt>
                <dd>@(_user.LastLoginAt?.ToString("yyyy-MM-dd HH:mm") ?? "Never")</dd>
            </dl>
        </div>

        <div class="detail-section">
            <h2>Roles</h2>
            @if (_user.Roles.Count > 0)
            {
                <ul class="tag-list">
                    @foreach (var role in _user.Roles)
                    {
                        <li class="tag">
                            @role
                            @if (string.Equals(role, "Administrator", StringComparison.OrdinalIgnoreCase))
                            {
                                <span class="badge badge-warning" style="margin-left: 0.25rem;">System Admin</span>
                            }
                        </li>
                    }
                </ul>
            }
            else
            {
                <p class="text-muted">No roles assigned.</p>
            }
            <div style="margin-top: 0.75rem;">
                @if (_user.Roles.Any(r => string.Equals(r, "Administrator", StringComparison.OrdinalIgnoreCase)))
                {
                    <button class="btn btn-warning btn-sm" @onclick="RevokeAdminAsync" disabled="@_actionInProgress">
                        Revoke Admin
                    </button>
                }
                else
                {
                    <button class="btn btn-success btn-sm" @onclick="GrantAdminAsync" disabled="@_actionInProgress">
                        Grant Admin
                    </button>
                }
            </div>
        </div>

        <div class="detail-section">
            <h2>Storage Quota</h2>
            @if (_quota is not null)
            {
                <dl class="detail-list">
                    <dt>Quota</dt>
                    <dd>@(_quota.MaxBytes == 0 ? "Unlimited" : FormatBytes(_quota.MaxBytes))</dd>
                    <dt>Used</dt>
                    <dd>@FormatBytes(_quota.UsedBytes)</dd>
                    <dt>Remaining</dt>
                    <dd>@(_quota.MaxBytes == 0 ? "Unlimited" : FormatBytes(_quota.RemainingBytes))</dd>
                    <dt>Usage</dt>
                    <dd>
                        @if (_quota.MaxBytes > 0)
                        {
                            <div class="quota-bar">
                                <div class="quota-bar-fill @QuotaBarClass()" style="width: @(Math.Min(_quota.UsagePercent, 100).ToString("F0"))%"></div>
                            </div>
                            <span class="text-muted">@_quota.UsagePercent.ToString("F1")%</span>
                        }
                        else
                        {
                            <span class="text-muted">N/A (unlimited)</span>
                        }
                    </dd>
                </dl>
            }
            else
            {
                <p class="text-muted">No quota record found.</p>
            }
        </div>

        <div class="detail-section">
            <h2>Actions</h2>
            <div class="action-buttons">
                @if (_user.IsActive)
                {
                    <button class="btn btn-warning" @onclick="DisableAsync" disabled="@_actionInProgress">Disable</button>
                }
                else
                {
                    <button class="btn btn-success" @onclick="EnableAsync" disabled="@_actionInProgress">Enable</button>
                }
                <button class="btn btn-outline" @onclick="ShowResetPassword">Reset Password</button>
                <button class="btn btn-danger" @onclick="DeleteAsync" disabled="@_actionInProgress">Delete</button>
            </div>
        </div>
    </div>

    @if (_showResetPassword)
    {
        <div class="detail-section">
            <h2>Reset Password</h2>
            <div class="form-group">
                <label>New Password</label>
                <input type="password" class="input" @bind="_newPassword" />
            </div>
            <div class="form-actions">
                <button class="btn btn-primary" @onclick="ResetPasswordAsync" disabled="@_actionInProgress">Reset</button>
                <button class="btn btn-outline" @onclick="() => _showResetPassword = false">Cancel</button>
            </div>
        </div>
    }

    <ConfirmDialog @ref="_confirmDialog" />
}

@code {
    [Parameter] public Guid UserId { get; set; }
    [Inject] private DotNetCloudApiClient Api { get; set; } = default!;
    [Inject] private ToastService Toast { get; set; } = default!;
    [Inject] private NavigationManager Nav { get; set; } = default!;

    private bool _loading = true;
    private bool _actionInProgress;
    private bool _showResetPassword;
    private string _newPassword = string.Empty;
    private UserDto? _user;
    private QuotaResponse? _quota;
    private ConfirmDialog _confirmDialog = default!;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        try
        {
            _user = await Api.GetUserAsync(UserId);
            _quota = await Api.GetUserQuotaAsync(UserId);
        }
        catch { Toast.ShowError("Failed to load user."); }
        finally { _loading = false; }
    }

    private async Task DisableAsync()
    {
        if (!await _confirmDialog.ShowAsync("Are you sure you want to disable this user?", "Disable User"))
            return;
        _actionInProgress = true;
        if (await Api.DisableUserAsync(UserId))
        {
            Toast.ShowSuccess("User disabled.");
            await LoadAsync();
        }
        else Toast.ShowError("Failed to disable user.");
        _actionInProgress = false;
    }

    private async Task EnableAsync()
    {
        _actionInProgress = true;
        if (await Api.EnableUserAsync(UserId))
        {
            Toast.ShowSuccess("User enabled.");
            await LoadAsync();
        }
        else Toast.ShowError("Failed to enable user.");
        _actionInProgress = false;
    }

    private async Task DeleteAsync()
    {
        if (!await _confirmDialog.ShowAsync("This action cannot be undone. Delete this user?", "Delete User"))
            return;
        _actionInProgress = true;
        if (await Api.DeleteUserAsync(UserId))
        {
            Toast.ShowSuccess("User deleted.");
            Nav.NavigateTo("/admin/users");
        }
        else Toast.ShowError("Failed to delete user.");
        _actionInProgress = false;
    }

    private void ShowResetPassword() => _showResetPassword = true;

    private async Task ResetPasswordAsync()
    {
        if (string.IsNullOrWhiteSpace(_newPassword))
        {
            Toast.ShowWarning("Password is required.");
            return;
        }
        _actionInProgress = true;
        if (await Api.AdminResetPasswordAsync(UserId, _newPassword))
        {
            Toast.ShowSuccess("Password reset successfully.");
            _showResetPassword = false;
            _newPassword = string.Empty;
        }
        else Toast.ShowError("Failed to reset password.");
        _actionInProgress = false;
    }

    private async Task GrantAdminAsync()
    {
        _actionInProgress = true;
        try
        {
            var roles = new List<string>(_user!.Roles) { "Administrator" };
            var result = await Api.SetUserRolesAsync(UserId, roles);
            if (result is not null)
            {
                Toast.ShowSuccess("Administrator role granted.");
                await LoadAsync();
            }
            else
            {
                Toast.ShowError("Failed to grant administrator role.");
            }
        }
        catch { Toast.ShowError("Failed to grant administrator role."); }
        finally { _actionInProgress = false; }
    }

    private async Task RevokeAdminAsync()
    {
        _actionInProgress = true;
        try
        {
            var success = await Api.RemoveUserRoleAsync(UserId, "Administrator");
            if (success)
            {
                Toast.ShowSuccess("Administrator role revoked.");
                await LoadAsync();
            }
            else
            {
                Toast.ShowError("Failed to revoke administrator role.");
            }
        }
        catch { Toast.ShowError("Failed to revoke administrator role."); }
        finally { _actionInProgress = false; }
    }

    private static string FormatBytes(long bytes)
    {
        if (bytes == 0) return "0 B";
        string[] units = ["B", "KB", "MB", "GB", "TB"];
        var i = (int)Math.Floor(Math.Log(Math.Abs(bytes), 1024));
        i = Math.Min(i, units.Length - 1);
        return $"{bytes / Math.Pow(1024, i):F1} {units[i]}";
    }

    private string QuotaBarClass() => _quota?.UsagePercent switch
    {
        >= 95 => "quota-critical",
        >= 80 => "quota-warning",
        _ => ""
    };
}
