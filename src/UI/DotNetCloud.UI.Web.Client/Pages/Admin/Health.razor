@page "/admin/health"
@rendermode @(new Microsoft.AspNetCore.Components.Web.InteractiveAutoRenderMode(prerender: false))
@attribute [Authorize(Policy = "RequireAdmin")]

<PageTitle>System Health - DotNetCloud</PageTitle>

<div class="page-header">
    <h1>System Health</h1>
    <button class="btn btn-outline" @onclick="RefreshAsync" disabled="@_loading">Refresh</button>
</div>

@if (_loading)
{
    <LoadingIndicator Message="Checking system health..." />
}
else if (_health is null)
{
    <div class="empty-state">
        <p>Unable to retrieve health status.</p>
    </div>
}
else
{
    <div class="health-overview">
        <div class="health-status health-@_health.Status.ToLowerInvariant()">
            <h2>Overall: @_health.Status</h2>
        </div>
    </div>

    <div class="table-container">
        <table class="data-table">
            <thead>
                <tr>
                    <th>Component</th>
                    <th>Status</th>
                    <th>Duration</th>
                    <th>Description</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var entry in _health.Entries)
                {
                    <tr>
                        <td>@entry.Key</td>
                        <td>
                            <span class="badge badge-@GetBadgeClass(entry.Value.Status)">
                                @entry.Value.Status
                            </span>
                        </td>
                        <td>@entry.Value.Duration.ToString("F0") ms</td>
                        <td>@(entry.Value.Description ?? "—")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @* ── Background Services ──────────────────────────────────── *@
    <div class="bg-services-section">
        <h2>Background Services</h2>
        @if (_bgServices.Count == 0)
        {
            <p class="text-muted">No background service data available yet.</p>
        }
        else
        {
            <div class="table-container">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Service</th>
                            <th>Last Run</th>
                            <th>Duration</th>
                            <th>Status</th>
                            <th>Runs</th>
                            <th>Failures</th>
                            <th>Message</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var svc in _bgServices)
                        {
                            <tr>
                                <td class="bg-svc-name">@svc.ServiceName</td>
                                <td class="bg-svc-time" title="@svc.LastRunAt.ToString("O")">@FormatTimeAgo(svc.LastRunAt)</td>
                                <td>@FormatDuration(svc.LastRunDurationMs)</td>
                                <td>
                                    <span class="badge badge-@(svc.LastRunSuccess ? "success" : "danger")">
                                        @(svc.LastRunSuccess ? "OK" : "Failed")
                                    </span>
                                </td>
                                <td>@svc.TotalRuns</td>
                                <td>
                                    @if (svc.TotalFailures > 0)
                                    {
                                        <span class="text-danger">@svc.TotalFailures</span>
                                    }
                                    else
                                    {
                                        <span>0</span>
                                    }
                                </td>
                                <td class="bg-svc-message">@(svc.LastRunMessage ?? "—")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
}

@code {
    [Inject] private DotNetCloudApiClient Api { get; set; } = default!;
    [Inject] private ToastService Toast { get; set; } = default!;

    private bool _loading = true;
    private HealthReportDto? _health;
    private IReadOnlyList<BackgroundServiceStatusDto> _bgServices = [];

    protected override async Task OnInitializedAsync()
    {
        await RefreshAsync();
    }

    private async Task RefreshAsync()
    {
        _loading = true;
        try
        {
            var healthTask = Api.GetHealthAsync();
            var bgTask = Api.GetBackgroundServicesAsync();
            await Task.WhenAll(healthTask, bgTask);
            _health = healthTask.Result;
            _bgServices = bgTask.Result;
        }
        catch
        {
            Toast.ShowError("Failed to load health status.");
        }
        finally
        {
            _loading = false;
        }
    }

    private static string GetBadgeClass(string status) => status switch
    {
        "Healthy" => "success",
        "Degraded" => "warning",
        "Unhealthy" => "danger",
        _ => "muted"
    };

    private static string FormatTimeAgo(DateTimeOffset time)
    {
        var elapsed = DateTimeOffset.UtcNow - time;
        if (elapsed.TotalSeconds < 60) return $"{elapsed.Seconds}s ago";
        if (elapsed.TotalMinutes < 60) return $"{elapsed.Minutes}m ago";
        if (elapsed.TotalHours < 24) return $"{elapsed.Hours}h {elapsed.Minutes % 60}m ago";
        return $"{elapsed.Days}d {elapsed.Hours % 24}h ago";
    }

    private static string FormatDuration(double ms)
    {
        if (ms < 1000) return $"{ms:F0}ms";
        if (ms < 60_000) return $"{ms / 1000:F1}s";
        return $"{ms / 60_000:F1}m";
    }
}
