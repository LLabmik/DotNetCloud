@page "/admin/users/{UserId:guid}/edit"
@rendermode @(new Microsoft.AspNetCore.Components.Web.InteractiveAutoRenderMode(prerender: false))
@attribute [Authorize(Policy = "RequireAdmin")]

<PageTitle>Edit User - DotNetCloud</PageTitle>

@if (_loading)
{
    <LoadingIndicator Message="Loading user..." />
}
else if (_model is null)
{
    <div class="empty-state">
        <p>User not found.</p>
        <a href="/admin/users" class="btn btn-primary">Back to Users</a>
    </div>
}
else
{
    <div class="page-header">
        <h1>Edit User</h1>
        <a href="/admin/users/@UserId" class="btn btn-outline">Back</a>
    </div>

    <div class="form-container">
        <EditForm Model="_model" OnValidSubmit="SubmitAsync" FormName="edit-user">
            <DataAnnotationsValidator />

            <div class="form-group">
                <label for="displayName">Display Name</label>
                <InputText id="displayName" class="input" @bind-Value="_model.DisplayName" />
            </div>

            <div class="form-group">
                <label for="locale">Language / Region</label>
                <InputSelect id="locale" class="input" @bind-Value="_model!.Locale">
                    @if (!LocaleOptions.Any(x => x.Code.Equals(_model!.Locale, StringComparison.OrdinalIgnoreCase)))
                    {
                        <option value="@_model!.Locale">@_model!.Locale (current)</option>
                    }
                    @foreach (var item in LocaleOptions)
                    {
                        <option value="@item.Code">@item.Name</option>
                    }
                </InputSelect>
            </div>

            <div class="form-group">
                <label for="timezone">Timezone</label>
                <InputText id="timezone" class="input" @bind-Value="_model!.Timezone" />
                <span class="hint">e.g., UTC, America/New_York, Europe/London</span>
                <button type="button" class="btn btn-sm btn-outline" style="margin-top: 6px;" @onclick="DetectTimezoneAsync" disabled="@_detectingTimezone">
                    @(_detectingTimezone ? "Detecting..." : "Detect from browser")
                </button>
            </div>

            <div class="form-group">
                <label for="quotaMb">Storage Quota (MB)</label>
                <input id="quotaMb" type="number" class="input" step="1" min="0"
                       @bind="_quotaMb" />
                <span class="hint">0 = unlimited. Sets the maximum storage this user can consume.</span>
            </div>

            @if (!string.IsNullOrWhiteSpace(_errorMessage))
            {
                <div class="alert alert-danger">@_errorMessage</div>
            }

            <div class="form-actions">
                <button type="submit" class="btn btn-primary" disabled="@_submitting">
                    @(_submitting ? "Saving..." : "Save Changes")
                </button>
            </div>
        </EditForm>
    </div>
}

@code {
    [Parameter] public Guid UserId { get; set; }
    [Inject] private DotNetCloudApiClient Api { get; set; } = default!;
    [Inject] private ToastService Toast { get; set; } = default!;
    [Inject] private NavigationManager Nav { get; set; } = default!;
    [Inject] private IJSRuntime JS { get; set; } = default!;

    private bool _loading = true;
    private bool _submitting;
    private bool _detectingTimezone;
    private string? _errorMessage;
    private UpdateUserDto? _model;
    private double _quotaMb;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var user = await Api.GetUserAsync(UserId);
            if (user is not null)
            {
                _model = new UpdateUserDto
                {
                    DisplayName = user.DisplayName,
                    Locale = user.Locale,
                    Timezone = user.Timezone
                };
            }

            var quota = await Api.GetUserQuotaAsync(UserId);
            _quotaMb = quota is not null ? Math.Round(quota.MaxBytes / (1024.0 * 1024.0), 1) : 0;
        }
        catch
        {
            Toast.ShowError("Failed to load user.");
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task SubmitAsync()
    {
        if (_model is null) return;
        _errorMessage = null;
        _submitting = true;

        try
        {
            var result = await Api.UpdateUserAsync(UserId, _model);
            if (result is null)
            {
                _errorMessage = "Failed to update user.";
                return;
            }

            var maxBytes = (long)(_quotaMb * 1024 * 1024);
            await Api.SetUserQuotaAsync(UserId, maxBytes);

            Toast.ShowSuccess("User updated.");
            Nav.NavigateTo($"/admin/users/{UserId}");
        }
        catch (HttpRequestException)
        {
            _errorMessage = "Failed to communicate with the server.";
        }
        finally
        {
            _submitting = false;
        }
    }

    private async Task DetectTimezoneAsync()
    {
        if (_model is null) return;
        _detectingTimezone = true;
        try
        {
            var tz = await JS.InvokeAsync<string>("dotnetcloud.getTimezone");
            if (!string.IsNullOrWhiteSpace(tz))
            {
                _model.Timezone = tz;
                Toast.ShowSuccess($"Timezone detected: {tz}");
            }
        }
        catch
        {
            Toast.ShowError("Could not detect timezone.");
        }
        finally
        {
            _detectingTimezone = false;
        }
    }

    private static readonly (string Code, string Name)[] LocaleOptions =
    [
        ("en-US", "English (United States)"),
        ("en-GB", "English (United Kingdom)"),
        ("en-CA", "English (Canada)"),
        ("en-AU", "English (Australia)"),
        ("en-NZ", "English (New Zealand)"),
        ("de-DE", "German (Germany)"),
        ("de-AT", "German (Austria)"),
        ("de-CH", "German (Switzerland)"),
        ("fr-FR", "French (France)"),
        ("fr-CA", "French (Canada)"),
        ("fr-BE", "French (Belgium)"),
        ("fr-CH", "French (Switzerland)"),
        ("es-ES", "Spanish (Spain)"),
        ("es-MX", "Spanish (Mexico)"),
        ("es-AR", "Spanish (Argentina)"),
        ("it-IT", "Italian (Italy)"),
        ("pt-BR", "Portuguese (Brazil)"),
        ("pt-PT", "Portuguese (Portugal)"),
        ("nl-NL", "Dutch (Netherlands)"),
        ("nl-BE", "Dutch (Belgium)"),
        ("sv-SE", "Swedish (Sweden)"),
        ("nb-NO", "Norwegian (Norway)"),
        ("da-DK", "Danish (Denmark)"),
        ("fi-FI", "Finnish (Finland)"),
        ("pl-PL", "Polish (Poland)"),
        ("cs-CZ", "Czech (Czech Republic)"),
        ("sk-SK", "Slovak (Slovakia)"),
        ("hu-HU", "Hungarian (Hungary)"),
        ("ro-RO", "Romanian (Romania)"),
        ("hr-HR", "Croatian (Croatia)"),
        ("bg-BG", "Bulgarian (Bulgaria)"),
        ("ru-RU", "Russian (Russia)"),
        ("uk-UA", "Ukrainian (Ukraine)"),
        ("tr-TR", "Turkish (Turkey)"),
        ("ar-SA", "Arabic (Saudi Arabia)"),
        ("ar-AE", "Arabic (UAE)"),
        ("he-IL", "Hebrew (Israel)"),
        ("ja-JP", "Japanese (Japan)"),
        ("ko-KR", "Korean (South Korea)"),
        ("zh-CN", "Chinese Simplified (China)"),
        ("zh-TW", "Chinese Traditional (Taiwan)"),
    ];
}
