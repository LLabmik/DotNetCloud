@page "/admin/users/create"
@rendermode @(new Microsoft.AspNetCore.Components.Web.InteractiveAutoRenderMode(prerender: false))
@attribute [Authorize(Policy = "RequireAdmin")]

<PageTitle>Create User - DotNetCloud</PageTitle>

<div class="page-header">
    <h1>Create User</h1>
    <a href="/admin/users" class="btn btn-outline">Back</a>
</div>

<div class="form-container">
    <EditForm Model="_model" OnValidSubmit="SubmitAsync" FormName="create-user">
        <DataAnnotationsValidator />

        <div class="form-group">
            <label for="email">Email</label>
            <InputText id="email" class="input" @bind-Value="_model.Email" />
            <ValidationMessage For="() => _model.Email" />
        </div>

        <div class="form-group">
            <label for="displayName">Display Name</label>
            <InputText id="displayName" class="input" @bind-Value="_model.DisplayName" />
            <ValidationMessage For="() => _model.DisplayName" />
        </div>

        <div class="form-group">
            <label for="password">Password</label>
            <InputText id="password" class="input" type="password" @bind-Value="_model.Password" />
            <ValidationMessage For="() => _model.Password" />
        </div>

        <div class="form-group">
            <label for="locale">Language / Region</label>
            <InputSelect id="locale" class="input" @bind-Value="_model.Locale">
                @foreach (var item in LocaleOptions)
                {
                    <option value="@item.Code">@item.Name</option>
                }
            </InputSelect>
        </div>

        <div class="form-group">
            <label for="timezone">Timezone</label>
            <InputText id="timezone" class="input" @bind-Value="_model.Timezone" />
            <span class="hint">e.g., UTC, America/New_York, Europe/London</span>
            <button type="button" class="btn btn-sm btn-outline" style="margin-top: 6px;" @onclick="DetectTimezoneAsync" disabled="@_detectingTimezone">
                @(_detectingTimezone ? "Detecting..." : "Update based on current location")
            </button>
        </div>

        @if (!string.IsNullOrWhiteSpace(_errorMessage))
        {
            <div class="alert alert-danger">@_errorMessage</div>
        }

        <div class="form-actions">
            <button type="submit" class="btn btn-primary" disabled="@_submitting">
                @(_submitting ? "Creating..." : "Create User")
            </button>
        </div>
    </EditForm>
</div>

@code {
    [Inject] private DotNetCloudApiClient Api { get; set; } = default!;
    [Inject] private ToastService Toast { get; set; } = default!;
    [Inject] private NavigationManager Nav { get; set; } = default!;
    [Inject] private IJSRuntime JS { get; set; } = default!;

    private RegisterRequest _model = new() { Locale = "en-US", Timezone = "UTC" };
    private bool _submitting;
    private bool _detectingTimezone;
    private string? _errorMessage;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        try
        {
            var rawLocale = await JS.InvokeAsync<string>("dotnetcloud.getLocale");
            if (!string.IsNullOrWhiteSpace(rawLocale))
            {
                var normalized = NormalizeLocale(rawLocale);
                if (normalized is not null)
                {
                    _model.Locale = normalized;
                    StateHasChanged();
                }
            }
        }
        catch { }
    }

    private string? NormalizeLocale(string raw)
    {
        var exact = LocaleOptions.FirstOrDefault(x => x.Code.Equals(raw, StringComparison.OrdinalIgnoreCase));
        if (exact != default) return exact.Code;
        var prefix = raw.Split('-')[0];
        var prefixMatch = LocaleOptions.FirstOrDefault(x => x.Code.StartsWith(prefix + "-", StringComparison.OrdinalIgnoreCase));
        return prefixMatch != default ? prefixMatch.Code : null;
    }

    private async Task SubmitAsync()
    {
        _errorMessage = null;
        _submitting = true;
        try
        {
            var result = await Api.CreateUserAsync(_model);
            if (result.Success)
            {
                Toast.ShowSuccess("User created successfully.");
                Nav.NavigateTo("/admin/users");
            }
            else
            {
                _errorMessage = "Failed to create user. Please check the form and try again.";
            }
        }
        catch (HttpRequestException)
        {
            _errorMessage = "Failed to communicate with the server.";
        }
        finally
        {
            _submitting = false;
        }
    }

    private async Task DetectTimezoneAsync()
    {
        _detectingTimezone = true;
        try
        {
            var tz = await JS.InvokeAsync<string>("dotnetcloud.getTimezone");
            if (!string.IsNullOrWhiteSpace(tz))
            {
                _model.Timezone = tz;
                Toast.ShowSuccess($"Timezone detected: {tz}");
            }
        }
        catch
        {
            Toast.ShowError("Could not detect timezone.");
        }
        finally
        {
            _detectingTimezone = false;
        }
    }

    private static readonly (string Code, string Name)[] LocaleOptions =
    [
        ("en-US", "English (United States)"),
        ("en-GB", "English (United Kingdom)"),
        ("en-CA", "English (Canada)"),
        ("en-AU", "English (Australia)"),
        ("en-NZ", "English (New Zealand)"),
        ("de-DE", "German (Germany)"),
        ("de-AT", "German (Austria)"),
        ("de-CH", "German (Switzerland)"),
        ("fr-FR", "French (France)"),
        ("fr-CA", "French (Canada)"),
        ("fr-BE", "French (Belgium)"),
        ("fr-CH", "French (Switzerland)"),
        ("es-ES", "Spanish (Spain)"),
        ("es-MX", "Spanish (Mexico)"),
        ("es-AR", "Spanish (Argentina)"),
        ("it-IT", "Italian (Italy)"),
        ("pt-BR", "Portuguese (Brazil)"),
        ("pt-PT", "Portuguese (Portugal)"),
        ("nl-NL", "Dutch (Netherlands)"),
        ("nl-BE", "Dutch (Belgium)"),
        ("sv-SE", "Swedish (Sweden)"),
        ("nb-NO", "Norwegian (Norway)"),
        ("da-DK", "Danish (Denmark)"),
        ("fi-FI", "Finnish (Finland)"),
        ("pl-PL", "Polish (Poland)"),
        ("cs-CZ", "Czech (Czech Republic)"),
        ("sk-SK", "Slovak (Slovakia)"),
        ("hu-HU", "Hungarian (Hungary)"),
        ("ro-RO", "Romanian (Romania)"),
        ("hr-HR", "Croatian (Croatia)"),
        ("bg-BG", "Bulgarian (Bulgaria)"),
        ("ru-RU", "Russian (Russia)"),
        ("uk-UA", "Ukrainian (Ukraine)"),
        ("tr-TR", "Turkish (Turkey)"),
        ("ar-SA", "Arabic (Saudi Arabia)"),
        ("ar-AE", "Arabic (UAE)"),
        ("he-IL", "Hebrew (Israel)"),
        ("ja-JP", "Japanese (Japan)"),
        ("ko-KR", "Korean (South Korea)"),
        ("zh-CN", "Chinese Simplified (China)"),
        ("zh-TW", "Chinese Traditional (Taiwan)"),
    ];
}
