    private async Task ToggleSharePanel()
    {
        _showSharePanel = !_showSharePanel;
        if (_showSharePanel && _selectedCalendar is not null)
        {
            _shares.Clear();
            _shares.AddRange(await ApiClient.ListSharesAsync(_selectedCalendar.Id));
        }
    }

    private async Task AddShareAsync()
    {
        if (_selectedCalendar is null || !Guid.TryParse(_shareUserId, out var userId))
        {
            return;
        }

        await ApiClient.ShareCalendarAsync(_selectedCalendar.Id, userId, null, _sharePermission);
        _shareUserId = string.Empty;
        _shares.Clear();
        _shares.AddRange(await ApiClient.ListSharesAsync(_selectedCalendar.Id));
    }

    private async Task RevokeShareAsync(Guid shareId)
    {
        await ApiClient.RevokeShareAsync(shareId);
        if (_selectedCalendar is not null)
        {
            _shares.Clear();
            _shares.AddRange(await ApiClient.ListSharesAsync(_selectedCalendar.Id));
        }
