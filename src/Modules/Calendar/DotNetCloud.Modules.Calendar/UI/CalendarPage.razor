@namespace DotNetCloud.Modules.Calendar.UI

@using DotNetCloud.Core.DTOs
@using DotNetCloud.Core.Capabilities
@using DotNetCloud.Modules.Calendar.Services
@using Microsoft.AspNetCore.WebUtilities
@inject ICalendarApiClient ApiClient
@inject IOrganizationDirectory OrgDirectory
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject NavigationManager Navigation
@inject Microsoft.JSInterop.IJSRuntime JSRuntime

<div class="calendar-page-layout">
    <div class="calendar-sidebar @(_sidebarCollapsed ? "collapsed" : "")">
        <div class="calendar-sidebar-header">
            @if (!_sidebarCollapsed)
            {
                <h3 class="calendar-sidebar-title">Calendar</h3>
            }
            <button class="calendar-sidebar-toggle" @onclick="ToggleSidebar" title="@(_sidebarCollapsed ? "Expand sidebar" : "Collapse sidebar")">
                <span>@(_sidebarCollapsed ? "▶" : "◀")</span>
            </button>
            @if (!_sidebarCollapsed)
            {
                <button class="btn btn-sm btn-primary" @onclick="BeginCreateEvent" title="New Event">
                    <span>+</span>
                </button>
            }
        </div>
        <nav class="calendar-nav">
            <a class="calendar-nav-item @(_activeView == "month" ? "active" : "")" @onclick='() => SetView("month")' title="Month">
                <span class="calendar-nav-icon">📅</span>
                @if (!_sidebarCollapsed)
                {
                    <span class="calendar-nav-label">Month</span>
                }
            </a>
            <a class="calendar-nav-item @(_activeView == "week" ? "active" : "")" @onclick='() => SetView("week")' title="Week">
                <span class="calendar-nav-icon">🗓️</span>
                @if (!_sidebarCollapsed)
                {
                    <span class="calendar-nav-label">Week</span>
                }
            </a>
            <a class="calendar-nav-item @(_activeView == "day" ? "active" : "")" @onclick='() => SetView("day")' title="Day">
                <span class="calendar-nav-icon">☀️</span>
                @if (!_sidebarCollapsed)
                {
                    <span class="calendar-nav-label">Day</span>
                }
            </a>
            <a class="calendar-nav-item @(_activeView == "agenda" ? "active" : "")" @onclick='() => SetView("agenda")' title="Agenda">
                <span class="calendar-nav-icon">📝</span>
                @if (!_sidebarCollapsed)
                {
                    <span class="calendar-nav-label">Agenda</span>
                }
            </a>
        </nav>

        @if (!_sidebarCollapsed)
        {
            <div class="calendar-list-heading">My Calendars</div>
        }
        <div class="calendar-list">
            @foreach (var calendar in _calendars)
            {
                <button class="calendar-item @(_selectedCalendar?.Id == calendar.Id ? "selected" : "")"
                        title="@calendar.Name"
                        @onclick="() => SelectCalendarAsync(calendar.Id)">
                    <span class="calendar-dot" style="background:@(calendar.Color ?? "#3b82f6")"></span>
                    @if (!_sidebarCollapsed)
                    {
                        <span>@calendar.Name</span>
                    }
                </button>
            }
        </div>

        @if (!_sidebarCollapsed)
        {
            <div class="calendar-actions">
                <button class="btn btn-sm btn-outline-primary" @onclick="BeginCreateCalendar">New Calendar</button>
                @if (_selectedCalendar is not null)
                {
                    <button class="btn btn-sm btn-outline-secondary" @onclick="ToggleSharePanel">
                        @(_showSharePanel ? "Hide Shares" : "Share")
                    </button>
                    <button class="btn btn-sm btn-outline-secondary" @onclick="ExportCalendarAsync">Export iCal</button>
                    <button class="btn btn-sm btn-outline-secondary" @onclick="() => _showImportPanel = !_showImportPanel">Import</button>
                }
            </div>
        }

        @if (!_sidebarCollapsed && _showSharePanel && _selectedCalendar is not null)
        {
            <div class="calendar-share-panel">
                <h4>Shares</h4>
                @if (_shares.Count == 0)
                {
                    <p>Not shared.</p>
                }
                else
                {
                    @foreach (var share in _shares)
                    {
                        <div class="share-item">
                            <span>@(share.SharedWithUserId?.ToString("N")[..8] ?? share.SharedWithTeamId?.ToString("N")[..8] ?? "—")… — @share.Permission</span>
                            <button class="btn btn-sm btn-outline-danger" @onclick="() => RevokeShareAsync(share.Id)">Revoke</button>
                        </div>
                    }
                }
                <div class="share-form">
                    <input type="text" class="form-control form-control-sm" placeholder="User ID" @bind="_shareUserId" />
                    <select class="form-select form-select-sm" @bind="_sharePermission" style="max-width:140px;">
                        <option value="ReadOnly">Read Only</option>
                        <option value="ReadWrite">Read/Write</option>
                    </select>
                    <button class="btn btn-sm btn-primary" @onclick="AddShareAsync">Share</button>
                </div>
            </div>
        }

        @if (!_sidebarCollapsed && _showImportPanel && _selectedCalendar is not null)
        {
            <div class="calendar-import-panel">
                <textarea class="form-control form-control-sm" rows="4" placeholder="Paste iCalendar (.ics) data here…" @bind="_importText"></textarea>
                <button class="btn btn-sm btn-primary" @onclick="ImportCalendarAsync" style="margin-top:8px;">Import</button>
            </div>
        }
    </div>
    <div class="calendar-main">
        @if (!string.IsNullOrWhiteSpace(_operationError))
        {
            <div class="calendar-inline-error">@_operationError</div>
        }

        <div class="calendar-toolbar">
            <button class="btn btn-sm btn-outline-secondary" @onclick="PrevRange" title="Previous">←</button>
            <strong>@RangeLabel</strong>
            <button class="btn btn-sm btn-outline-secondary" @onclick="NextRange" title="Next">→</button>
            <button class="btn btn-sm btn-outline-secondary" @onclick="GoToToday">Today</button>
            <div class="calendar-org-picker">
                <button class="btn btn-sm btn-outline-secondary" @onclick="ToggleOrgDropdown">
                    @(_selectedOrgId is null ? "My Calendars" : (_organizations.FirstOrDefault(o => o.Id == _selectedOrgId)?.Name ?? "Org"))
                    <span class="calendar-org-arrow">▾</span>
                </button>
                @if (_showOrgDropdown)
                {
                    <div class="calendar-org-dropdown">
                        <button class="calendar-org-option @(_selectedOrgId is null ? "selected" : "")"
                                @onclick="() => SelectOrganizationAsync(null)">
                            My Calendars
                        </button>
                        @if (_organizations.Count > 0)
                        {
                            <div class="calendar-org-divider"></div>
                        }
                        @foreach (var org in _organizations)
                        {
                            <button class="calendar-org-option @(_selectedOrgId == org.Id ? "selected" : "")"
                                    @onclick="() => SelectOrganizationAsync(org.Id)">
                                @org.Name
                            </button>
                        }
                    </div>
                }
            </div>
            <button class="btn btn-sm btn-primary" @onclick="BeginCreateEvent">+ New Event</button>
        </div>

        @if (_activeView == "month")
        {
            <div class="calendar-month-grid">
                @foreach (var name in DayNames)
                {
                    <div class="calendar-day-header">@name</div>
                }
                @foreach (var day in GetMonthGridDays())
                {
                    var dayEvents = GetEventsForDate(day);
                    var visibleEvents = dayEvents.Take(3).ToList();
                    var overflowCount = dayEvents.Count - 3;
                    <div class="calendar-day-cell @(day.Month != _anchorDate.Month ? "other-month" : "") @(day.Date == DateTime.Today ? "today" : "")"
                         @onclick="() => DayClicked(day)">
                        <span class="calendar-day-number">@day.Day</span>
                        @foreach (var evt in visibleEvents)
                        {
                            <div class="calendar-day-event @(evt.IsAllDay ? "all-day" : "")"
                                 style="background:@(GetEventColor(evt))"
                                 @onclick:stopPropagation @onclick="() => BeginEditEvent(evt)"
                                 title="@evt.Title">
                                @if (!evt.IsAllDay)
                                {
                                    <span class="calendar-event-time-badge">@evt.StartUtc.ToLocalTime().ToString("HH:mm")</span>
                                }
                                <span class="calendar-event-title">@evt.Title</span>
                            </div>
                        }
                        @if (overflowCount > 0)
                        {
                            <div class="calendar-more-events"
                                 @onclick:stopPropagation @onclick="() => ShowDayDetails(day.Date, dayEvents)">
                                +@overflowCount more
                            </div>
                        }
                    </div>
                }
            </div>
        }
        else if (_activeView == "week")
        {
            <div class="calendar-week-grid">
                @foreach (var day in GetWeekDays())
                {
                    var dayEvents = GetEventsForDate(day);
                    <div class="calendar-week-col">
                        <div class="calendar-week-col-header @(day.Date == DateTime.Today ? "today" : "")">
                            <span class="calendar-week-day-name">@day.ToString("ddd")</span>
                            <span class="calendar-week-day-num">@day.Day</span>
                        </div>
                        <div class="calendar-week-col-body" @onclick="() => DayClicked(day)">
                            @if (dayEvents.Count == 0)
                            {
                                <span class="calendar-week-empty">&nbsp;</span>
                            }
                            else
                            {
                                @foreach (var evt in dayEvents)
                                {
                                    <div class="calendar-day-event @(evt.IsAllDay ? "all-day" : "")"
                                         style="background:@(GetEventColor(evt))"
                                         @onclick:stopPropagation @onclick="() => BeginEditEvent(evt)">
                                        @if (!evt.IsAllDay)
                                        {
                                            <span class="calendar-event-time-badge">@evt.StartUtc.ToLocalTime().ToString("HH:mm")</span>
                                        }
                                        <span class="calendar-event-title">@evt.Title</span>
                                    </div>
                                }
                            }
                        </div>
                    </div>
                }
            </div>
        }
        else if (_activeView == "day")
        {
            <div class="calendar-day-view">
                @for (var h = 0; h < 24; h++)
                {
                    var hour = h;
                    var hourEvents = GetEventsForHour(_anchorDate, hour);
                    <div class="calendar-hour-row @(DateTime.Now.Hour == hour && _anchorDate.Date == DateTime.Today ? "current-hour" : "")">
                        <div class="calendar-hour-label">@($"{hour:D2}:00")</div>
                        <div class="calendar-hour-content" @onclick="() => CreateEventAtHour(hour)">
                            @foreach (var evt in hourEvents)
                            {
                                <div class="calendar-day-event @(evt.IsAllDay ? "all-day" : "")"
                                     style="background:@(GetEventColor(evt))"
                                     @onclick:stopPropagation @onclick="() => BeginEditEvent(evt)">
                                    <span class="calendar-event-title">@evt.Title</span>
                                    @if (!evt.IsAllDay)
                                    {
                                        <span class="calendar-event-time-badge">@evt.StartUtc.ToLocalTime().ToString("HH:mm") – @evt.EndUtc.ToLocalTime().ToString("HH:mm")</span>
                                    }
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            @* Agenda view — flat event list *@
            <div class="calendar-events-panel">
                @if (_events.Count == 0)
                {
                    <p>No events in this range.</p>
                }
                else
                {
                    @foreach (var eventItem in _events.OrderBy(e => e.StartUtc))
                    {
                        <div class="calendar-event-row">
                            <button class="btn btn-link p-0 text-start" @onclick="() => BeginEditEvent(eventItem)">
                                <strong>@eventItem.Title</strong>
                                <span>@eventItem.StartUtc.ToLocalTime().ToString("g") – @eventItem.EndUtc.ToLocalTime().ToString("g")</span>
                                <span>@eventItem.Location</span>
                            </button>
                            @if (CanCurrentUserRsvp(eventItem))
                            {
                                <div class="calendar-rsvp-buttons">
                                    <button class="btn btn-sm btn-outline-success" @onclick="() => RsvpAsync(eventItem.Id, AttendeeStatus.Accepted)">Accept</button>
                                    <button class="btn btn-sm btn-outline-warning" @onclick="() => RsvpAsync(eventItem.Id, AttendeeStatus.Tentative)">Maybe</button>
                                    <button class="btn btn-sm btn-outline-danger" @onclick="() => RsvpAsync(eventItem.Id, AttendeeStatus.Declined)">Decline</button>
                                </div>
                            }
                            <CrossModuleLinkList Requests="BuildAttendeeContactRequests(eventItem)" />
                        </div>
                    }
                }
            </div>
        }
    </div>
</div>

@* ═══════════════════════════════════════════
   MODALS
   ═══════════════════════════════════════════ *@

@* ── Event Add/Edit Modal ── *@
@if (_showEventModal && _eventEditor is not null)
{
    <div class="calendar-modal-backdrop" @onclick="CancelEventEdit">
        <div class="calendar-modal" @onclick:stopPropagation>
            <div class="calendar-modal-header">
                <h4>@(_eventEditor.Id.HasValue ? "Edit Event" : "New Event")</h4>
                <button class="calendar-modal-close" @onclick="CancelEventEdit" title="Close">✕</button>
            </div>
            <div class="calendar-modal-body">
                <EditForm Model="_eventEditor" OnValidSubmit="SaveEventAsync">
                    <div class="calendar-form-grid">
                        <InputText class="form-control" @bind-Value="_eventEditor.Title" placeholder="Title" />
                        <div class="calendar-form-row">
                            <label class="calendar-form-check">
                                <InputCheckbox @bind-Value="_eventEditor.IsAllDay" />
                                <span>All-day event</span>
                            </label>
                        </div>
                        <div class="calendar-form-row">
                            <label class="calendar-form-label">Start</label>
                            <div class="calendar-form-datetime">
                                <InputDate class="form-control" @bind-Value="_eventEditor.StartDate" />
                                @if (!_eventEditor.IsAllDay)
                                {
                                    <InputDate Type="InputDateType.Time" class="form-control" @bind-Value="_eventEditor.StartTime" />
                                }
                            </div>
                        </div>
                        <div class="calendar-form-row">
                            <label class="calendar-form-label">End</label>
                            <div class="calendar-form-datetime">
                                <InputDate class="form-control" @bind-Value="_eventEditor.EndDate" />
                                @if (!_eventEditor.IsAllDay)
                                {
                                    <InputDate Type="InputDateType.Time" class="form-control" @bind-Value="_eventEditor.EndTime" />
                                }
                            </div>
                        </div>
                        <InputText class="form-control" @bind-Value="_eventEditor.Location" placeholder="Location" />
                        <div class="calendar-form-row">
                            <label class="calendar-form-label">Repeat</label>
                            <select class="form-select" @bind="_eventEditor.RecurrenceType">
                                <option value="None">None</option>
                                <option value="Daily">Daily</option>
                                <option value="Weekly">Weekly</option>
                                <option value="Biweekly">Biweekly</option>
                                <option value="Monthly">Monthly</option>
                                <option value="Yearly">Yearly</option>
                            </select>
                        </div>
                        @if (_eventEditor.RecurrenceType != "None")
                        {
                            <div class="calendar-form-row">
                                <label class="calendar-form-label">Ends on</label>
                                <InputDate class="form-control" @bind-Value="_eventEditor.RecurrenceEndDate" />
                            </div>
                        }
                        <div class="calendar-form-row">
                            <label class="calendar-form-label">Color</label>
                            <div class="calendar-color-swatches">
                                @foreach (var swatch in _colorSwatches)
                                {
                                    <button type="button"
                                            class="calendar-color-swatch @(_eventEditor.Color == swatch ? "selected" : "")"
                                            style="background-color: @swatch;"
                                            @onclick="() => _eventEditor.Color = _eventEditor.Color == swatch ? null : swatch"
                                            title="@swatch"></button>
                                }
                                <input type="color" class="calendar-color-custom" @bind="_eventEditor.Color" title="Custom color" />
                            </div>
                        </div>
                        <InputText class="form-control" @bind-Value="_eventEditor.Url" placeholder="URL (e.g., video call link)" />

                        @* ── Advanced Recurrence (BYDAY) ── *@
                        @if (_eventEditor.RecurrenceType is "Weekly" or "Biweekly")
                        {
                            <div class="calendar-form-row">
                                <label class="calendar-form-label">On days</label>
                                <div class="calendar-weekday-picker">
                                    <button type="button"
                                            class="calendar-weekday-btn @(_eventEditor.RecurOnMon ? "active" : "")"
                                            @onclick="() => _eventEditor.RecurOnMon = !_eventEditor.RecurOnMon">M</button>
                                    <button type="button"
                                            class="calendar-weekday-btn @(_eventEditor.RecurOnTue ? "active" : "")"
                                            @onclick="() => _eventEditor.RecurOnTue = !_eventEditor.RecurOnTue">T</button>
                                    <button type="button"
                                            class="calendar-weekday-btn @(_eventEditor.RecurOnWed ? "active" : "")"
                                            @onclick="() => _eventEditor.RecurOnWed = !_eventEditor.RecurOnWed">W</button>
                                    <button type="button"
                                            class="calendar-weekday-btn @(_eventEditor.RecurOnThu ? "active" : "")"
                                            @onclick="() => _eventEditor.RecurOnThu = !_eventEditor.RecurOnThu">T</button>
                                    <button type="button"
                                            class="calendar-weekday-btn @(_eventEditor.RecurOnFri ? "active" : "")"
                                            @onclick="() => _eventEditor.RecurOnFri = !_eventEditor.RecurOnFri">F</button>
                                    <button type="button"
                                            class="calendar-weekday-btn @(_eventEditor.RecurOnSat ? "active" : "")"
                                            @onclick="() => _eventEditor.RecurOnSat = !_eventEditor.RecurOnSat">S</button>
                                    <button type="button"
                                            class="calendar-weekday-btn @(_eventEditor.RecurOnSun ? "active" : "")"
                                            @onclick="() => _eventEditor.RecurOnSun = !_eventEditor.RecurOnSun">S</button>
                                </div>
                            </div>
                        }
                        @if (_eventEditor.RecurrenceType == "Monthly")
                        {
                            <div class="calendar-form-row">
                                <label class="calendar-form-label">On the</label>
                                <select class="form-select" style="max-width:130px;"
                                        @bind="_eventEditor.MonthlyByDayPosition">
                                    <option value="">Day of month</option>
                                    <option value="1">First</option>
                                    <option value="2">Second</option>
                                    <option value="3">Third</option>
                                    <option value="4">Fourth</option>
                                    <option value="-1">Last</option>
                                </select>
                                @if (_eventEditor.MonthlyByDayPosition.HasValue)
                                {
                                    <div class="calendar-weekday-picker">
                                        <button type="button"
                                                class="calendar-weekday-btn @(_eventEditor.RecurOnMon ? "active" : "")"
                                                @onclick="() => _eventEditor.RecurOnMon = !_eventEditor.RecurOnMon">M</button>
                                        <button type="button"
                                                class="calendar-weekday-btn @(_eventEditor.RecurOnTue ? "active" : "")"
                                                @onclick="() => _eventEditor.RecurOnTue = !_eventEditor.RecurOnTue">T</button>
                                        <button type="button"
                                                class="calendar-weekday-btn @(_eventEditor.RecurOnWed ? "active" : "")"
                                                @onclick="() => _eventEditor.RecurOnWed = !_eventEditor.RecurOnWed">W</button>
                                        <button type="button"
                                                class="calendar-weekday-btn @(_eventEditor.RecurOnThu ? "active" : "")"
                                                @onclick="() => _eventEditor.RecurOnThu = !_eventEditor.RecurOnThu">T</button>
                                        <button type="button"
                                                class="calendar-weekday-btn @(_eventEditor.RecurOnFri ? "active" : "")"
                                                @onclick="() => _eventEditor.RecurOnFri = !_eventEditor.RecurOnFri">F</button>
                                        <button type="button"
                                                class="calendar-weekday-btn @(_eventEditor.RecurOnSat ? "active" : "")"
                                                @onclick="() => _eventEditor.RecurOnSat = !_eventEditor.RecurOnSat">S</button>
                                        <button type="button"
                                                class="calendar-weekday-btn @(_eventEditor.RecurOnSun ? "active" : "")"
                                                @onclick="() => _eventEditor.RecurOnSun = !_eventEditor.RecurOnSun">S</button>
                                    </div>
                                }
                            </div>
                        }

                        @* ── Reminders ── *@
                        <div class="calendar-section">
                            <div class="calendar-section-header">
                                <label class="calendar-form-label">Reminders</label>
                                <button type="button" class="btn btn-sm btn-outline-secondary"
                                        @onclick="() => _eventEditor.Reminders.Add(new ReminderEditorModel())">+ Add</button>
                            </div>
                            @foreach (var r in _eventEditor.Reminders)
                            {
                                var reminder = r;
                                <div class="calendar-form-row" style="margin-bottom:4px;">
                                    <select class="form-select" @bind="reminder.Method" style="max-width:140px;">
                                        <option value="Notification">Notification</option>
                                        <option value="Email">Email</option>
                                    </select>
                                    <input type="number" class="form-control" @bind="reminder.MinutesBefore"
                                           style="max-width:100px;" placeholder="Minutes" />
                                    <span class="text-sm text-muted">min before</span>
                                    <button type="button" class="btn btn-sm btn-outline-danger"
                                            @onclick="() => _eventEditor.Reminders.Remove(reminder)">✕</button>
                                </div>
                            }
                        </div>

                        @* ── Attendees ── *@
                        <div class="calendar-section">
                            <div class="calendar-section-header">
                                <label class="calendar-form-label">Attendees</label>
                                <button type="button" class="btn btn-sm btn-outline-secondary"
                                        @onclick="() => _eventEditor.Attendees.Add(new AttendeeEditorModel())">+ Add</button>
                            </div>
                            @foreach (var a in _eventEditor.Attendees)
                            {
                                var attendee = a;
                                <div class="calendar-form-row" style="margin-bottom:4px;">
                                    <input class="form-control" @bind="attendee.Email" placeholder="email"
                                           style="max-width:200px;" />
                                    <input class="form-control" @bind="attendee.DisplayName" placeholder="Name"
                                           style="max-width:140px;" />
                                    <select class="form-select" @bind="attendee.Role" style="max-width:130px;">
                                        <option value="Required">Required</option>
                                        <option value="Optional">Optional</option>
                                        <option value="Informational">FYI</option>
                                    </select>
                                    <button type="button" class="btn btn-sm btn-outline-danger"
                                            @onclick="() => _eventEditor.Attendees.Remove(attendee)">✕</button>
                                </div>
                            }
                        </div>

                        <InputText class="form-control" @bind-Value="_eventEditor.Description" placeholder="Description" />
                    </div>
                    <div class="calendar-form-actions">
                        <button type="submit" class="btn btn-primary">Save Event</button>
                        <button type="button" class="btn btn-secondary" @onclick="CancelEventEdit">Cancel</button>
                        @if (_eventEditor.Id.HasValue)
                        {
                            <button type="button" class="btn btn-danger" @onclick="DeleteEventAsync">Delete</button>
                        }
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
}

@* ── Calendar Add/Edit Modal ── *@
@if (_showCalendarModal && _calendarEditor is not null)
{
    <div class="calendar-modal-backdrop" @onclick="CancelCalendarEdit">
        <div class="calendar-modal" @onclick:stopPropagation>
            <div class="calendar-modal-header">
                <h4>@(_calendarEditor.Id.HasValue ? "Edit Calendar" : "New Calendar")</h4>
                <button class="calendar-modal-close" @onclick="CancelCalendarEdit" title="Close">✕</button>
            </div>
            <div class="calendar-modal-body">
                <EditForm Model="_calendarEditor" OnValidSubmit="SaveCalendarAsync">
                    <div class="calendar-form-grid">
                        <InputText class="form-control" @bind-Value="_calendarEditor.Name" placeholder="Calendar Name" />
                        <InputText class="form-control" @bind-Value="_calendarEditor.Color" placeholder="Color (e.g. #3b82f6)" />
                        <InputText class="form-control" @bind-Value="_calendarEditor.Description" placeholder="Description" />
                        @if (_selectedOrgId.HasValue)
                        {
                            var orgName = _organizations.FirstOrDefault(o => o.Id == _selectedOrgId.Value)?.Name ?? "Organization";
                            <div class="calendar-form-row">
                                <label class="calendar-form-label">Owner</label>
                                <span class="calendar-org-badge">🏢 @orgName</span>
                            </div>
                        }
                    </div>
                    <div class="calendar-form-actions">
                        <button type="submit" class="btn btn-primary">Save Calendar</button>
                        <button type="button" class="btn btn-secondary" @onclick="CancelCalendarEdit">Cancel</button>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
}

@* ── Day Details Modal ── *@
@if (_showDayModal)
{
    <div class="calendar-modal-backdrop" @onclick="CloseDayModal">
        <div class="calendar-modal calendar-modal-sm" @onclick:stopPropagation>
            <div class="calendar-modal-header">
                <h4>@_dayModalDate.ToString("dddd, MMM d")</h4>
                <button class="calendar-modal-close" @onclick="CloseDayModal" title="Close">✕</button>
            </div>
            <div class="calendar-modal-body">
                @if (_dayModalEvents.Count == 0)
                {
                    <p class="calendar-empty-state">No events on this day.</p>
                }
                else
                {
                    @foreach (var evt in _dayModalEvents.OrderBy(e => e.IsAllDay ? 0 : 1).ThenBy(e => e.StartUtc))
                    {
                        <div class="calendar-day-detail-event"
                             style="border-left-color: @(GetEventColor(evt))"
                             @onclick="() => { CloseDayModal(); BeginEditEvent(evt); }">
                            <div class="calendar-day-detail-time">
                                @if (evt.IsAllDay)
                                {
                                    <span class="calendar-all-day-badge">All day</span>
                                }
                                else
                                {
                                    <span>@evt.StartUtc.ToLocalTime().ToString("HH:mm") – @evt.EndUtc.ToLocalTime().ToString("HH:mm")</span>
                                }
                            </div>
                            <div class="calendar-day-detail-title">@evt.Title</div>
                            @if (!string.IsNullOrWhiteSpace(evt.Location))
                            {
                                <div class="calendar-day-detail-location">📍 @evt.Location</div>
                            }
                        </div>
                    }
                }
                <div class="calendar-form-actions" style="margin-top: 16px;">
                    <button class="btn btn-primary" @onclick="CreateEventOnDay">+ Add Event</button>
                    <button class="btn btn-secondary" @onclick="CloseDayModal">Close</button>
                </div>
            </div>
        </div>
    </div>
}

@* ── Delete Confirmation Modal ── *@
@if (_showDeleteModal && _eventEditor is not null)
{
    <div class="calendar-modal-backdrop" @onclick="CancelDelete">
        <div class="calendar-modal calendar-modal-sm" @onclick:stopPropagation>
            <div class="calendar-modal-header">
                <h4>Delete Event</h4>
                <button class="calendar-modal-close" @onclick="CancelDelete" title="Close">✕</button>
            </div>
            <div class="calendar-modal-body">
                <p>Are you sure you want to delete <strong>"@_eventEditor.Title"</strong>?</p>
                <p class="calendar-delete-warning">This action cannot be undone.</p>
                <div class="calendar-form-actions">
                    <button class="btn btn-danger" @onclick="ConfirmDeleteAsync">Delete</button>
                    <button class="btn btn-secondary" @onclick="CancelDelete">Cancel</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private readonly List<CalendarDto> _calendars = [];
