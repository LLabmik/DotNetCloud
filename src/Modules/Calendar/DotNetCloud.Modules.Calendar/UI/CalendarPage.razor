        }

        _eventEditor = new EventEditorModel
        {
            CalendarId = _selectedCalendar.Id,
            StartLocal = DateTime.UtcNow,
            EndLocal = DateTime.UtcNow.AddHours(1)
        };

        _showEventModal = true;
    }

    private void BeginEditEvent(CalendarEventDto dto)
