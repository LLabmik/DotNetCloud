        _showDayModal = false;
        _eventEditor = new EventEditorModel
        {
            CalendarId = _selectedCalendar.Id,
            StartLocal = _dayModalDate.Date.AddHours(9),
            EndLocal = _dayModalDate.Date.AddHours(10)
