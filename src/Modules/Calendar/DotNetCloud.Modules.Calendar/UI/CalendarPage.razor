@namespace DotNetCloud.Modules.Calendar.UI

@using DotNetCloud.Core.DTOs
@using DotNetCloud.Modules.Calendar.Services
@using Microsoft.AspNetCore.WebUtilities
@inject ICalendarApiClient ApiClient
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject NavigationManager Navigation
@inject Microsoft.JSInterop.IJSRuntime JSRuntime

<div class="calendar-page-layout">
    <div class="calendar-sidebar @(_sidebarCollapsed ? "collapsed" : "")">
        <div class="calendar-sidebar-header">
            <h3 class="calendar-sidebar-title">Calendar</h3>
            <button class="calendar-sidebar-toggle" @onclick="ToggleSidebar" title="Toggle sidebar">
                @(_sidebarCollapsed ? "▸" : "◂")
            </button>
            <button class="btn btn-sm btn-primary" @onclick="BeginCreateEvent" title="New Event">
                <span>+</span>
            </button>
        </div>
        <nav class="calendar-nav">
            <a class="calendar-nav-item @(_activeView == "month" ? "active" : "")" @onclick='() => SetView("month")'>Month</a>
            <a class="calendar-nav-item @(_activeView == "week" ? "active" : "")" @onclick='() => SetView("week")'>Week</a>
            <a class="calendar-nav-item @(_activeView == "day" ? "active" : "")" @onclick='() => SetView("day")'>Day</a>
            <a class="calendar-nav-item @(_activeView == "agenda" ? "active" : "")" @onclick='() => SetView("agenda")'>Agenda</a>
        </nav>

        <div class="calendar-list-heading">My Calendars</div>
        <div class="calendar-list">
            @foreach (var calendar in _calendars)
            {
                <button class="calendar-item @(_selectedCalendar?.Id == calendar.Id ? "selected" : "")"
                        @onclick="() => SelectCalendarAsync(calendar.Id)">
                    <span class="calendar-dot" style="background:@(calendar.Color ?? "#3b82f6")"></span>
                    <span>@calendar.Name</span>
                </button>
            }
        </div>

        <div class="calendar-actions">
            <button class="btn btn-sm btn-outline-primary" @onclick="BeginCreateCalendar">New Calendar</button>
            @if (_selectedCalendar is not null)
            {
                <button class="btn btn-sm btn-outline-secondary" @onclick="ToggleSharePanel">
                    @(_showSharePanel ? "Hide Shares" : "Share")
                </button>
                <button class="btn btn-sm btn-outline-secondary" @onclick="ExportCalendarAsync">Export iCal</button>
                <button class="btn btn-sm btn-outline-secondary" @onclick="() => _showImportPanel = !_showImportPanel">Import</button>
            }
        </div>

        @if (_showSharePanel && _selectedCalendar is not null)
        {
            <div class="calendar-share-panel">
                <h4>Shares</h4>
                @if (_shares.Count == 0)
                {
                    <p>Not shared.</p>
                }
                else
                {
                    @foreach (var share in _shares)
                    {
                        <div class="share-item">
                            <span>@(share.SharedWithUserId?.ToString("N")[..8] ?? share.SharedWithTeamId?.ToString("N")[..8] ?? "—")… — @share.Permission</span>
                            <button class="btn btn-sm btn-outline-danger" @onclick="() => RevokeShareAsync(share.Id)">Revoke</button>
                        </div>
                    }
                }
                <div class="share-form">
                    <input type="text" class="form-control form-control-sm" placeholder="User ID" @bind="_shareUserId" />
                    <select class="form-select form-select-sm" @bind="_sharePermission" style="max-width:140px;">
                        <option value="ReadOnly">Read Only</option>
                        <option value="ReadWrite">Read/Write</option>
                    </select>
                    <button class="btn btn-sm btn-primary" @onclick="AddShareAsync">Share</button>
                </div>
            </div>
        }

        @if (_showImportPanel && _selectedCalendar is not null)
        {
            <div class="calendar-import-panel">
                <textarea class="form-control form-control-sm" rows="4" placeholder="Paste iCalendar (.ics) data here…" @bind="_importText"></textarea>
                <button class="btn btn-sm btn-primary" @onclick="ImportCalendarAsync" style="margin-top:8px;">Import</button>
            </div>
        }
    </div>
    <div class="calendar-main">
        @if (!string.IsNullOrWhiteSpace(_operationError))
        {
            <div class="calendar-inline-error">@_operationError</div>
        }

        <div class="calendar-toolbar">
            <button class="btn btn-sm btn-outline-secondary" @onclick="PrevRange">Prev</button>
            <strong>@RangeLabel</strong>
            <button class="btn btn-sm btn-outline-secondary" @onclick="NextRange">Next</button>
        </div>

        @if (_calendarEditor is not null)
        {
            <EditForm Model="_calendarEditor" OnValidSubmit="SaveCalendarAsync">
                <div class="calendar-form-grid">
                    <InputText class="form-control" @bind-Value="_calendarEditor.Name" placeholder="Calendar Name" />
                    <InputText class="form-control" @bind-Value="_calendarEditor.Color" placeholder="Color (e.g. #3b82f6)" />
                    <InputText class="form-control" @bind-Value="_calendarEditor.Description" placeholder="Description" />
                </div>
                <div class="calendar-form-actions">
                    <button type="submit" class="btn btn-primary">Save Calendar</button>
                    <button type="button" class="btn btn-secondary" @onclick="CancelCalendarEdit">Cancel</button>
                </div>
            </EditForm>
        }
        else if (_eventEditor is not null)
        {
            <EditForm Model="_eventEditor" OnValidSubmit="SaveEventAsync">
                <div class="calendar-form-grid">
                    <InputText class="form-control" @bind-Value="_eventEditor.Title" placeholder="Title" />
                    <InputDate class="form-control" @bind-Value="_eventEditor.StartLocal" />
                    <InputDate class="form-control" @bind-Value="_eventEditor.EndLocal" />
                    <InputText class="form-control" @bind-Value="_eventEditor.Location" placeholder="Location" />
                    <InputText class="form-control" @bind-Value="_eventEditor.Description" placeholder="Description" />
                </div>
                <div class="calendar-form-actions">
                    <button type="submit" class="btn btn-primary">Save Event</button>
                    <button type="button" class="btn btn-secondary" @onclick="CancelEventEdit">Cancel</button>
                    @if (_eventEditor.Id.HasValue)
                    {
                        <button type="button" class="btn btn-danger" @onclick="DeleteEventAsync">Delete</button>
                    }
                </div>
            </EditForm>
        }
        else if (_activeView == "month")
        {
            <div class="calendar-month-grid">
                @foreach (var name in DayNames)
                {
                    <div class="calendar-day-header">@name</div>
                }
                @foreach (var day in GetMonthGridDays())
                {
                    var dayEvents = GetEventsForDate(day);
                    <div class="calendar-day-cell @(day.Month != _anchorDate.Month ? "other-month" : "") @(day.Date == DateTime.Today ? "today" : "")"
                         @onclick="() => DayClicked(day)">
                        <span class="calendar-day-number">@day.Day</span>
                        @foreach (var evt in dayEvents)
                        {
                            <div class="calendar-day-event"
                                 style="background:@(GetEventColor(evt))"
                                 @onclick:stopPropagation @onclick="() => BeginEditEvent(evt)">
                                @evt.Title
                            </div>
                        }
                    </div>
                }
            </div>
        }
        else if (_activeView == "week")
        {
            <div class="calendar-week-grid">
                @foreach (var day in GetWeekDays())
                {
                    var dayEvents = GetEventsForDate(day);
                    <div class="calendar-week-col">
                        <div class="calendar-week-col-header @(day.Date == DateTime.Today ? "today" : "")">
                            <span class="calendar-week-day-name">@day.ToString("ddd")</span>
                            <span class="calendar-week-day-num">@day.Day</span>
                        </div>
                        <div class="calendar-week-col-body" @onclick="() => DayClicked(day)">
                            @if (dayEvents.Count == 0)
                            {
                                <span class="calendar-week-empty">&nbsp;</span>
                            }
                            else
                            {
                                @foreach (var evt in dayEvents)
                                {
                                    <div class="calendar-day-event"
                                         style="background:@(GetEventColor(evt))"
                                         @onclick:stopPropagation @onclick="() => BeginEditEvent(evt)">
                                        <span class="calendar-event-time">@evt.StartUtc.ToLocalTime().ToString("HH:mm")</span>
                                        @evt.Title
                                    </div>
                                }
                            }
                        </div>
                    </div>
                }
            </div>
        }
        else if (_activeView == "day")
        {
            <div class="calendar-day-view">
                @for (var h = 0; h < 24; h++)
                {
                    var hour = h;
                    var hourEvents = GetEventsForHour(_anchorDate, hour);
                    <div class="calendar-hour-row @(DateTime.Now.Hour == hour && _anchorDate.Date == DateTime.Today ? "current-hour" : "")">
                        <div class="calendar-hour-label">@($"{hour:D2}:00")</div>
                        <div class="calendar-hour-content" @onclick="() => CreateEventAtHour(hour)">
                            @foreach (var evt in hourEvents)
                            {
                                <div class="calendar-day-event"
                                     style="background:@(GetEventColor(evt))"
                                     @onclick:stopPropagation @onclick="() => BeginEditEvent(evt)">
                                    @evt.Title
                                    <span class="calendar-event-time">@evt.StartUtc.ToLocalTime().ToString("HH:mm") – @evt.EndUtc.ToLocalTime().ToString("HH:mm")</span>
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            @* Agenda view — flat event list *@
            <div class="calendar-events-panel">
                @if (_events.Count == 0)
                {
                    <p>No events in this range.</p>
                }
                else
                {
                    @foreach (var eventItem in _events.OrderBy(e => e.StartUtc))
                    {
                        <div class="calendar-event-row">
                            <button class="btn btn-link p-0 text-start" @onclick="() => BeginEditEvent(eventItem)">
                                <strong>@eventItem.Title</strong>
                                <span>@eventItem.StartUtc.ToLocalTime().ToString("g") – @eventItem.EndUtc.ToLocalTime().ToString("g")</span>
                                <span>@eventItem.Location</span>
                            </button>
                            @if (CanCurrentUserRsvp(eventItem))
                            {
                                <div class="calendar-rsvp-buttons">
                                    <button class="btn btn-sm btn-outline-success" @onclick="() => RsvpAsync(eventItem.Id, AttendeeStatus.Accepted)">Accept</button>
                                    <button class="btn btn-sm btn-outline-warning" @onclick="() => RsvpAsync(eventItem.Id, AttendeeStatus.Tentative)">Maybe</button>
                                    <button class="btn btn-sm btn-outline-danger" @onclick="() => RsvpAsync(eventItem.Id, AttendeeStatus.Declined)">Decline</button>
                                </div>
                            }
                            <CrossModuleLinkList Requests="BuildAttendeeContactRequests(eventItem)" />
                        </div>
                    }
                }
            </div>
        }
    </div>
</div>

@code {
    private readonly List<CalendarDto> _calendars = [];
    private readonly List<CalendarEventDto> _events = [];
    private readonly List<CalendarShareResponse> _shares = [];
    private string _activeView = "month";
    private CalendarDto? _selectedCalendar;
    private DateTime _anchorDate = DateTime.UtcNow.Date;
    private CalendarEditorModel? _calendarEditor;
    private EventEditorModel? _eventEditor;
    private bool _showSharePanel;
    private bool _showImportPanel;
    private Guid? _currentUserId;
    private string? _operationError;
    private string _shareUserId = string.Empty;
    private string _sharePermission = "ReadOnly";
    private string _importText = string.Empty;
    private bool _sidebarCollapsed;

    private string RangeLabel => _activeView switch
    {
        "day" => _anchorDate.ToLocalTime().ToString("D"),
        "week" => $"Week of {_anchorDate.ToLocalTime():d}",
        _ => _anchorDate.ToLocalTime().ToString("Y")
    };

    private static readonly string[] DayNames = ["Sun", "Mon", "Tue", "Wed", "Thu", "Fri", "Sat"];

    private List<DateTime> GetMonthGridDays()
    {
        var firstOfMonth = new DateTime(_anchorDate.Year, _anchorDate.Month, 1);
        var startOffset = (int)firstOfMonth.DayOfWeek;
        var startDate = firstOfMonth.AddDays(-startOffset);
        var days = new List<DateTime>(42);
        for (var i = 0; i < 42; i++)
        {
            days.Add(startDate.AddDays(i));
        }
        return days;
    }

    private List<DateTime> GetWeekDays()
    {
        var startOfWeek = _anchorDate.Date.AddDays(-(int)_anchorDate.DayOfWeek);
        var days = new List<DateTime>(7);
        for (var i = 0; i < 7; i++)
        {
            days.Add(startOfWeek.AddDays(i));
        }
        return days;
    }

    private List<CalendarEventDto> GetEventsForDate(DateTime date)
    {
        return _events
            .Where(e => e.StartUtc.ToLocalTime().Date == date.Date)
            .OrderBy(e => e.StartUtc)
            .ToList();
    }

    private List<CalendarEventDto> GetEventsForHour(DateTime date, int hour)
    {
        return _events
            .Where(e =>
            {
                var local = e.StartUtc.ToLocalTime();
                return local.Date == date.Date && local.Hour == hour;
            })
            .OrderBy(e => e.StartUtc)
            .ToList();
    }

    private string GetEventColor(CalendarEventDto evt)
    {
        var color = evt.Color
            ?? _calendars.FirstOrDefault(c => c.Id == evt.CalendarId)?.Color
            ?? "#3b82f6";
        return $"color-mix(in srgb, {color} 20%, transparent)";
    }

    private void DayClicked(DateTime day)
    {
        if (_selectedCalendar is null)
        {
            return;
        }

        _eventEditor = new EventEditorModel
        {
            CalendarId = _selectedCalendar.Id,
            StartLocal = day.Date.AddHours(9),
            EndLocal = day.Date.AddHours(10)
        };
        _calendarEditor = null;
    }

    private void CreateEventAtHour(int hour)
    {
        if (_selectedCalendar is null)
        {
            return;
        }

        _eventEditor = new EventEditorModel
        {
            CalendarId = _selectedCalendar.Id,
            StartLocal = _anchorDate.Date.AddHours(hour),
            EndLocal = _anchorDate.Date.AddHours(hour + 1)
        };
        _calendarEditor = null;
    }

    private async Task ToggleSidebar()
    {
        _sidebarCollapsed = !_sidebarCollapsed;
        await SaveSidebarCollapsedStateAsync();
    }

    private async Task SaveSidebarCollapsedStateAsync()
    {
        try
        {
            await JSRuntime.InvokeAsync<object?>("localStorage.setItem", new object?[] { "dotnetcloud.sidebar:calendar", _sidebarCollapsed.ToString().ToLowerInvariant() });
        }
        catch
        {
            // localStorage unavailable
        }
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var collapsed = await JSRuntime.InvokeAsync<string>("localStorage.getItem", new object?[] { "dotnetcloud.sidebar:calendar" });
            if (bool.TryParse(collapsed ?? "false", out var parsed))
            {
                _sidebarCollapsed = parsed;
            }
        }
        catch
        {
            // localStorage unavailable
        }

        await ResolveCurrentUserAsync();
        await ReloadCalendarsAsync();
        await TryOpenEventFromQueryAsync();
    }

    private async Task TryOpenEventFromQueryAsync()
    {
        var uri = Navigation.ToAbsoluteUri(Navigation.Uri);
        if (!QueryHelpers.ParseQuery(uri.Query).TryGetValue("eventId", out var eventIdValue))
            return;
        if (!Guid.TryParse(eventIdValue, out var eventId))
            return;

        try
        {
            var evt = await ApiClient.GetEventAsync(eventId);
            if (evt is null) return;

            // Select the calendar that owns this event
            var calendar = _calendars.FirstOrDefault(c => c.Id == evt.CalendarId);
            if (calendar is not null)
            {
                _selectedCalendar = calendar;
                _anchorDate = evt.StartUtc.ToLocalTime();
                await ReloadEventsAsync();
            }

            // Open the event editor
            BeginEditEvent(evt);
        }
        catch
        {
            // Event not found or access denied — ignore
        }
    }

    private async Task ResolveCurrentUserAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var principal = authState.User;

        var claimValue = principal.FindFirst(ClaimTypes.NameIdentifier)?.Value
            ?? principal.FindFirst("sub")?.Value;

        if (Guid.TryParse(claimValue, out var userId))
        {
            _currentUserId = userId;
        }
    }

    private bool CanCurrentUserRsvp(CalendarEventDto eventDto)
    {
        return _currentUserId.HasValue && eventDto.Attendees.Any(a => a.UserId == _currentUserId.Value);
    }

    private async Task ReloadCalendarsAsync()
    {
        _calendars.Clear();
        _calendars.AddRange(await ApiClient.ListCalendarsAsync());

        // Auto-create a default "Personal" calendar on first access
        if (_calendars.Count == 0)
        {
            var created = await ApiClient.CreateCalendarAsync(new CreateCalendarDto
            {
                Name = "Personal",
                Color = "#3b82f6",
                Description = "Default personal calendar"
            });

            if (created is not null)
            {
                _calendars.Add(created);
            }
        }

        _selectedCalendar ??= _calendars.FirstOrDefault();
        if (_selectedCalendar is not null)
        {
            await ReloadEventsAsync();
        }
    }

    private async Task ReloadEventsAsync()
    {
        if (_selectedCalendar is null)
        {
            _events.Clear();
            return;
        }

        var (startUtc, endUtc) = GetRange();
        _events.Clear();
        _events.AddRange(await ApiClient.ListEventsAsync(_selectedCalendar.Id, startUtc, endUtc));
    }

    private (DateTime startUtc, DateTime endUtc) GetRange()
    {
        return _activeView switch
        {
            "day" => (_anchorDate.Date, _anchorDate.Date.AddDays(1)),
            "week" => (_anchorDate.Date, _anchorDate.Date.AddDays(7)),
            "agenda" => (_anchorDate.Date, _anchorDate.Date.AddDays(30)),
            _ => (new DateTime(_anchorDate.Year, _anchorDate.Month, 1), new DateTime(_anchorDate.Year, _anchorDate.Month, 1).AddMonths(1))
        };
    }

    private async Task SelectCalendarAsync(Guid calendarId)
    {
        _selectedCalendar = _calendars.FirstOrDefault(c => c.Id == calendarId);
        await ReloadEventsAsync();
    }

    private async Task SetView(string view)
    {
        _activeView = view;
        await ReloadEventsAsync();
    }

    private async Task PrevRange()
    {
        _anchorDate = _activeView switch
        {
            "day" => _anchorDate.AddDays(-1),
            "week" => _anchorDate.AddDays(-7),
            "agenda" => _anchorDate.AddDays(-30),
            _ => _anchorDate.AddMonths(-1)
        };

        await ReloadEventsAsync();
    }

    private async Task NextRange()
    {
        _anchorDate = _activeView switch
        {
            "day" => _anchorDate.AddDays(1),
            "week" => _anchorDate.AddDays(7),
            "agenda" => _anchorDate.AddDays(30),
            _ => _anchorDate.AddMonths(1)
        };

        await ReloadEventsAsync();
    }

    private void BeginCreateCalendar()
    {
        _calendarEditor = new CalendarEditorModel();
        _eventEditor = null;
    }

    private async Task SaveCalendarAsync()
    {
        if (_calendarEditor is null)
        {
            return;
        }

        if (_calendarEditor.Id is null)
        {
            await ApiClient.CreateCalendarAsync(_calendarEditor.ToCreateDto());
        }
        else
        {
            await ApiClient.UpdateCalendarAsync(_calendarEditor.Id.Value, _calendarEditor.ToUpdateDto());
        }

        _calendarEditor = null;
        await ReloadCalendarsAsync();
    }

    private void CancelCalendarEdit()
    {
        _calendarEditor = null;
    }

    private void BeginCreateEvent()
    {
        if (_selectedCalendar is null)
        {
            return;
        }

        _eventEditor = new EventEditorModel
        {
            CalendarId = _selectedCalendar.Id,
            StartLocal = DateTime.UtcNow,
            EndLocal = DateTime.UtcNow.AddHours(1)
        };

        _calendarEditor = null;
    }

    private void BeginEditEvent(CalendarEventDto dto)
    {
        _eventEditor = EventEditorModel.From(dto);
        _calendarEditor = null;
    }

    private async Task SaveEventAsync()
    {
        if (_eventEditor is null)
        {
            return;
        }

        if (_eventEditor.Id is null)
        {
            await ApiClient.CreateEventAsync(_eventEditor.ToCreateDto());
        }
        else
        {
            await ApiClient.UpdateEventAsync(_eventEditor.Id.Value, _eventEditor.ToUpdateDto());
        }

        _eventEditor = null;
        await ReloadEventsAsync();
    }

    private void CancelEventEdit()
    {
        _eventEditor = null;
    }

    private async Task DeleteEventAsync()
    {
        if (_eventEditor?.Id is not Guid eventId)
        {
            return;
        }

        await ApiClient.DeleteEventAsync(eventId);
        _eventEditor = null;
        await ReloadEventsAsync();
    }

    private async Task RsvpAsync(Guid eventId, AttendeeStatus status)
    {
        _operationError = null;

        try
        {
            await ApiClient.RsvpAsync(eventId, new EventRsvpDto { Status = status });
            await ReloadEventsAsync();
        }
        catch (HttpRequestException)
        {
            _operationError = "RSVP failed for this event. You may not be listed as an attendee.";
        }
    }

    private async Task ToggleSharePanel()
    {
        _showSharePanel = !_showSharePanel;
        if (_showSharePanel && _selectedCalendar is not null)
        {
            _shares.Clear();
            _shares.AddRange(await ApiClient.ListSharesAsync(_selectedCalendar.Id));
        }
    }

    private async Task AddShareAsync()
    {
        if (_selectedCalendar is null || !Guid.TryParse(_shareUserId, out var userId))
        {
            return;
        }

        await ApiClient.ShareCalendarAsync(_selectedCalendar.Id, userId, null, _sharePermission);
        _shareUserId = string.Empty;
        _shares.Clear();
        _shares.AddRange(await ApiClient.ListSharesAsync(_selectedCalendar.Id));
    }

    private async Task RevokeShareAsync(Guid shareId)
    {
        await ApiClient.RevokeShareAsync(shareId);
        if (_selectedCalendar is not null)
        {
            _shares.Clear();
            _shares.AddRange(await ApiClient.ListSharesAsync(_selectedCalendar.Id));
        }
    }

    private async Task ExportCalendarAsync()
    {
        if (_selectedCalendar is null)
        {
            return;
        }

        _exportedIcal = await ApiClient.ExportCalendarICalAsync(_selectedCalendar.Id);
    }

    private async Task ImportCalendarAsync()
    {
        if (_selectedCalendar is null || string.IsNullOrWhiteSpace(_importText))
        {
            return;
        }

        await ApiClient.ImportICalAsync(_selectedCalendar.Id, _importText);
        _importText = string.Empty;
        _showImportPanel = false;
        await ReloadEventsAsync();
    }

    private string? _exportedIcal;

    private sealed class CalendarEditorModel
    {
        public Guid? Id { get; set; }
        public string Name { get; set; } = string.Empty;
        public string? Description { get; set; }
        public string? Color { get; set; }

        public CreateCalendarDto ToCreateDto() => new()
        {
            Name = Name,
            Description = Description,
            Color = Color
        };

        public UpdateCalendarDto ToUpdateDto() => new()
        {
            Name = Name,
            Description = Description,
            Color = Color
        };
    }

    private sealed class EventEditorModel
    {
        public Guid? Id { get; set; }
        public Guid CalendarId { get; set; }
        public string Title { get; set; } = string.Empty;
        public string? Description { get; set; }
        public string? Location { get; set; }
        public DateTime StartLocal { get; set; }
        public DateTime EndLocal { get; set; }

        public static EventEditorModel From(CalendarEventDto dto) => new()
        {
            Id = dto.Id,
            CalendarId = dto.CalendarId,
            Title = dto.Title,
            Description = dto.Description,
            Location = dto.Location,
            StartLocal = dto.StartUtc.ToLocalTime(),
            EndLocal = dto.EndUtc.ToLocalTime()
        };

        public CreateCalendarEventDto ToCreateDto() => new()
        {
            CalendarId = CalendarId,
            Title = Title,
            Description = Description,
            Location = Location,
            StartUtc = StartLocal.ToUniversalTime(),
            EndUtc = EndLocal.ToUniversalTime()
        };

        public UpdateCalendarEventDto ToUpdateDto() => new()
        {
            Title = Title,
            Description = Description,
            Location = Location,
            StartUtc = StartLocal.ToUniversalTime(),
            EndUtc = EndLocal.ToUniversalTime()
        };
    }

    private static IReadOnlyList<CrossModuleLinkRequest> BuildAttendeeContactRequests(CalendarEventDto eventDto)
    {
        return eventDto.Attendees
            .Where(a => a.UserId.HasValue)
            .Select(a => new CrossModuleLinkRequest
            {
                LinkType = CrossModuleLinkType.Contact,
                TargetId = a.UserId!.Value
            })
            .DistinctBy(r => r.TargetId)
            .ToList();
    }
}
