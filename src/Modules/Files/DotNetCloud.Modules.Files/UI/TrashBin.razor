@namespace DotNetCloud.Modules.Files.UI

@*
    Trash bin page - Lists deleted files with restore and permanent delete options.
    Supports sorting, bulk selection, and a total trash size display.
    Code-behind: TrashBin.razor.cs
*@

<div class="trash-bin-page">
    <div class="page-header">
        <h1>Trash</h1>
        <div class="page-header-meta">
            @if (TrashedItems.Count > 0)
            {
                <span class="trash-size-info">@TrashedItems.Count items &mdash; @TrashTotalSizeLabel</span>
            }
        </div>
        @if (TrashedItems.Count > 0)
        {
            <button class="btn btn-danger btn-sm" @onclick="EmptyTrash">
                Empty Trash
            </button>
        }
    </div>

    @if (TrashedItems.Count == 0)
    {
        <div class="empty-state">
            <p>Trash is empty</p>
            <p class="text-muted">Deleted files will appear here for @RetentionDays days before permanent deletion.</p>
        </div>
    }
    else
    {
        <div class="trash-toolbar">
            <label class="checkbox-label">
                <input type="checkbox"
                       checked="@IsAllSelected"
                       @onchange="ToggleSelectAll"
                       aria-label="Select all" />
                <span>Select all</span>
            </label>
            @if (SelectedCount > 0)
            {
                <span class="selection-info">@SelectedCount selected</span>
                <button class="btn btn-sm" @onclick="RestoreSelected">Restore selected</button>
                <button class="btn btn-sm btn-danger" @onclick="DeleteSelected">Delete selected</button>
            }
        </div>

        <div class="trash-list">
            <div class="trash-list-header">
                <div class="col-check"></div>
                <div class="col-icon"></div>
                <button class="col-name sort-header @SortHeaderClass("Name")"
                        @onclick='() => SetSort("Name")'>
                    Name @SortIndicator("Name")
                </button>
                <button class="col-date sort-header @SortHeaderClass("Date")"
                        @onclick='() => SetSort("Date")'>
                    Deleted @SortIndicator("Date")
                </button>
                <button class="col-size sort-header @SortHeaderClass("Size")"
                        @onclick='() => SetSort("Size")'>
                    Size @SortIndicator("Size")
                </button>
                <div class="col-actions"></div>
            </div>

            @foreach (var item in SortedItems)
            {
                <div class="trash-item @(IsSelected(item.Id) ? "selected" : "")">
                    <div class="col-check">
                        <input type="checkbox"
                               checked="@IsSelected(item.Id)"
                               @onchange="() => ToggleSelect(item.Id)"
                               aria-label="Select @item.Name" />
                    </div>
                    <div class="col-icon file-icon">
                        @(item.NodeType == "Folder" ? "[Folder]" : "[File]")
                    </div>
                    <div class="col-name file-info">
                        <span class="file-name" title="@item.Name">@item.Name</span>
                    </div>
                    <div class="col-date file-meta">
                        @item.DeletedAt?.ToString("MMM d, yyyy HH:mm")
                    </div>
                    <div class="col-size file-meta">
                        @if (item.Size > 0)
                        {
                            @FormatSize(item.Size)
                        }
                        else
                        {
                            <text>&mdash;</text>
                        }
                    </div>
                    <div class="col-actions trash-actions">
                        <button class="btn btn-sm" @onclick="() => RestoreItem(item.Id)">
                            Restore
                        </button>
                        <button class="btn btn-sm btn-danger" @onclick="() => PurgeItem(item.Id)">
                            Delete Forever
                        </button>
                    </div>
                </div>
            }
        </div>
    }
</div>
