@namespace DotNetCloud.Modules.Files.UI
@inject IJSRuntime JS

@*
    File upload dialog — uses JavaScript fetch() for direct HTTP uploads,
    bypassing Blazor Server's SignalR channel. Supports files up to 16 GB.
    Code-behind: FileUploadComponent.razor.cs
*@

<div class="file-upload-overlay">
    <div class="file-upload-dialog">
        <div class="file-upload-header">
            <h3>Upload Files</h3>
            <button class="btn-icon" @onclick="OnCancel" title="Close" disabled="@IsUploading">✕</button>
        </div>

        @if (!string.IsNullOrWhiteSpace(ErrorMessage) && !IsUploading)
        {
            <div class="alert alert-danger alert-dismissible">
                @ErrorMessage
                <button class="btn-icon alert-close" @onclick="DismissError" title="Dismiss">✕</button>
            </div>
        }

        <div class="file-upload-dropzone @(IsDragging ? "dragging" : "")"
             @ondragenter="HandleDragEnter"
             @ondragleave="HandleDragLeave"
             @ondragover:preventDefault
             @ondrop:preventDefault
             hidden="@IsUploading"
             aria-hidden="@IsUploading">
            <input type="file" id="@FileInputId" class="file-upload-input-overlay"
                   @onchange="HandleFileInputChange"
                   multiple
                   disabled="@IsUploading"
                   aria-label="Drop files or click to browse" />
            <span class="dropzone-icon" aria-hidden="true">⤴</span>
            <p>Drag and drop files here</p>
            <p class="text-muted">or</p>
            <span class="btn btn-primary btn-sm" role="button" aria-hidden="true">
                Browse Files
            </span>
            <p class="text-muted text-xs">Hold Shift or Ctrl to select multiple files</p>
        </div>

        @if (Files.Count > 0)
        {
            @if (IsUploading)
            {
                <div class="upload-panel-files" style="margin: 0.5rem 0;">
                    @for (var i = 0; i < Files.Count; i++)
                    {
                        var idx = i;
                        var file = Files[idx];
                        @if (file.DismissedFromView) { continue; }
                        <div class="upload-panel-file @(file.Status == UploadStatus.Failed ? "upload-panel-file--error" : "")">
                            <div class="upload-file-header">
                                <span class="upload-file-name" title="@file.Name">@TruncateName(file.Name)</span>
                                <div class="upload-file-controls">
                                    @if (file.Status == UploadStatus.Uploading)
                                    {
                                        <button class="btn-icon btn-xs" @onclick="() => PauseUpload(idx)"
                                                title="Pause">⏸</button>
                                    }
                                    else if (file.Status == UploadStatus.Paused)
                                    {
                                        <button class="btn-icon btn-xs" @onclick="() => ResumeUpload(idx)"
                                                title="Resume">▶</button>
                                    }
                                    @if (file.Status is UploadStatus.Uploading or UploadStatus.Paused)
                                    {
                                        <button class="btn-icon btn-xs" @onclick="() => CancelUpload(idx)"
                                                title="Cancel">✕</button>
                                    }
                                    <span class="upload-file-status-label">@file.StatusText</span>
                                </div>
                            </div>
                            <div class="upload-file-progress">
                                <div class="progress-bar-track progress-bar-track--sm">
                                    <div class="progress-bar-fill @GetProgressClass(file.Status)"
                                         style="width: @(file.Progress)%"></div>
                                </div>
                                <span class="upload-file-pct">@file.Progress%</span>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="file-upload-list">
                    @foreach (var file in Files)
                    {
                        <div class="upload-item">
                            <span class="upload-name" title="@file.Name">@file.Name</span>
                            <span class="upload-size">@FormatSize(file.Size)</span>
                            <button class="btn-icon btn-xs upload-remove"
                                    @onclick="() => RemoveFile(file)" title="Remove">✕</button>
                        </div>
                    }
                </div>
            }

            @if (!IsUploading)
            {
                <div class="file-upload-footer">
                    <button class="btn btn-primary" @onclick="StartUpload">
                        Upload @(Files.Count == 1 ? "1 File" : $"{Files.Count} Files")
                    </button>
                    <button class="btn" @onclick="ClearFiles">Clear</button>
                </div>
            }
        }
    </div>
</div>
