@namespace DotNetCloud.Modules.Files.UI

@*
    File upload dialog with drag-drop file selection and chunked upload progress.
    While uploading, the file list is replaced by an UploadProgressPanel.
    Code-behind: FileUploadComponent.razor.cs
*@

<div class="file-upload-overlay">
    <div class="file-upload-dialog">
        <div class="file-upload-header">
            <h3>Upload Files</h3>
            <button class="btn-icon" @onclick="OnCancel" title="Close">✕</button>
        </div>

        @if (!IsUploading)
        {
            @if (!string.IsNullOrWhiteSpace(ErrorMessage))
            {
                <div class="alert alert-danger">@ErrorMessage</div>
            }

            <div class="file-upload-dropzone @(IsDragging ? "dragging" : "")"
                 @ondragenter="HandleDragEnter"
                 @ondragleave="HandleDragLeave"
                 @ondragover:preventDefault>
                <span class="dropzone-icon" aria-hidden="true">⤴</span>
                <p>Drag and drop files here</p>
                <p class="text-muted">or</p>
                <label class="btn btn-primary btn-sm">
                    Browse Files
                    <InputFile OnChange="HandleFileSelected" multiple style="display:none;" />
                </label>
                <p class="text-muted text-xs">Hold Shift or Ctrl to select multiple files</p>
            </div>
        }

        @if (Files.Count > 0)
        {
            @if (IsUploading)
            {
                <UploadProgressPanel
                    Files="Files"
                    OnPause="PauseUpload"
                    OnResume="ResumeUpload"
                    OnCancel="CancelUpload"
                    OnClose="ClearFiles" />
            }
            else
            {
                <div class="file-upload-list">
                    @foreach (var file in Files)
                    {
                        <div class="upload-item @(file.IsCancelled ? "upload-item--cancelled" : "")">
                            <span class="upload-name" title="@file.Name">@file.Name</span>
                            <span class="upload-size">@FormatSize(file.Size)</span>
                            <button class="btn-icon btn-xs upload-remove"
                                    @onclick="() => RemoveFile(file)" title="Remove">✕</button>
                        </div>
                    }
                </div>
            }

            @if (!IsUploading)
            {
                <div class="file-upload-footer">
                    <button class="btn btn-primary" @onclick="StartUpload">
                        Upload @(Files.Count == 1 ? "1 File" : $"{Files.Count} Files")
                    </button>
                    <button class="btn" @onclick="ClearFiles">Clear</button>
                </div>
            }
        }
    </div>
</div>
