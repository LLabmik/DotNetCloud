@namespace DotNetCloud.Modules.Files.UI

@*
    File browser page — main UI for the Files module.
    Displays files and folders in grid/list view with breadcrumbs, drag-drop upload,
    thumbnails in grid mode, and full-screen file preview with navigation.
    Code-behind: FileBrowser.razor.cs
*@

<div class="files-browser @(IsBrowserDragging ? "files-browser--drag-over" : "")"
     @ondragenter="HandleBrowserDragEnter"
     @ondragleave="HandleBrowserDragLeave"
     @ondragover:preventDefault
     @ondrop="HandleBrowserDrop">

    @* Drop overlay shown when dragging files over the browser *@
    @if (IsBrowserDragging)
    {
        <div class="browser-drop-overlay" aria-label="Drop files to upload">
            <div class="browser-drop-message">
                <span class="browser-drop-icon">[Upload]</span>
                <p>Drop files to upload to this folder</p>
            </div>
        </div>
    }

    <div class="files-header">
        <h1>Files</h1>
        <div class="files-header-actions">
            <button class="btn btn-sm" @onclick="ToggleViewMode" title="Toggle view">
                @GetViewToggleLabel()
            </button>
        </div>
    </div>

    <nav class="files-breadcrumbs" aria-label="File path">
        <ol>
            <li>
                <a href="#" @onclick="() => NavigateToFolder(null)" @onclick:preventDefault>Home</a>
            </li>
            @foreach (var crumb in Breadcrumbs)
            {
                <li>
                    <span class="separator">/</span>
                    <a href="#" @onclick="() => NavigateToFolder(crumb.Id)" @onclick:preventDefault>
                        @crumb.Name
                    </a>
                </li>
            }
        </ol>
    </nav>

    <div class="files-actions">
        <button class="btn btn-primary btn-sm" @onclick="ShowCreateFolderDialog">New Folder</button>
        <button class="btn btn-primary btn-sm" @onclick="ShowUploadDialog">Upload</button>
        @if (SelectedCount > 0)
        {
            <span class="selection-info">@SelectedCount selected</span>
            <button class="btn btn-sm btn-danger" @onclick="DeleteSelected">Delete</button>
            <button class="btn btn-sm" @onclick="ClearSelection">Clear</button>
        }
    </div>

    @if (IsShowUploadDialog)
    {
        <FileUploadComponent
            ParentId="CurrentFolderId"
            OnUploadComplete="HandleUploadComplete"
            OnCancel="HideUploadDialog" />
    }

    @if (IsShowCreateFolder)
    {
        <div class="create-folder-dialog">
            <input type="text" @bind="NewFolderName" placeholder="Folder name"
                   @onkeydown="HandleFolderKeyDown" autofocus />
            <button class="btn btn-primary btn-sm" @onclick="CreateFolder">Create</button>
            <button class="btn btn-sm" @onclick="HideCreateFolder">Cancel</button>
        </div>
    }

    @if (IsLoading)
    {
        <div class="loading-state" aria-live="polite">
            <div class="loading-skeleton">
                @for (var i = 0; i < 8; i++)
                {
                    <div class="skeleton-row">
                        <div class="skeleton-icon"></div>
                        <div class="skeleton-name"></div>
                        <div class="skeleton-meta"></div>
                    </div>
                }
            </div>
        </div>
    }
    else if (Nodes.Count == 0)
    {
        <div class="empty-state" role="status">
            <p class="empty-state-title">No files yet — upload or create a folder</p>
            <p class="text-muted empty-state-hint">You can also drag and drop files anywhere on this page.</p>
            <div class="empty-state-actions">
                <button class="btn btn-primary btn-sm" @onclick="ShowCreateFolderDialog">New Folder</button>
                <button class="btn btn-primary btn-sm" @onclick="ShowUploadDialog">Upload</button>
            </div>
        </div>
    }
    else
    {
        @if (_viewMode == ViewMode.List)
        {
            <div class="files-list-header">
                <div class="col-check"></div>
                <div class="col-icon"></div>
                <button class="col-name sort-header @SortHeaderClass("Name")"
                        @onclick='() => SetSort("Name")'>
                    Name @SortIndicator("Name")
                </button>
                <button class="col-type sort-header @SortHeaderClass("Type")"
                        @onclick='() => SetSort("Type")'>
                    Type @SortIndicator("Type")
                </button>
                <button class="col-size sort-header @SortHeaderClass("Size")"
                        @onclick='() => SetSort("Size")'>
                    Size @SortIndicator("Size")
                </button>
                <button class="col-date sort-header @SortHeaderClass("Date")"
                        @onclick='() => SetSort("Date")'>
                    Modified @SortIndicator("Date")
                </button>
                <div class="col-actions"></div>
            </div>
        }

        <div class="@GetFilesContainerClass()">
            @foreach (var node in SortedNodes)
            {
                <div class="file-item @(IsSelected(node.Id) ? "selected" : "")"
                     @onclick="() => HandleNodeClick(node)"
                     @ondblclick="() => HandleNodeDoubleClick(node)">

                    <div class="file-icon">
                        @if (_viewMode == ViewMode.Grid && node.ThumbnailUrl is not null)
                        {
                            <img src="@node.ThumbnailUrl" alt="" class="file-thumbnail"
                                 loading="lazy" />
                        }
                        else
                        {
                            @GetNodeIcon(node)
                        }
                    </div>

                    <div class="file-info">
                        <span class="file-name" title="@node.Name">@node.Name</span>
                        <span class="file-meta">
                            @if (node.NodeType == "File")
                            {
                                @FormatSize(node.Size)
                            }
                            <text> </text>@node.UpdatedAt.ToString("MMM d, yyyy")
                        </span>
                    </div>

                    <div class="file-actions">
                        <button class="btn-icon" @onclick:stopPropagation
                                @onclick="() => ToggleFavorite(node.Id)"
                                title="@(node.IsFavorite ? "Unfavorite" : "Favorite")">
                            @(node.IsFavorite ? "★" : "☆")
                        </button>
                        <button class="btn-icon" @onclick:stopPropagation
                                @onclick="() => ShowShareDialog(node)" title="Share">Share</button>
                    </div>
                </div>
            }
        </div>

        @if (TotalCount > PageSize)
        {
            <div class="files-pagination">
                <button class="btn btn-sm" disabled="@(CurrentPage <= 1)"
                        @onclick="PreviousPage">Previous</button>
                <span>Page @CurrentPage of @TotalPages</span>
                <button class="btn btn-sm" disabled="@(CurrentPage >= TotalPages)"
                        @onclick="NextPage">Next</button>
            </div>
        }
    }

    @if (IsShowShareDialog && ShareTargetNode is not null)
    {
        <ShareDialog Node="ShareTargetNode" OnClose="HideShareDialog" />
    }

    @if (IsShowPreview && PreviewNode is not null)
    {
        <FilePreview
            Node="PreviewNode"
            AllNodes="SortedNodes"
            ApiBaseUrl="ApiBaseUrl"
            OnClose="HidePreview"
            OnShare="HandlePreviewShare"
            OnDownload="HandlePreviewDownload" />
    }

    @if (IsShowDocumentEditor && EditorNode is not null)
    {
        <div class="document-editor-overlay">
            <DocumentEditor
                FileId="EditorNode.Id"
                FileName="EditorNode.Name"
                UserId="UserId"
                ApiBaseUrl="ApiBaseUrl"
                OnClose="HideDocumentEditor"
                OnDownload="HideDocumentEditor" />
        </div>
    }

</div>
