@namespace DotNetCloud.Modules.Files.UI

@*
    "Shared by me" view — displays all files and folders the current user has shared.
    Shows recipients, permission levels, and supports inline share revocation.
    Code-behind: SharedByMeView.razor.cs
*@

<div class="shared-view shared-by-me">
    <div class="shared-view-header">
        <h2>Shared by me</h2>
    </div>

    @if (IsLoading)
    {
        <div class="loading-state" aria-live="polite">
            <div class="loading-skeleton">
                @for (var i = 0; i < 5; i++)
                {
                    <div class="skeleton-row">
                        <div class="skeleton-icon"></div>
                        <div class="skeleton-name"></div>
                        <div class="skeleton-meta"></div>
                    </div>
                }
            </div>
        </div>
    }
    else if (Items.Count == 0)
    {
        <div class="empty-state" role="status">
            <p class="empty-state-title">You haven't shared anything yet</p>
            <p class="text-muted empty-state-hint">
                Share files or folders from the file browser to collaborate with others.
            </p>
        </div>
    }
    else
    {
        <div class="shared-by-me-sort-bar">
            <button class="sort-btn @SortHeaderClass("Name")"
                    @onclick='() => SetSort("Name")'>
                Name @SortIndicator("Name")
            </button>
            <button class="sort-btn @SortHeaderClass("Date")"
                    @onclick='() => SetSort("Date")'>
                Shared @SortIndicator("Date")
            </button>
        </div>

        <ul class="shared-items-list shared-by-me-items">
            @foreach (var item in SortedItems)
            {
                <li class="shared-item @(item.IsExpired ? "shared-item--expired" : "")">
                    <div class="shared-item-icon">@GetNodeIcon(item)</div>

                    <div class="shared-item-content">
                        <div class="shared-item-top-row">
                            <span class="shared-item-name">@item.NodeName</span>
                            @if (item.NodeType == "File")
                            {
                                <span class="shared-item-size text-muted">@FormatSize(item.Size)</span>
                            }
                        </div>
                        <div class="shared-item-bottom-row">
                            <div class="shared-item-recipient">
                                <span class="badge badge-@item.ShareType.ToLowerInvariant()">
                                    @item.ShareType
                                </span>
                                <span class="recipient-name">
                                    @if (item.ShareType == "PublicLink")
                                    {
                                        <text>Anyone with link</text>
                                        @if (item.LinkUrl is not null)
                                        {
                                            <button class="btn-icon btn-sm"
                                                    @onclick="() => CopyLink(item)"
                                                    title="Copy link">
                                                📋
                                            </button>
                                        }
                                    }
                                    else
                                    {
                                        @item.SharedWithName
                                    }
                                </span>
                            </div>

                            <div class="shared-item-permission">
                                <select class="form-control form-control-sm share-inline-permission"
                                        value="@item.Permission"
                                        @onchange="e => UpdatePermission(item, e.Value?.ToString() ?? item.Permission)">
                                    <option value="Read">View only</option>
                                    <option value="ReadWrite">Can edit</option>
                                    <option value="Full">Full access</option>
                                </select>
                            </div>

                            <div class="shared-item-date">
                                <span>@item.SharedAt.ToString("MMM d, yyyy")</span>
                                @if (item.IsExpired)
                                {
                                    <span class="badge badge-danger">Expired</span>
                                }
                                else if (item.ExpiresAt.HasValue)
                                {
                                    <span class="text-muted">
                                        (expires @FormatRelativeDate(item.ExpiresAt.Value))
                                    </span>
                                }
                                @if (item.ShareType == "PublicLink" && item.MaxDownloads.HasValue)
                                {
                                    <span class="text-muted">
                                        @item.DownloadCount/@item.MaxDownloads downloads
                                    </span>
                                }
                            </div>
                        </div>
                    </div>

                    <div class="shared-item-actions">
                        <button class="btn btn-sm btn-outline" @onclick="() => ManageShare(item)"
                                title="Manage share settings">
                            Manage
                        </button>
                        <button class="btn-icon btn-sm btn-danger" @onclick="() => RevokeShare(item)"
                                title="Revoke share">
                            ✕
                        </button>
                    </div>
                </li>
            }
        </ul>
    }
</div>
