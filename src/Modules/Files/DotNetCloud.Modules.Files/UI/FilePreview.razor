@namespace DotNetCloud.Modules.Files.UI

@*
    File preview component - Shows preview for images, text, PDF, and other file types.
    Code-behind: FilePreview.razor.cs
*@

<div class="file-preview-overlay" @onclick="OnClose">
    <div class="file-preview-dialog" @onclick:stopPropagation>
        <div class="preview-header">
            <h3>@Node?.Name</h3>
            <div class="preview-actions">
                <button class="btn btn-sm" @onclick="Download" title="Download">Download</button>
                <button class="btn-icon" @onclick="OnClose" title="Close">X</button>
            </div>
        </div>

        <div class="preview-body">
            @if (IsImage)
            {
                <div class="preview-image">
                    <p class="text-muted">Image preview would render here</p>
                    <p>@Node?.Name</p>
                </div>
            }
            else if (IsText)
            {
                <div class="preview-text">
                    <pre>Text file content would be loaded and displayed here.</pre>
                </div>
            }
            else if (IsPdf)
            {
                <div class="preview-pdf">
                    <p>PDF viewer would be embedded here</p>
                    <p class="text-muted">@Node?.Name</p>
                </div>
            }
            else if (IsDocument)
            {
                <div class="preview-document">
                    <p>Open in Collabora for editing</p>
                    <button class="btn btn-primary" @onclick="OpenInCollabora">
                        Open in Editor
                    </button>
                </div>
            }
            else
            {
                <div class="preview-unsupported">
                    <p>@GetFileIcon(Node?.MimeType) Preview not available</p>
                    <p class="text-muted">
                        @Node?.Name - @FormatSize(Node?.Size ?? 0)
                    </p>
                    <button class="btn btn-primary" @onclick="Download">Download</button>
                </div>
            }
        </div>

        <div class="preview-footer">
            <span class="file-info-detail">
                Type: @(Node?.MimeType ?? "Unknown") - Size: @FormatSize(Node?.Size ?? 0)
            </span>
        </div>
    </div>
</div>
