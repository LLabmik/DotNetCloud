@namespace DotNetCloud.Modules.Files.UI

@*
    Document editor component — embeds Collabora Online editor in an iframe via WOPI.
    Shows loading state while token is being generated, error state if Collabora is unavailable,
    and co-editing indicators when multiple users are editing.
    Code-behind: DocumentEditor.razor.cs
*@

<div class="document-editor-container">
    @if (IsLoading)
    {
        <div class="editor-loading">
            <div class="spinner"></div>
            <p>Opening document editor...</p>
        </div>
    }
    else if (!string.IsNullOrEmpty(ErrorMessage))
    {
        <div class="editor-error">
            <p class="error-icon">[!]</p>
            <p class="error-message">@ErrorMessage</p>
            <div class="error-actions">
                <button class="btn btn-primary" @onclick="RetryAsync">Retry</button>
                <button class="btn" @onclick="DownloadInstead">Download to edit locally</button>
                @if (OnClose.HasDelegate)
                {
                    <button class="btn" @onclick="CloseEditorAsync">Close</button>
                }
            </div>
        </div>
    }
    else if (!string.IsNullOrEmpty(EditorUrl))
    {
        <div class="editor-header">
            <span class="editor-filename">@FileName</span>
            @if (CoEditingUsers.Count > 0)
            {
                <span class="co-editing-indicator" title="@string.Join(", ", CoEditingUsers) also editing">
                    @CoEditingUsers.Count other(s) editing
                </span>
            }
            <div class="editor-actions">
                @if (OnClose.HasDelegate)
                {
                    <button class="btn btn-sm" @onclick="CloseEditorAsync" title="Close editor">Close</button>
                }
            </div>
        </div>
        <iframe class="collabora-frame"
                src="@EditorUrl"
                sandbox="allow-scripts allow-same-origin allow-forms allow-popups allow-popups-to-escape-sandbox"
                allow="clipboard-read; clipboard-write"
                title="Document Editor - @FileName">
        </iframe>
    }
    else
    {
        <div class="editor-unavailable">
            <p>Online editing is not available.</p>
            <button class="btn btn-primary" @onclick="DownloadInstead">Download to edit locally</button>
        </div>
    }
</div>

<style>
    .document-editor-overlay {
        position: fixed;
        inset: 0;
        z-index: 1400;
        background: rgba(15, 23, 42, 0.62);
        padding: 1rem;
        display: flex;
        align-items: stretch;
        justify-content: center;
    }

    .document-editor-container {
        width: min(1400px, 100%);
        height: calc(100vh - 2rem);
        background: #fff;
        border-radius: 12px;
        box-shadow: 0 22px 60px rgba(2, 6, 23, 0.35);
        display: flex;
        flex-direction: column;
        overflow: hidden;
    }

    .editor-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        padding: 0.75rem 1rem;
        border-bottom: 1px solid #dbe2ea;
        background: #f8fafc;
    }

    .editor-filename {
        font-weight: 600;
        color: #0f172a;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .co-editing-indicator {
        font-size: 0.875rem;
        color: #334155;
    }

    .editor-loading,
    .editor-error,
    .editor-unavailable {
        flex: 1;
        display: grid;
        place-items: center;
        text-align: center;
        padding: 2rem;
    }

    .error-actions {
        display: flex;
        gap: 0.5rem;
        justify-content: center;
        margin-top: 1rem;
        flex-wrap: wrap;
    }

    .collabora-frame {
        width: 100%;
        height: 100%;
        border: 0;
        background: #fff;
    }

    @@media (max-width: 800px) {
        .document-editor-overlay {
            padding: 0;
        }

        .document-editor-container {
            height: 100vh;
            border-radius: 0;
        }
    }
</style>
