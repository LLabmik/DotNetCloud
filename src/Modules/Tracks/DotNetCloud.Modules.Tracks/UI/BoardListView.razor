@namespace DotNetCloud.Modules.Tracks.UI

<div class="tracks-board-list">
    <div class="tracks-board-list-header">
        <h2>My Boards</h2>
        <div class="tracks-board-list-actions">
            <div class="tracks-filter-group">
                <input type="text" class="tracks-search-input" placeholder="Search boards..."
                       @bind="_searchQuery" @bind:event="oninput" />
                @if (Teams.Count > 0)
                {
                    <select class="tracks-filter-select" @bind="_teamFilter">
                        <option value="">All</option>
                        <option value="personal">Personal</option>
                        @foreach (var team in Teams)
                        {
                            <option value="@team.Id">@team.Name</option>
                        }
                    </select>
                }
            </div>
            <button class="btn btn-primary" @onclick="OpenCreateDialog">
                + New Board
            </button>
        </div>
    </div>

    @if (FilteredBoards.Count == 0)
    {
        <div class="tracks-empty-state">
            <div class="tracks-empty-icon">📋</div>
            <h3>No boards yet</h3>
            <p>Create your first board to start tracking work.</p>
            <button class="btn btn-primary" @onclick="OpenCreateDialog">Create Board</button>
        </div>
    }
    else
    {
        <div class="tracks-board-grid">
            @foreach (var board in FilteredBoards)
            {
                <div class="tracks-board-card @(board.IsArchived ? "tracks-board-card--archived" : "")"
                     @onclick="() => OnBoardSelected.InvokeAsync(board.Id)">
                    <div class="tracks-board-card-color"
                         style="background: @(board.Color ?? "#3b82f6");"></div>
                    <div class="tracks-board-card-body">
                        <div class="tracks-board-card-header">
                            <h3>@board.Title</h3>
                            @if (board.IsArchived)
                            {
                                <span class="tracks-badge tracks-badge--muted">Archived</span>
                            }
                        </div>
                        <span class="tracks-board-mode-badge @(board.Mode == BoardMode.Team ? "team" : "personal")">
                            @(board.Mode == BoardMode.Team ? "👥 Team" : "📋 Personal")
                        </span>
                        @if (board.TeamId.HasValue)
                        {
                            var team = Teams.FirstOrDefault(t => t.Id == board.TeamId.Value);
                            @if (team is not null)
                            {
                                        <span class="tracks-team-badge">👥 @team.Name</span>
                            }
                        }
                        @if (!string.IsNullOrEmpty(board.Description))
                        {
                            <p class="tracks-board-card-desc">@TruncateText(board.Description, 120)</p>
                        }
                        <div class="tracks-board-card-footer">
                            <span class="tracks-board-meta">
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                                @board.Members.Count
                            </span>
                            <span class="tracks-board-meta">
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>
                                @board.Swimlanes.Count swimlane@(board.Swimlanes.Count != 1 ? "s" : "")
                            </span>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@* ── Create Board Dialog ── *@
@if (_showCreateDialog)
{
    <DncModal Title="Create Board" StartVisible OnClose="CloseCreateDialog">
        <EditForm Model="_createModel" OnValidSubmit="CreateBoardAsync">
            <div class="form-group">
                <label>Board Type</label>
                <div class="tracks-mode-selector">
                    <button type="button"
                            class="tracks-mode-btn @(_createMode == BoardMode.Personal ? "active" : "")"
                            @onclick="() => SetCreateMode(BoardMode.Personal)">
                        <span class="tracks-mode-icon">📋</span>
                        <span class="tracks-mode-label">Personal</span>
                        <span class="tracks-mode-desc">Simple kanban boards</span>
                    </button>
                    <button type="button"
                            class="tracks-mode-btn @(_createMode == BoardMode.Team ? "active" : "")"
                            @onclick="() => SetCreateMode(BoardMode.Team)">
                        <span class="tracks-mode-icon">👥</span>
                        <span class="tracks-mode-label">Team</span>
                        <span class="tracks-mode-desc">Sprints, planning &amp; reviews</span>
                    </button>
                </div>
            </div>
            <div class="form-group">
                <label>Title</label>
                <InputText class="form-control" @bind-Value="_createModel.Title" placeholder="Board title" />
            </div>
            <div class="form-group">
                <label>Description (optional)</label>
                <InputTextArea class="form-control" @bind-Value="_createModel.Description" rows="3"
                               placeholder="What is this board for?" />
            </div>
            <div class="form-group">
                <label>Color</label>
                <div class="tracks-color-picker">
                    @foreach (var color in _boardColors)
                    {
                        <button type="button"
                                class="tracks-color-swatch @(_createModel.Color == color ? "selected" : "")"
                                style="background: @color;"
                                @onclick="() => _createModel.Color = color">
                        </button>
                    }
                </div>
            </div>
            @if (_createMode == BoardMode.Team && Teams.Count > 0)
            {
                <div class="form-group">
                    <label>Team</label>
                    <select class="form-control" @bind="_createTeamId">
                        <option value="">Select a team…</option>
                        @foreach (var team in Teams)
                        {
                            <option value="@team.Id">@team.Name</option>
                        }
                    </select>
                </div>
            }
            <div class="form-actions">
                <button type="button" class="btn btn-secondary" @onclick="CloseCreateDialog">Cancel</button>
                <button type="submit" class="btn btn-primary" disabled="@_isCreating">
                    @(_isCreating ? "Creating..." : "Create Board")
                </button>
            </div>
        </EditForm>
    </DncModal>
}
