@namespace DotNetCloud.Modules.Tracks.UI

<div class="tracks-board-list">
    <div class="tracks-board-list-header">
        <h2>Products</h2>
        <div class="tracks-board-list-actions">
            <div class="tracks-filter-group">
                <input type="text" class="tracks-search-input" placeholder="Search products..."
                       @bind="_searchQuery" @bind:event="oninput" />
            </div>
            <button class="btn btn-primary" @onclick="OpenCreateWizard">
                + New Product
            </button>
        </div>
    </div>

    @if (FilteredProducts.Count == 0)
    {
        <div class="tracks-empty-state">
            <div class="tracks-empty-icon">📋</div>
            <h3>No products yet</h3>
            <p>Create your first product to start tracking work.</p>
            <button class="btn btn-primary" @onclick="OpenCreateWizard">Create Product</button>
        </div>
    }
    else
    {
        <div class="tracks-board-grid">
            @foreach (var product in FilteredProducts)
            {
                <div class="tracks-board-card @(product.IsArchived ? "tracks-board-card--archived" : "")"
                     @onclick="() => OnProductSelected.InvokeAsync(product.Id)">
                    <div class="tracks-board-card-color"
                         style="background: @(product.Color ?? "#3b82f6");"></div>
                    <div class="tracks-board-card-body">
                        <div class="tracks-board-card-header">
                            <h3>@product.Name</h3>
                            <div class="tracks-board-card-header-actions" @onclick:stopPropagation>
                                @if (product.IsArchived)
                                {
                                    <span class="tracks-badge tracks-badge--muted">Archived</span>
                                }
                                <button class="tracks-board-card-delete-btn"
                                        @onclick="() => ConfirmDelete(product)"
                                        title="Delete product">
                                    🗑
                                </button>
                            </div>
                        </div>
                        @if (!string.IsNullOrEmpty(product.Description))
                        {
                            <p class="tracks-board-card-desc">@TruncateText(product.Description, 120)</p>
                        }
                        <div class="tracks-board-card-footer">
                            <span class="tracks-board-meta">
                                <span>@product.MemberCount members</span>
                            </span>
                            <span class="tracks-board-meta">
                                <span>@product.SwimlaneCount swimlane@(product.SwimlaneCount != 1 ? "s" : "")</span>
                            </span>
                            <span class="tracks-board-meta">
                                <span>@product.EpicCount epic@(product.EpicCount != 1 ? "s" : "")</span>
                            </span>
                        </div>
                    </div>
                </div>
            }
        </div>
    }

    @* ── Deleted Products ── *@
    @if (_deletedProducts.Count > 0)
    {
        <div class="tracks-deleted-section">
            <button class="tracks-deleted-toggle" @onclick="() => _showDeleted = !_showDeleted">
                <span class="tracks-deleted-toggle-icon">@(_showDeleted ? "▼" : "▶")</span>
                <span>🗑 Trash (@_deletedProducts.Count)</span>
                <span class="tracks-deleted-toggle-hint">Restorable within 30 days</span>
            </button>

            @if (_showDeleted)
            {
                <div class="tracks-deleted-grid">
                    @foreach (var product in _deletedProducts)
                    {
                        <div class="tracks-board-card tracks-board-card--deleted">
                            <div class="tracks-board-card-color"
                                 style="background: @(product.Color ?? "#6b7280"); opacity: 0.5;"></div>
                            <div class="tracks-board-card-body">
                                <div class="tracks-board-card-header">
                                    <h3>@product.Name</h3>
                                    <div class="tracks-board-card-header-actions">
                                        @if (product.DeletedAt.HasValue)
                                        {
                                            var daysLeft = 30 - (int)(DateTime.UtcNow - product.DeletedAt.Value).TotalDays;
                                            <span class="tracks-badge @(daysLeft <= 7 ? "tracks-badge--warning" : "tracks-badge--muted")">
                                                @daysLeft day@(daysLeft != 1 ? "s" : "") left
                                            </span>
                                        }
                                        <button class="tracks-deleted-restore-btn"
                                                @onclick="() => RestoreProductAsync(product)"
                                                disabled="@(_isRestoring == product.Id)"
                                                title="Restore product">
                                            @(_isRestoring == product.Id ? "Restoring..." : "↩ Restore")
                                        </button>
                                        <button class="tracks-deleted-permanent-btn"
                                                @onclick="() => PermanentDeleteProductAsync(product)"
                                                disabled="@(_isPermanentlyDeleting == product.Id)"
                                                title="Permanently delete — cannot be undone">
                                            @(_isPermanentlyDeleting == product.Id ? "Deleting..." : "🗑")
                                        </button>
                                    </div>
                                </div>
                                @if (!string.IsNullOrEmpty(product.Description))
                                {
                                    <p class="tracks-board-card-desc">@TruncateText(product.Description, 80)</p>
                                }
                                @if (product.DeletedAt.HasValue)
                                {
                                    <div class="tracks-deleted-date">
                                        Deleted @product.DeletedAt.Value.ToString("MMM d, yyyy")
                                    </div>
                                }
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    }
</div>

@* ── Create Product Wizard ── *@
@if (_showCreateWizard && OrganizationId.HasValue)
{
    <ProductCreationWizard OrganizationId="OrganizationId.Value"
                           OnClose="CloseCreateWizard"
                           OnCreated="HandleProductCreatedFromWizard" />
}

@* ── Delete Confirmation Dialog ── *@
@if (_deleteTarget is not null)
{
    <div class="tracks-wizard-overlay" @onclick="CancelDelete">
        <div class="tracks-confirm-dialog" @onclick:stopPropagation>
            <div class="tracks-confirm-icon">⚠️</div>
            <h3>@($"Delete \"{_deleteTarget.Name}\"?")</h3>
            <p>This will mark the product for deletion. It can be restored within 30 days by an admin. <strong>After 30 days it will be permanently removed.</strong></p>
            <div class="tracks-confirm-actions">
                <button class="btn btn-danger" @onclick="DeleteProductAsync" disabled="@_isDeleting">
                    @(_isDeleting ? "Deleting..." : "Delete Product")
                </button>
                <button class="btn btn-secondary" @onclick="CancelDelete">Cancel</button>
            </div>
            @if (_deleteError is not null)
            {
                <DncErrorDisplay Message="@_deleteError" />
            }
        </div>
    </div>
}
