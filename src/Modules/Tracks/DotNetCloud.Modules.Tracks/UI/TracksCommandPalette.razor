@namespace DotNetCloud.Modules.Tracks.UI
@inherits TracksCommandPaletteBase
@implements IDisposable

@* Ctrl+K command palette — fast keyboard-driven navigation and actions *@

@if (_isVisible)
{
    <div class="command-palette-overlay" @onclick="Close" @onkeydown="HandleOverlayKeyDown" @onclick:preventDefault="false">
        <div class="command-palette-dialog" @onclick:stopPropagation="true" @onclick:preventDefault="true">
            <div class="command-palette-search">
                <svg class="cp-search-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="11" cy="11" r="8" /><path d="m21 21-4.35-4.35" />
                </svg>
                <input @ref="_searchInput"
                       type="text"
                       class="cp-search-input"
                       placeholder="Search work items, products, actions..."
                       @bind-value="_query"
                       @bind-value:event="oninput"
                       @onkeydown="HandleKeyDown"
                       autocomplete="off"
                       spellcheck="false" />
                <span class="cp-shortcut-hint">ESC to close</span>
            </div>

            <div class="command-palette-results">
                @if (_isLoading)
                {
                    <div class="cp-loading">Searching...</div>
                }
                else if (!_results.Any())
                {
                    <div class="cp-empty">No results found for "@_query"</div>
                }
                else
                {
                    @foreach (var (group, items) in _results)
                    {
                        if (items.Count == 0) continue;

                        <div class="cp-group">
                            <div class="cp-group-header">@group</div>
                            @for (int i = 0; i < items.Count; i++)
                            {
                                var item = items[i];
                                var isSelected = _groupsFlat is not null && _selectedIndex >= 0 &&
                                    _selectedIndex < _groupsFlat.Count && _groupsFlat[_selectedIndex] == item;

                                <div class="cp-item @(isSelected ? "cp-item-selected" : "")"
                                     @onclick="() => ExecuteItem(item)"
                                     @onmouseenter="() => _selectedIndex = FindFlatIndex(item)"
                                     role="option"
                                     aria-selected="@isSelected">
                                    <div class="cp-item-main">
                                        <span class="cp-item-icon">
                                            @GetIcon(item)
                                        </span>
                                        <span class="cp-item-title">@item.Title</span>
                                    </div>
                                    <span class="cp-item-subtitle">@item.Subtitle</span>
                                </div>
                            }
                        </div>
                    }
                }
            </div>

            <div class="command-palette-footer">
                <span><kbd>↑↓</kbd> Navigate</span>
                <span><kbd>Enter</kbd> Select</span>
                <span><kbd>Esc</kbd> Close</span>
            </div>
        </div>
    </div>
}

<style>
    .command-palette-overlay {
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, 0.45);
        display: flex;
        align-items: flex-start;
        justify-content: center;
        padding-top: 12vh;
        z-index: 10000;
        animation: cp-fade-in 0.12s ease-out;
    }

    @@keyframes cp-fade-in {
        from { opacity: 0; }
        to { opacity: 1; }
    }

    .command-palette-dialog {
        width: 560px;
        max-width: 95vw;
        max-height: 70vh;
        background: var(--surface-bg, #ffffff);
        border: 1px solid var(--border-color, #e0e0e0);
        border-radius: 12px;
        box-shadow: 0 16px 48px rgba(0, 0, 0, 0.18);
        display: flex;
        flex-direction: column;
        overflow: hidden;
        animation: cp-slide-in 0.15s ease-out;
    }

    @@keyframes cp-slide-in {
        from { transform: translateY(-12px); opacity: 0; }
        to { transform: translateY(0); opacity: 1; }
    }

    .command-palette-search {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 12px 16px;
        border-bottom: 1px solid var(--border-color, #e0e0e0);
    }

    .cp-search-icon {
        width: 18px;
        height: 18px;
        color: var(--text-secondary, #888);
        flex-shrink: 0;
    }

    .cp-search-input {
        flex: 1;
        border: none;
        outline: none;
        font-size: 15px;
        font-family: inherit;
        background: transparent;
        color: var(--text-primary, #1a1a1a);
    }

    .cp-search-input::placeholder {
        color: var(--text-tertiary, #aaa);
    }

    .cp-shortcut-hint {
        font-size: 11px;
        color: var(--text-tertiary, #aaa);
        flex-shrink: 0;
        background: var(--surface-secondary, #f0f0f0);
        padding: 2px 8px;
        border-radius: 4px;
        font-family: monospace;
    }

    .command-palette-results {
        flex: 1;
        overflow-y: auto;
        padding: 8px;
    }

    .cp-loading,
    .cp-empty {
        padding: 24px;
        text-align: center;
        color: var(--text-secondary, #888);
        font-size: 14px;
    }

    .cp-group {
        margin-bottom: 4px;
    }

    .cp-group-header {
        font-size: 11px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        color: var(--text-tertiary, #aaa);
        padding: 8px 12px 4px;
    }

    .cp-item {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 8px 12px;
        border-radius: 8px;
        cursor: pointer;
        transition: background-color 0.1s;
    }

    .cp-item:hover,
    .cp-item-selected {
        background: var(--surface-hover, #f0f3ff);
    }

    .cp-item-main {
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .cp-item-icon {
        width: 20px;
        height: 20px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 14px;
        flex-shrink: 0;
    }

    .cp-item-title {
        font-size: 14px;
        color: var(--text-primary, #1a1a1a);
    }

    .cp-item-subtitle {
        font-size: 12px;
        color: var(--text-tertiary, #aaa);
        flex-shrink: 0;
        margin-left: 12px;
    }

    .command-palette-footer {
        display: flex;
        gap: 16px;
        padding: 8px 16px;
        border-top: 1px solid var(--border-color, #e0e0e0);
        font-size: 11px;
        color: var(--text-tertiary, #aaa);
    }

    .command-palette-footer kbd {
        background: var(--surface-secondary, #f0f0f0);
        padding: 1px 5px;
        border-radius: 3px;
        font-family: monospace;
        font-size: 10px;
        border: 1px solid var(--border-color, #e0e0e0);
    }

    /* Dark mode overrides */
    :global(.dark) .command-palette-dialog,
    :global([data-theme="dark"]) .command-palette-dialog {
        --surface-bg: #1e1e2e;
        --border-color: #3a3a4a;
        --text-primary: #e0e0e0;
        --text-secondary: #999;
        --text-tertiary: #777;
        --surface-hover: #2a2a3a;
        --surface-secondary: #2a2a3a;
    }
</style>
