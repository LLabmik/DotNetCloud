@namespace DotNetCloud.Modules.Tracks.UI

<div class="tracks-teams">
    <div class="tracks-teams-header">
        <h2>Teams</h2>
        <div class="tracks-teams-actions">
            <button class="btn btn-primary" @onclick="() => _showCreateDialog = true">+ New Team</button>
        </div>
    </div>

    @if (_teams.Count == 0)
    {
        <div class="tracks-empty-state">
            <span class="tracks-empty-icon">👥</span>
            <h3>No teams yet</h3>
            <p>Create a team to collaborate on boards together.</p>
            <button class="btn btn-primary" @onclick="() => _showCreateDialog = true">Create Team</button>
        </div>
    }
    else
    {
        <div class="tracks-team-grid">
            @foreach (var team in _teams)
            {
                <div class="tracks-team-card @(_selectedTeamId == team.Id ? "selected" : "")">
                    <div class="tracks-team-card-header">
                        <h3>@team.Name</h3>
                        <div class="tracks-team-card-meta">
                            <span class="tracks-team-stat" title="Members">👥 @team.MemberCount</span>
                        </div>
                    </div>
                    @if (!string.IsNullOrEmpty(team.Description))
                    {
                        <p class="tracks-team-description">@team.Description</p>
                    }

                    @if (team.MemberCount > 0)
                    {
                        <div class="tracks-team-members-preview">
                            <span class="tracks-team-stat">👥 @team.MemberCount member(s)</span>
                        </div>
                    }

                    <div class="tracks-team-card-actions">
                        <button class="btn btn-sm btn-outline" @onclick="() => OnTeamSelected.InvokeAsync(team.Id)">
                            View Boards
                        </button>
                        <button class="btn btn-sm btn-outline" @onclick="() => ExpandTeamAsync(team.Id)">
                            @(_selectedTeamId == team.Id ? "Close" : "Manage")
                        </button>
                    </div>

                    @if (_selectedTeamId == team.Id)
                    {
                        <div class="tracks-team-expanded">
                            @* ── Edit Team Details ── *@
                            <div class="tracks-team-section">
                                <h4>Team Details</h4>
                                <div class="tracks-form-group">
                                    <label>Name</label>
                                    <input type="text" class="tracks-input" @bind="_editName" />
                                </div>
                                <div class="tracks-form-group">
                                    <label>Description</label>
                                    <textarea class="tracks-textarea" rows="2" @bind="_editDescription"></textarea>
                                </div>
                                <div class="tracks-form-actions">
                                    <button class="btn btn-sm btn-primary" @onclick="() => UpdateTeamAsync(team.Id)">Save</button>
                                </div>
                            </div>

                            @* ── Members ── *@
                            <div class="tracks-team-section">
                                <h4>Members (@team.MemberCount)</h4>
                                <p class="tracks-muted">Use the search below to add or manage team members.</p>

                                <div class="tracks-add-member-row" style="position: relative;">
                                    <div style="flex: 1; position: relative;">
                                        <input type="text" class="tracks-input" placeholder="Search by name or email..."
                                               @bind="_addMemberSearch" @bind:event="oninput" @bind:after="SearchUsersAsync" />
                                        @if (_searchResults.Count > 0)
                                        {
                                            <div class="tracks-search-dropdown">
                                                @foreach (var user in _searchResults)
                                                {
                                                    <div class="tracks-search-item" @onclick="() => SelectUserForAdd(user)">
                                                        <span class="tracks-avatar-sm">@GetInitials(user.DisplayName)</span>
                                                        <div class="tracks-member-info">
                                                            <span class="tracks-member-name">@user.DisplayName</span>
                                                            <span class="tracks-member-date">@user.Email</span>
                                                        </div>
                                                    </div>
                                                }
                                            </div>
                                        }
                                    </div>
                                    <select class="tracks-filter-select" @bind="_addMemberRole">
                                        <option value="Member">Member</option>
                                        <option value="Manager">Manager</option>
                                        <option value="Owner">Owner</option>
                                    </select>
                                    <button class="btn btn-sm btn-primary" @onclick="() => AddMemberAsync(team.Id)"
                                            disabled="@(_selectedUserId == Guid.Empty)">Add</button>
                                </div>

                                @if (_teamMembers.Count > 0)
                                {
                                    <div class="tracks-member-list">
                                        @foreach (var member in _teamMembers)
                                        {
                                            <div class="tracks-member-row">
                                                <span class="tracks-avatar-sm">@GetInitials(member.DisplayName)</span>
                                                <div class="tracks-member-info">
                                                    <span class="tracks-member-name">@member.DisplayName</span>
                                                    <span class="tracks-member-date">@member.Role &middot; Joined @member.AssignedAt.ToString("MMM d, yyyy")</span>
                                                </div>
                                                <select class="tracks-filter-select" value="@member.Role.ToString()"
                                                        @onchange="e => UpdateMemberRoleAsync(team.Id, member.UserId, e)">
                                                    <option value="Member">Member</option>
                                                    <option value="Manager">Manager</option>
                                                    <option value="Owner">Owner</option>
                                                </select>
                                                <button class="btn btn-sm btn-outline tracks-remove-btn"
                                                        @onclick="() => RemoveMemberAsync(team.Id, member.UserId)"
                                                        title="Remove member">✕</button>
                                            </div>
                                        }
                                    </div>
                                }
                                else
                                {
                                    <p class="tracks-muted">No members to display.</p>
                                }
                            </div>

                            @* ── Danger Zone ── *@
                            <div class="tracks-team-section tracks-danger-zone">
                                <h4>Danger Zone</h4>
                                <button class="btn btn-sm btn-danger" @onclick="() => DeleteTeamAsync(team.Id)">Delete Team</button>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    }

    @* ── Create Team Dialog ── *@
    @if (_showCreateDialog)
    {
        <div class="tracks-dialog-overlay" @onclick="() => _showCreateDialog = false">
            <div class="tracks-dialog" @onclick:stopPropagation>
                <div class="tracks-dialog-header">
                    <h3>Create Team</h3>
                    <button class="tracks-icon-btn" @onclick="() => _showCreateDialog = false">✕</button>
                </div>
                <div class="tracks-dialog-body">
                    <div class="tracks-form-group">
                        <label>Team Name *</label>
                        <input type="text" class="tracks-input" @bind="_newTeamName" placeholder="e.g. Engineering" />
                    </div>
                    <div class="tracks-form-group">
                        <label>Description</label>
                        <textarea class="tracks-textarea" rows="3" @bind="_newTeamDescription"
                                  placeholder="What does this team do?"></textarea>
                    </div>
                </div>
                <div class="tracks-dialog-footer">
                    <button class="btn btn-primary" @onclick="CreateTeamAsync"
                            disabled="@string.IsNullOrWhiteSpace(_newTeamName)">Create</button>
                    <button class="btn btn-outline" @onclick="() => _showCreateDialog = false">Cancel</button>
                </div>
            </div>
        </div>
    }

    @if (!string.IsNullOrEmpty(_errorMessage))
    {
        <div class="tracks-toast tracks-toast-error">
            <span>@_errorMessage</span>
            <button class="tracks-icon-btn" @onclick="() => _errorMessage = null">✕</button>
        </div>
    }
</div>
