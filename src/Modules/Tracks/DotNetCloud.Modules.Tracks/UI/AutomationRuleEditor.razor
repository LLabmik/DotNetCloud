@namespace DotNetCloud.Modules.Tracks.UI

<div class="automation-rules-editor">
    <div class="automation-header">
        <h4>Automation Rules</h4>
        <button class="btn btn-primary btn-sm" @onclick="StartCreating">+ New Rule</button>
    </div>

    @if (_rules is null)
    {
        <p class="automation-loading">Loading rules...</p>
    }
    else if (_rules.Count == 0 && !_isEditing)
    {
        <div class="automation-empty">
            <p>No automation rules yet. Automate your workflow: "When X happens, do Y."</p>
            <div class="automation-presets">
                <h5>Quick Presets</h5>
                <button class="btn btn-outline btn-sm" @onclick='() => CreatePreset("done_label")'>
                    ✓ When moved to Done, add "Done" label
                </button>
                <button class="btn btn-outline btn-sm" @onclick='() => CreatePreset("urgent_notify")'>
                    🔔 When urgent item created, notify product members
                </button>
                <button class="btn btn-outline btn-sm" @onclick='() => CreatePreset("due_reminder")'>
                    ⏰ When due date is tomorrow, notify assignee
                </button>
            </div>
        </div>
    }
    else
    {
        <div class="automation-list">
            @foreach (var rule in _rules)
            {
                <div class="automation-rule-card @(rule.IsActive ? "" : "inactive")">
                    <div class="automation-rule-header">
                        <span class="automation-rule-name">@rule.Name</span>
                        <div class="automation-rule-actions">
                            <label class="automation-toggle">
                                <input type="checkbox" checked="@rule.IsActive"
                                       @onchange="(ChangeEventArgs e) => ToggleRule(rule, (bool)e.Value!)" />
                                <span class="automation-toggle-slider"></span>
                            </label>
                            <button class="btn btn-sm" @onclick="() => EditRule(rule)">Edit</button>
                            <button class="btn btn-sm btn-danger" @onclick="() => DeleteRule(rule)">Delete</button>
                        </div>
                    </div>
                    <div class="automation-rule-summary">
                        <span class="automation-trigger-badge">@FormatTrigger(rule.Trigger)</span>
                        <span>→</span>
                        <span>@FormatActions(rule.ActionsJson)</span>
                    </div>
                    @if (rule.LastTriggeredAt.HasValue)
                    {
                        <div class="automation-rule-last-run">
                            Last triggered: @rule.LastTriggeredAt.Value.ToString("MMM d, yyyy HH:mm")
                        </div>
                    }
                </div>
            }
        </div>
    }

    @* Edit Modal *@
    @if (_isEditing)
    {
        <div class="automation-modal-overlay" @onclick="CancelEdit">
            <div class="automation-modal" @onclick:stopPropagation>
                <h4>@(_editingId.HasValue ? "Edit Rule" : "New Rule")</h4>

                <div class="automation-form-field">
                    <label>Rule Name</label>
                    <input type="text" class="form-control" @bind="_editName" placeholder="e.g., Auto-label done items" />
                </div>

                <div class="automation-form-field">
                    <label>When</label>
                    <select class="form-control" @bind="_editTrigger">
                        <option value="work_item_created">Work item created</option>
                        <option value="work_item_moved">Work item moved</option>
                        <option value="status_changed">Status changed</option>
                        <option value="due_date_approaching">Due date approaching (24h)</option>
                        <option value="assigned">Work item assigned</option>
                    </select>
                </div>

                <div class="automation-form-field">
                    <label>Then</label>
                    <div class="automation-actions-list">
                        @for (int i = 0; i < _editActions.Count; i++)
                        {
                            var action = _editActions[i];
                            <div class="automation-action-row">
                                <select class="form-control form-control-sm" @bind="action.Type"
                                        @bind:after="() => OnActionTypeChanged(action)">
                                    <option value="">— Select Action —</option>
                                    <option value="add_label">Add label</option>
                                    <option value="remove_label">Remove label</option>
                                    <option value="move_to_swimlane">Move to swimlane</option>
                                    <option value="assign">Assign to user</option>
                                    <option value="set_priority">Set priority</option>
                                    <option value="set_field">Set custom field</option>
                                    <option value="add_comment">Add comment</option>
                                </select>
                                @if (action.Type == "add_label")
                                {
                                    <select class="form-control form-control-sm" @bind="action.LabelId">
                                        <option value="">— Select Label —</option>
                                        @if (ProductLabels is not null)
                                        {
                                            @foreach (var label in ProductLabels)
                                            {
                                                <option value="@label.Id">@label.Title</option>
                                            }
                                        }
                                    </select>
                                }
                                else if (action.Type == "move_to_swimlane")
                                {
                                    <select class="form-control form-control-sm" @bind="action.SwimlaneId">
                                        <option value="">— Select Swimlane —</option>
                                        @if (ProductSwimlanes is not null)
                                        {
                                            @foreach (var lane in ProductSwimlanes)
                                            {
                                                <option value="@lane.Id">@lane.Title</option>
                                            }
                                        }
                                    </select>
                                }
                                else if (action.Type == "set_priority")
                                {
                                    <select class="form-control form-control-sm" @bind="action.PriorityValue">
                                        <option value="None">None</option>
                                        <option value="Low">Low</option>
                                        <option value="Medium">Medium</option>
                                        <option value="High">High</option>
                                        <option value="Urgent">Urgent</option>
                                    </select>
                                }
                                else if (action.Type == "assign")
                                {
                                    <input type="text" class="form-control form-control-sm" placeholder="User ID"
                                           @bind="action.UserIdStr" />
                                }
                                else if (action.Type == "set_field" || action.Type == "add_comment")
                                {
                                    <input type="text" class="form-control form-control-sm"
                                           placeholder="@(action.Type == "set_field" ? "Field ID" : "Comment text")"
                                           @bind="action.FieldOrCommentValue" />
                                }
                                <button class="btn btn-sm btn-danger" @onclick="() => RemoveAction(i)">✕</button>
                            </div>
                        }
                    </div>
                    <button class="btn btn-sm btn-outline" @onclick="AddAction">+ Add Action</button>
                </div>

                @if (!string.IsNullOrEmpty(_editError))
                {
                    <div class="automation-error">@_editError</div>
                }

                <div class="automation-preview">
                    <strong>Preview:</strong>
                    <span>When <em>@FormatTrigger(_editTrigger)</em>, then @FormatActionsPreview()</span>
                </div>

                <div class="automation-modal-actions">
                    <button class="btn btn-primary" @onclick="SaveRule" disabled="@(_isSaving)">
                        @(_isSaving ? "Saving..." : "Save Rule")
                    </button>
                    <button class="btn btn-secondary" @onclick="CancelEdit">Cancel</button>
                </div>
            </div>
        </div>
    }
</div>
