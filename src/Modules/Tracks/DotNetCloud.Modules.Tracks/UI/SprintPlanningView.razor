@namespace DotNetCloud.Modules.Tracks.UI

<div class="tracks-sprint-planning">
    <div class="tracks-sprint-planning-header">
        <h2>Sprint Planning: @Sprint.Title</h2>
        <div class="tracks-sprint-planning-summary">
            <span class="badge @GetStatusBadgeClass(Sprint.Status)">@Sprint.Status.ToString()</span>
            @if (Sprint.StartDate.HasValue && Sprint.EndDate.HasValue)
            {
                <span>📅 @Sprint.StartDate.Value.ToString("MMM d") – @Sprint.EndDate.Value.ToString("MMM d")</span>
            }
        </div>
        <button class="btn btn-sm btn-outline" @onclick="OnClose">← Back to Epic</button>
    </div>

    @* ── Capacity Bar ── *@
    <div class="tracks-sprint-capacity">
        @{
            var committedSp = _sprintItems.Where(i => i.StoryPoints.HasValue).Sum(i => i.StoryPoints!.Value);
            var targetSp = _targetStoryPoints ?? 0;
            var capacityPct = targetSp > 0 ? Math.Min(100, committedSp * 100 / targetSp) : 0;
            var isOvercommitted = targetSp > 0 && committedSp > targetSp;
        }
        <div class="tracks-capacity-header">
            <span>Capacity: @committedSp SP committed</span>
            @if (targetSp > 0)
            {
                <span class="@(isOvercommitted ? "overcommitted" : "")"> / @targetSp SP target (@capacityPct%)</span>
            }
            @if (!_isEditingTarget)
            {
                <button class="tracks-link-btn" @onclick="() => { _isEditingTarget = true; _editTargetSp = targetSp.ToString(); }">
                    @(targetSp > 0 ? "Edit" : "Set target")
                </button>
            }
            else
            {
                <input type="number" class="form-control form-control-sm tracks-target-input"
                       @bind="_editTargetSp" @onkeydown="HandleTargetKeyDown" min="0" />
                <button class="btn btn-sm btn-primary" @onclick="SaveTargetAsync">Save</button>
                <button class="btn btn-sm btn-secondary" @onclick="() => _isEditingTarget = false">Cancel</button>
            }
        </div>
        @if (targetSp > 0)
        {
            <div class="tracks-capacity-bar">
                <div class="tracks-capacity-fill @(isOvercommitted ? "over" : "")" style="width: @capacityPct%"></div>
            </div>
        }
    </div>

    @* ── Two-Panel Layout ── *@
    <div class="tracks-planning-panels">
        @* ── Left Panel: Product Backlog ── *@
        <div class="tracks-planning-panel backlog">
            <div class="tracks-planning-panel-header">
                <h3>Product Backlog</h3>
                <span class="tracks-muted">@_backlogItems.Count items</span>
            </div>
            <input type="text" class="form-control form-control-sm" placeholder="Search backlog..."
                   @bind="_backlogSearch" @bind:event="oninput" />

            <div class="tracks-planning-card-list">
                @if (_isLoading)
                {
                    <p class="tracks-muted">Loading...</p>
                }
                else
                {
                    var filteredBacklog = GetFilteredBacklog();
                    var priorityGroups = filteredBacklog.GroupBy(item => item.Priority)
                        .OrderByDescending(g => g.Key);

                    @foreach (var group in priorityGroups)
                    {
                        <div class="tracks-planning-priority-group">
                            <div class="tracks-planning-group-header">@GetPriorityLabel(group.Key)</div>
                            @foreach (var item in group)
                            {
                                <div class="tracks-planning-card"
                                     @onclick="() => AddToSprintAsync(item.Id)">
                                    <span class="tracks-card-number">#@item.ItemNumber</span>
                                    <span class="tracks-planning-card-title">@item.Title</span>
                                    @if (item.StoryPoints.HasValue)
                                    {
                                        <span class="tracks-sprint-card-sp">@item.StoryPoints SP</span>
                                    }
                                    else
                                    {
                                        <span class="tracks-sprint-card-sp no-estimate">?</span>
                                    }
                                    <button class="tracks-add-btn" title="Add to sprint">→</button>
                                </div>
                            }
                        </div>
                    }

                    @if (filteredBacklog.Count == 0)
                    {
                        <p class="tracks-muted">No backlog items found.</p>
                    }
                }
            </div>
        </div>

        @* ── Right Panel: Sprint Backlog ── *@
        <div class="tracks-planning-panel sprint">
            <div class="tracks-planning-panel-header">
                <h3>Sprint Backlog</h3>
                <span class="tracks-muted">@_sprintItems.Count items · @committedSp SP</span>
            </div>

            <div class="tracks-planning-card-list">
                @if (_isLoading)
                {
                    <p class="tracks-muted">Loading...</p>
                }
                else
                {
                    @* ── Committed Items ── *@
                    var estimated = _sprintItems.Where(i => i.StoryPoints.HasValue).ToList();
                    var unestimated = _sprintItems.Where(i => !i.StoryPoints.HasValue).ToList();

                    @if (estimated.Count > 0)
                    {
                        <div class="tracks-planning-group-header">Committed (@estimated.Count)</div>
                        @foreach (var item in estimated)
                        {
                            <div class="tracks-planning-card @(item.IsArchived ? "completed" : "")">
                                <span class="tracks-sprint-card-status">@(item.IsArchived ? "✓" : "☐")</span>
                                <span class="tracks-card-number">#@item.ItemNumber</span>
                                <span class="tracks-planning-card-title" @onclick="() => OnWorkItemSelected.InvokeAsync(item.Id)">
                                    @item.Title
                                </span>
                                <span class="tracks-sprint-card-sp">@item.StoryPoints SP</span>
                                <button class="tracks-remove-btn" title="Remove from sprint"
                                        @onclick="() => RemoveFromSprintAsync(item.Id)">←</button>
                            </div>
                        }
                    }

                    @* ── Needs Estimate ── *@
                    @if (unestimated.Count > 0)
                    {
                        <div class="tracks-planning-group-header needs-estimate">Needs Estimate (@unestimated.Count)</div>
                        @foreach (var item in unestimated)
                        {
                            <div class="tracks-planning-card needs-estimate">
                                <span class="tracks-sprint-card-status">☐</span>
                                <span class="tracks-card-number">#@item.ItemNumber</span>
                                <span class="tracks-planning-card-title" @onclick="() => OnWorkItemSelected.InvokeAsync(item.Id)">
                                    @item.Title
                                </span>
                                <span class="tracks-sprint-card-sp no-estimate">? SP</span>
                                <button class="tracks-remove-btn" title="Remove from sprint"
                                        @onclick="() => RemoveFromSprintAsync(item.Id)">←</button>
                            </div>
                        }
                    }

                    @if (_sprintItems.Count == 0)
                    {
                        <p class="tracks-muted">No items in this sprint. Add items from the backlog.</p>
                    }
                }
            </div>

            @* ── Member Workload ── *@
            @{
                var memberWorkload = _sprintItems
                    .Where(i => !i.IsArchived)
                    .SelectMany(i => i.Assignments.Select(a => new { a.UserId, DisplayName = a.DisplayName ?? "User", i.StoryPoints }))
                    .GroupBy(x => new { x.UserId, x.DisplayName })
                    .Select(g => new { g.Key.DisplayName, TotalSp = g.Sum(x => x.StoryPoints ?? 0), Count = g.Count() })
                    .OrderByDescending(m => m.TotalSp)
                    .ToList();
            }
            @if (memberWorkload.Count > 0)
            {
                <div class="tracks-member-workload">
                    <div class="tracks-planning-group-header">Member Workload</div>
                    @foreach (var member in memberWorkload)
                    {
                        var maxSp = memberWorkload.Max(m => m.TotalSp);
                        var barWidth = maxSp > 0 ? (member.TotalSp * 100 / maxSp) : 0;
                        <div class="tracks-workload-row">
                            <span class="tracks-workload-name">@member.DisplayName</span>
                            <div class="tracks-workload-bar-container">
                                <div class="tracks-workload-bar" style="width: @barWidth%"></div>
                            </div>
                            <span class="tracks-workload-sp">@member.TotalSp SP (@member.Count items)</span>
                        </div>
                    }
                </div>
            }
        </div>
    </div>

    @* ── Charts Section ── *@
    <div class="tracks-planning-charts">
        <SprintBurndownChart SprintId="Sprint.Id" />
        <VelocityChart ProductId="EpicId" />
    </div>
</div>
