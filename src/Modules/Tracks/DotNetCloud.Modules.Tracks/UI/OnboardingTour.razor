@namespace DotNetCloud.Modules.Tracks.UI
@inherits OnboardingTourBase

@* ── Onboarding Tour ───────────────────────────────────────
   Center-stage guided tour with dimmed overlay and tooltip.
   No DOM element targeting — all steps are centered.
   ─────────────────────────────────────────────────────────── *@

@if (_isVisible)
{
    <div class="onboarding-overlay" @onclick="() => { }">
    </div>

    <div class="onboarding-tooltip-wrapper">
        <TourTooltip Emoji="@_currentStepDef.Emoji"
                     Title="@_currentStepDef.Title"
                     Description="@_currentStepDef.Description"
                     CurrentStep="@_currentStep"
                     TotalSteps="@_steps.Count"
                     OnPrevious="GoToPreviousAsync"
                     OnNext="GoToNextAsync"
                     OnSkip="SkipTourAsync" />
    </div>
}
