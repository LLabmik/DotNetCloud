@namespace DotNetCloud.Modules.Tracks.UI
@inject Microsoft.JSInterop.IJSRuntime JS

<div class="tracks-kanban">
    @* ── Board Header ── *@
    <div class="tracks-kanban-header">
        <h2>
            @if (!string.IsNullOrEmpty(Board.Color))
            {
                <span class="tracks-board-dot" style="background: @Board.Color;"></span>
            }
            @Board.Title
        </h2>
        <div class="tracks-kanban-toolbar">
            <div class="tracks-filter-group">
                <input type="text" class="tracks-search-input" placeholder="Filter cards..."
                       @bind="_filterText" @bind:event="oninput" />
                <select class="tracks-filter-select" @bind="_priorityFilter">
                    <option value="">All priorities</option>
                    <option value="Urgent">🔴 Urgent</option>
                    <option value="High">🟠 High</option>
                    <option value="Medium">🟡 Medium</option>
                    <option value="Low">🟢 Low</option>
                </select>
                @if (Board.Labels.Count > 0)
                {
                    <select class="tracks-filter-select" @bind="_labelFilter">
                        <option value="">All labels</option>
                        @foreach (var label in Board.Labels)
                        {
                            <option value="@label.Id">@label.Title</option>
                        }
                    </select>
                }
                @if (Sprints is not null && Sprints.Count > 0)
                {
                    <select class="tracks-filter-select" @bind="_sprintFilter">
                        <option value="">All cards</option>
                        @foreach (var sprint in Sprints.Where(s => s.Status != SprintStatus.Completed))
                        {
                            <option value="@sprint.Id">@sprint.Title @(sprint.Status == SprintStatus.Active ? "✓" : "")</option>
                        }
                        <option value="none">No sprint</option>
                    </select>
                }
            </div>
            <button class="btn btn-sm btn-outline" @onclick="() => OnRefreshRequested.InvokeAsync()">↻ Refresh</button>
        </div>
    </div>

    @* ── Board Columns ── *@
    <div class="tracks-kanban-columns" id="tracks-kanban-columns">
        @foreach (var swimlane in Swimlanes)
        {
            var swimlaneCards = GetFilteredCards(swimlane.Id);
            var isWipExceeded = swimlane.CardLimit.HasValue && swimlaneCards.Count >= swimlane.CardLimit.Value;

            <div class="tracks-kanban-column"
                 data-swimlane-id="@swimlane.Id">
                <div class="tracks-kanban-column-header">
                    <div class="tracks-kanban-column-title">
                        @if (!string.IsNullOrEmpty(swimlane.Color))
                        {
                            <span class="tracks-column-dot" style="background: @swimlane.Color;"></span>
                        }
                        <span>@swimlane.Title</span>
                        <span class="tracks-card-count @(isWipExceeded ? "wip-exceeded" : "")">
                            @swimlaneCards.Count@(swimlane.CardLimit.HasValue ? $"/{swimlane.CardLimit}" : "")
                        </span>
                    </div>
                    <div class="tracks-kanban-column-actions">
                        <button class="tracks-icon-btn" title="Add card"
                                @onclick="() => BeginAddCard(swimlane.Id)">+</button>
                        <button class="tracks-icon-btn" title="Delete swimlane"
                                @onclick="() => DeleteSwimlaneAsync(swimlane.Id)">×</button>
                    </div>
                </div>

                <div class="tracks-kanban-cards"
                     @ondragover="HandleDragOver"
                     @ondragover:preventDefault
                     @ondrop="() => HandleDropOnSwimlane(swimlane.Id)">
                    @foreach (var card in swimlaneCards)
                    {
                        <div class="tracks-kanban-card @(card.IsArchived ? "archived" : "") @GetPriorityClass(card.Priority) @(_dropTargetCardId == card.Id ? "drop-target" : "")"
                             draggable="true"
                             data-card-id="@card.Id"
                             @ondragstart="() => HandleDragStart(card)"
                             @ondragenter="() => HandleDragEnterCard(card.Id)"
                             @onclick="() => OnCardSelected.InvokeAsync(card.Id)">

                            @* ── Card Header (board-colored) ── *@
                            <div class="tracks-card-header" style="@GetCardHeaderStyle()">
                                <span class="tracks-card-number">#@card.CardNumber</span>
                                <div class="tracks-card-header-actions">
                                    @if (card.Priority != CardPriority.None)
                                    {
                                        <span class="tracks-card-priority-badge" title="@card.Priority">@GetPriorityIcon(card.Priority)</span>
                                    }
                                    <a href="/apps/tracks/card/@card.CardNumber" target="_blank" class="tracks-open-newtab-btn"
                                       title="Open in new tab" @onclick:stopPropagation>⧉</a>
                                </div>
                            </div>

                            @* ── Card Body ── *@
                            <div class="tracks-card-body">
                                <div class="tracks-card-title">@card.Title</div>

                                @* ── Labels ── *@
                                @if (card.Labels.Count > 0)
                                {
                                    <div class="tracks-card-labels">
                                        @foreach (var label in card.Labels)
                                        {
                                            <span class="tracks-card-label-pill"
                                                  style="background: @label.Color; color: @GetContrastTextColor(label.Color);">@label.Title</span>
                                        }
                                    </div>
                                }

                                @* ── Metadata badges ── *@
                                @{
                                    var hasMeta = card.DueDate.HasValue || card.StoryPoints.HasValue ||
                                                  card.Checklists.Count > 0 || card.CommentCount > 0 || card.AttachmentCount > 0;
                                }
                                @if (hasMeta)
                                {
                                    <div class="tracks-card-meta">
                                        @if (card.DueDate.HasValue)
                                        {
                                            <span class="tracks-card-badge @(IsOverdue(card.DueDate.Value) ? "overdue" : IsDueSoon(card.DueDate.Value) ? "due-soon" : "")">
                                                📅 @TimeProvider.ToLocal(card.DueDate.Value).ToString("MMM d")
                                            </span>
                                        }
                                        @if (card.StoryPoints.HasValue)
                                        {
                                            <span class="tracks-card-badge">@card.StoryPoints SP</span>
                                        }
                                        @if (card.Checklists.Count > 0)
                                        {
                                            var totalItems = card.Checklists.Sum(c => c.Items.Count);
                                            var doneItems = card.Checklists.Sum(c => c.Items.Count(i => i.IsCompleted));
                                            <span class="tracks-card-badge @(doneItems == totalItems && totalItems > 0 ? "complete" : "")">
                                                ☑ @doneItems/@totalItems
                                            </span>
                                        }
                                        @if (card.CommentCount > 0)
                                        {
                                            <span class="tracks-card-badge">💬 @card.CommentCount</span>
                                        }
                                        @if (card.AttachmentCount > 0)
                                        {
                                            <span class="tracks-card-badge">📎 @card.AttachmentCount</span>
                                        }
                                    </div>
                                }

                                @* ── Sprint Badge ── *@
                                @if (!string.IsNullOrEmpty(card.SprintTitle) && string.IsNullOrEmpty(_sprintFilter))
                                {
                                    <div class="tracks-card-sprint-badge">🏃 @card.SprintTitle</div>
                                }

                                @* ── Footer: Assignees ── *@
                                @if (card.Assignments.Count > 0)
                                {
                                    <div class="tracks-card-footer">
                                        <div class="tracks-card-assignees">
                                            @foreach (var assign in card.Assignments.Take(3))
                                            {
                                                <span class="tracks-card-avatar" title="@(assign.DisplayName ?? "User")">
                                                    @GetInitials(assign.DisplayName)
                                                </span>
                                            }
                                            @if (card.Assignments.Count > 3)
                                            {
                                                <span class="tracks-card-avatar tracks-card-avatar-more">
                                                    +@(card.Assignments.Count - 3)
                                                </span>
                                            }
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    }

                    @if (_addingCardToSwimlane == swimlane.Id)
                    {
                        <div class="tracks-kanban-card-add">
                            <input type="text" class="form-control" placeholder="Card title..."
                                   @bind="_newCardTitle" @bind:event="oninput"
                                   @onkeydown="HandleAddCardKeyDown" />
                            <div class="tracks-card-add-actions">
                                <button class="btn btn-sm btn-primary" @onclick="SubmitNewCardAsync">Add</button>
                                <button class="btn btn-sm btn-secondary" @onclick="CancelAddCard">Cancel</button>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }

        @* ── Add Swimlane Column ── *@
        @if (!Board.LockSwimlanes)
        {
        <div class="tracks-kanban-add-swimlane">
            @if (_showAddSwimlane)
            {
                <div class="tracks-add-swimlane-form">
                    <input type="text" class="form-control" placeholder="Swimlane title..."
                           @bind="_newSwimlaneTitle" @bind:event="oninput"
                           @onkeydown="HandleAddSwimlaneKeyDown" />
                    <div class="tracks-card-add-actions">
                        <button class="btn btn-sm btn-primary" @onclick="SubmitNewSwimlaneAsync">Add</button>
                        <button class="btn btn-sm btn-secondary" @onclick="() => _showAddSwimlane = false">Cancel</button>
                    </div>
                </div>
            }
            else
            {
                <button class="tracks-add-swimlane-btn" @onclick="() => _showAddSwimlane = true">
                    + Add Swimlane
                </button>
            }
        </div>
        }
    </div>
</div>
