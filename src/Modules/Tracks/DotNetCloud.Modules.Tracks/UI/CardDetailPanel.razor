@namespace DotNetCloud.Modules.Tracks.UI
@using DotNetCloud.UI.Shared.Components.Editors
@using DotNetCloud.UI.Shared.Services
@inject IMarkdownRenderer MarkdownRenderer

<div class="tracks-card-overlay" @onclick="OnClose">
    <div class="tracks-card-panel" @onclick:stopPropagation>
        <div class="tracks-card-panel-header">
            <div class="tracks-card-panel-title-area">
                @if (_isEditingTitle)
                {
                    <input type="text" class="tracks-card-title-input" @bind="_editTitle"
                           @onkeydown="HandleTitleKeyDown" @onblur="SaveTitleAsync" />
                }
                else
                {
                    <h2 @onclick="BeginEditTitle"><span class="tracks-card-number">#@Card.CardNumber</span> @Card.Title</h2>
                }
                <span class="tracks-card-swimlane-name">
                    in <strong>@_swimlaneName</strong>
                </span>
            </div>
            <div class="tracks-panel-header-actions">
                <a href="/apps/tracks/card/@Card.CardNumber" target="_blank" class="tracks-open-newtab-btn panel"
                   title="Open in new tab">⧉</a>
                <button class="tracks-close-btn" @onclick="OnClose" title="Close">✕</button>
            </div>
        </div>

        <div class="tracks-card-panel-body">
            @* ── Main Content ── *@
            <div class="tracks-card-panel-main">
                @* Labels *@
                @if (Card.Labels.Count > 0)
                {
                    <div class="tracks-card-section">
                        <h4>Labels</h4>
                        <div class="tracks-label-list">
                            @foreach (var label in Card.Labels)
                            {
                                <span class="tracks-label-pill" style="background: @label.Color;">
                                    @label.Title
                                    <button class="tracks-label-remove"
                                            @onclick="() => RemoveLabelAsync(label.Id)">×</button>
                                </span>
                            }
                        </div>
                    </div>
                }

                @* Description *@
                <div class="tracks-card-section">
                    <h4>Description</h4>
                    @if (_isEditingDescription)
                    {
                        <MarkdownEditor Compact
                                        Rows="6"
                                        Content="@_editDescription"
                                        ContentChanged="@(v => _editDescription = v)"
                                        Renderer="MarkdownRenderer" />
                        <div class="tracks-card-section-actions">
                            <button class="btn btn-sm btn-primary" @onclick="SaveDescriptionAsync">Save</button>
                            <button class="btn btn-sm btn-secondary" @onclick="CancelEditDescription">Cancel</button>
                        </div>
                    }
                    else
                    {
                        <div class="tracks-card-description @(string.IsNullOrEmpty(Card.Description) ? "empty" : "")"
                             @onclick="BeginEditDescription">
                            @if (string.IsNullOrEmpty(Card.Description))
                            {
                                <span>Add a description...</span>
                            }
                            else
                            {
                                <div class="markdown-body">@((MarkupString)MarkdownRenderer.RenderToHtml(Card.Description))</div>
                            }
                        </div>
                    }
                </div>

                @* Checklists *@
                @if (_checklists.Count > 0)
                {
                    @foreach (var checklist in _checklists)
                    {
                        var total = checklist.Items.Count;
                        var done = checklist.Items.Count(i => i.IsCompleted);
                        <div class="tracks-card-section">
                            <div class="tracks-checklist-header">
                                <h4>☑ @checklist.Title</h4>
                                <button class="tracks-icon-btn" title="Delete checklist"
                                        @onclick="() => DeleteChecklistAsync(checklist.Id)">×</button>
                            </div>
                            @if (total > 0)
                            {
                                <div class="tracks-progress-bar">
                                    <div class="tracks-progress-fill"
                                         style="width: @(total > 0 ? (done * 100 / total) : 0)%"></div>
                                </div>
                            }
                            @foreach (var item in checklist.Items.OrderBy(i => i.Position))
                            {
                                <label class="tracks-checklist-item">
                                    <input type="checkbox" checked="@item.IsCompleted"
                                           @onchange="() => ToggleChecklistItemAsync(checklist.Id, item.Id)" />
                                    <span class="@(item.IsCompleted ? "completed" : "")">@item.Title</span>
                                </label>
                            }
                            <div class="tracks-checklist-add">
                                @if (_addingItemToChecklist == checklist.Id)
                                {
                                    <input type="text" class="form-control form-control-sm"
                                           placeholder="Item title..."
                                           @bind="_newChecklistItemTitle"
                                           @onkeydown="HandleChecklistItemKeyDown" />
                                    <button class="btn btn-sm btn-primary"
                                            @onclick="() => AddChecklistItemAsync(checklist.Id)">Add</button>
                                }
                                else
                                {
                                    <button class="btn btn-sm btn-outline"
                                            @onclick="() => { _addingItemToChecklist = checklist.Id; _newChecklistItemTitle = string.Empty; }">
                                        + Add item
                                    </button>
                                }
                            </div>
                        </div>
                    }
                }

                @* Comments *@
                <div class="tracks-card-section">
                    <h4>Comments</h4>
                    @if (_showCommentComposer)
                    {
                        <div class="tracks-comment-add">
                            <MarkdownEditor Compact
                                            Placeholder="Write a comment..."
                                            Rows="2"
                                            Content="@_newCommentContent"
                                            ContentChanged="@(v => _newCommentContent = v)"
                                            Renderer="MarkdownRenderer" />
                            <div class="tracks-card-section-actions">
                                <button class="btn btn-sm btn-secondary" @onclick="() => _showCommentComposer = false">Cancel</button>
                                <button class="btn btn-sm btn-primary" disabled="@string.IsNullOrWhiteSpace(_newCommentContent)"
                                        @onclick="AddCommentAsync">Comment</button>
                            </div>
                        </div>
                    }
                    else
                    {
                        <button class="btn btn-sm btn-primary" @onclick="() => _showCommentComposer = true">+ Add Comment</button>
                    }
                    <div class="tracks-comment-list">
                    @foreach (var comment in _comments.OrderByDescending(c => c.CreatedAt))
                    {
                        <div class="tracks-comment">
                            <div class="tracks-comment-header">
                                <strong>@(comment.DisplayName ?? "User")</strong>
                                <span class="tracks-comment-date">@comment.CreatedAt.ToLocalTime().ToString("MMM d, h:mm tt")</span>
                            </div>
                            <div class="tracks-comment-body markdown-body">@((MarkupString)MarkdownRenderer.RenderToHtml(comment.Content))</div>
                            <div class="tracks-comment-actions">
                                <button class="tracks-link-btn" @onclick="() => DeleteCommentAsync(comment.Id)">Delete</button>
                            </div>
                        </div>
                    }
                    </div>
                </div>

                @* Activity Log *@
                <div class="tracks-card-section">
                    <h4>Activity</h4>
                    @if (_activities.Count == 0)
                    {
                        <p class="tracks-muted">No activity yet.</p>
                    }
                    @foreach (var activity in _activities.Take(10))
                    {
                        <div class="tracks-activity-item">
                            <strong>@(activity.DisplayName ?? "User")</strong>
                            <span>@FormatActivityAction(activity)</span>
                            <span class="tracks-activity-date">@activity.CreatedAt.ToLocalTime().ToString("MMM d, h:mm tt")</span>
                        </div>
                    }
                </div>
            </div>

            @* ── Sidebar ── *@
            <div class="tracks-card-panel-sidebar">
                @* Priority *@
                <div class="tracks-card-sidebar-section">
                    <label>Priority</label>
                    <select class="form-control form-control-sm" @bind="_selectedPriority"
                            @bind:after="SavePriorityAsync">
                        <option value="None">None</option>
                        <option value="Low">🟢 Low</option>
                        <option value="Medium">🟡 Medium</option>
                        <option value="High">🟠 High</option>
                        <option value="Urgent">🔴 Urgent</option>
                    </select>
                </div>

                @* Due Date *@
                <div class="tracks-card-sidebar-section">
                    <label>Due Date</label>
                    <input type="date" class="form-control form-control-sm"
                           value="@_dueDate" @onchange="SaveDueDateAsync" />
                </div>

                @* Story Points *@
                <div class="tracks-card-sidebar-section">
                    <label>Story Points</label>
                    <select class="form-control form-control-sm" value="@_storyPoints" @onchange="SaveStoryPointsAsync">
                        <option value="">—</option>
                        @foreach (var sp in _fibonacciValues)
                        {
                            <option value="@sp" selected="@(_storyPoints == sp.ToString())">@sp</option>
                        }
                    </select>
                </div>

                @* Assignees *@
                <div class="tracks-card-sidebar-section">
                    <label>Assigned</label>
                    @foreach (var assign in Card.Assignments)
                    {
                        <div class="tracks-assignee-row">
                            <span class="tracks-avatar-sm">@GetInitials(assign.DisplayName)</span>
                            <span>@(assign.DisplayName ?? "User")</span>
                            <button class="tracks-icon-btn" @onclick="() => UnassignUserAsync(assign.UserId)">×</button>
                        </div>
                    }
                    @if (_showAssignInput)
                    {
                        <div class="tracks-assign-input">
                            <select class="form-control form-control-sm" @bind="_assignUserId">
                                <option value="">Select member...</option>
                                @foreach (var member in Board.Members.Where(m =>
                                    !Card.Assignments.Any(a => a.UserId == m.UserId)))
                                {
                                    <option value="@member.UserId">@(member.DisplayName ?? member.UserId.ToString())</option>
                                }
                            </select>
                            <button class="btn btn-sm btn-primary" @onclick="AssignUserAsync">Add</button>
                        </div>
                    }
                    else
                    {
                        <button class="btn btn-sm btn-outline" @onclick="() => _showAssignInput = true">+ Assign</button>
                    }
                </div>

                @* Labels *@
                <div class="tracks-card-sidebar-section">
                    <label>Labels</label>
                    @if (_showLabelPicker)
                    {
                        <div class="tracks-label-picker">
                            @{ var availableLabels = Board.Labels.Where(l => !Card.Labels.Any(cl => cl.Id == l.Id)).ToList(); }
                            @if (availableLabels.Count > 0)
                            {
                                @foreach (var label in availableLabels)
                                {
                                    <button class="tracks-label-option" style="background: @label.Color;"
                                            @onclick="() => AddLabelAsync(label.Id)">
                                        @label.Title
                                    </button>
                                }
                            }
                            else if (!_showCreateLabel)
                            {
                                <span class="tracks-muted">All board labels applied</span>
                            }
                            @if (_showCreateLabel)
                            {
                                <div class="tracks-create-label">
                                    <input type="text" class="form-control form-control-sm"
                                           placeholder="Label name..." @bind="_newLabelTitle" />
                                    <div class="tracks-color-presets">
                                        @foreach (var color in _labelColors)
                                        {
                                            <button class="tracks-color-swatch @(color == _newLabelColor ? "active" : "")"
                                                    style="background: @color;"
                                                    @onclick="() => _newLabelColor = color"></button>
                                        }
                                    </div>
                                    <div class="tracks-create-label-actions">
                                        <button class="btn btn-sm btn-primary"
                                                disabled="@string.IsNullOrWhiteSpace(_newLabelTitle)"
                                                @onclick="CreateAndApplyLabelAsync">Create</button>
                                        <button class="btn btn-sm btn-secondary"
                                                @onclick="() => _showCreateLabel = false">Cancel</button>
                                    </div>
                                </div>
                            }
                            else
                            {
                                <button class="tracks-link-btn" @onclick="() => _showCreateLabel = true">+ New Label</button>
                            }
                            <button class="tracks-link-btn" @onclick="() => { _showLabelPicker = false; _showCreateLabel = false; }">Close</button>
                        </div>
                    }
                    else
                    {
                        <button class="btn btn-sm btn-outline" @onclick="() => _showLabelPicker = true">+ Label</button>
                    }
                </div>

                @* Attachments *@
                <div class="tracks-card-sidebar-section">
                    <label>Attachments (@_attachments.Count)</label>
                    @foreach (var att in _attachments)
                    {
                        <div class="tracks-attachment-row">
                            <span>📎 @att.FileName</span>
                            <button class="tracks-icon-btn" @onclick="() => RemoveAttachmentAsync(att.Id)">×</button>
                        </div>
                    }
                    @if (_showAttachmentInput)
                    {
                        <div class="tracks-attachment-add">
                            <div class="tracks-file-upload">
                                <InputFile OnChange="HandleFileSelectedAsync" multiple
                                           class="tracks-file-input" id="card-file-upload" />
                                <label for="card-file-upload" class="btn btn-sm btn-outline tracks-file-label">
                                    @(_isUploadingFile ? "Uploading…" : "📁 Browse Files")
                                </label>
                            </div>
                            <div class="tracks-attachment-divider">
                                <span>or add URL</span>
                            </div>
                            <input type="text" class="form-control form-control-sm" placeholder="File name"
                                   @bind="_attachFileName" />
                            <input type="url" class="form-control form-control-sm" placeholder="URL (optional)"
                                   @bind="_attachUrl" />
                            <div class="tracks-attachment-actions">
                                <button class="btn btn-sm btn-primary"
                                        disabled="@string.IsNullOrWhiteSpace(_attachFileName)"
                                        @onclick="AddAttachmentAsync">Add Link</button>
                                <button class="btn btn-sm btn-secondary"
                                        @onclick="() => _showAttachmentInput = false">Cancel</button>
                            </div>
                        </div>
                    }
                    else
                    {
                        <button class="btn btn-sm btn-outline" @onclick="() => _showAttachmentInput = true">+ Attach</button>
                    }
                </div>

                @* Dependencies *@
                <div class="tracks-card-sidebar-section">
                    <label>Dependencies</label>
                    @foreach (var dep in _dependencies)
                    {
                        <div class="tracks-dependency-row">
                            <span class="tracks-dep-type">@(dep.Type == CardDependencyType.BlockedBy ? "🚫 Blocked by" : "🔗 Relates to")</span>
                            <div class="tracks-dep-target">
                                <span>@(dep.DependsOnCardTitle ?? dep.DependsOnCardId.ToString()[..8])</span>
                                <button class="tracks-icon-btn"
                                        @onclick="() => RemoveDependencyAsync(dep.DependsOnCardId)">×</button>
                            </div>
                        </div>
                    }
                    @if (_showDependencyPicker)
                    {
                        <div class="tracks-dependency-add">
                            <select class="form-control form-control-sm" @bind="_depType">
                                <option value="BlockedBy">🚫 Blocked by</option>
                                <option value="RelatesTo">🔗 Relates to</option>
                            </select>
                            <select class="form-control form-control-sm" @bind="_depTargetCardId">
                                <option value="">Select card...</option>
                                @foreach (var card in _boardCards.Where(c =>
                                    c.Id != Card.Id && !_dependencies.Any(d => d.DependsOnCardId == c.Id)))
                                {
                                    <option value="@card.Id">#@card.CardNumber @card.Title</option>
                                }
                            </select>
                            <div class="tracks-dep-actions">
                                <button class="btn btn-sm btn-primary" @onclick="AddDependencyAsync">Add</button>
                                <button class="btn btn-sm btn-secondary" @onclick="() => _showDependencyPicker = false">Cancel</button>
                            </div>
                        </div>
                    }
                    else
                    {
                        <button class="btn btn-sm btn-outline" @onclick="OpenDependencyPickerAsync">+ Dependency</button>
                    }
                </div>

                @* Time Tracking *@
                <div class="tracks-card-sidebar-section">
                    <label>Time Tracked</label>
                    <span class="tracks-time-total">@FormatMinutes(_liveTrackedMinutes)</span>
                    @if (_timeEntries.Any(e => e.EndTime is null))
                    {
                        <button class="btn btn-sm btn-danger" @onclick="StopTimerAsync">⏹ Stop Timer</button>
                    }
                    else
                    {
                        <button class="btn btn-sm btn-outline" @onclick="StartTimerAsync">⏱ Start Timer</button>
                    }
                </div>

                @* Actions *@
                <div class="tracks-card-sidebar-section">
                    <label>Actions</label>
                    <button class="btn btn-sm btn-outline" @onclick="AddChecklistAsync">+ Checklist</button>
                </div>

                <div class="tracks-card-sidebar-section">
                    <label>Manage</label>
                    <button class="btn btn-sm btn-outline"
                            @onclick="ShowArchiveConfirm">
                        @(Card.IsArchived ? "Unarchive" : "Archive")
                    </button>
                    <button class="btn btn-sm btn-danger" @onclick="ShowDeleteConfirm">Delete</button>
                </div>
            </div>
        </div>
    </div>
</div>

@* ── Confirmation Modal ── *@
@if (_showConfirmModal && _confirmAction is not null)
{
    <div class="tracks-modal-overlay" @onclick="CancelConfirm">
        <div class="tracks-modal" @onclick:stopPropagation>
            <div class="tracks-modal-header">
                <h3>@(_confirmAction == "delete" ? "Delete Card" : (_confirmAction == "archive" ? "Archive Card" : "Unarchive Card"))</h3>
                <button class="tracks-close-btn" @onclick="CancelConfirm">×</button>
            </div>
            <div class="tracks-modal-body">
                @if (_confirmAction == "delete")
                {
                    <p>Are you sure you want to <strong>permanently delete</strong> card <strong>#@Card.CardNumber @Card.Title</strong>?</p>
                    <p class="tracks-modal-warning">This action cannot be undone.</p>
                }
                else
                {
                    <p>Are you sure you want to <strong>@_confirmAction</strong> card <strong>#@Card.CardNumber @Card.Title</strong>?</p>
                }
            </div>
            <div class="tracks-modal-footer">
                <button class="btn btn-sm btn-secondary" @onclick="CancelConfirm">Cancel</button>
                <button class="btn btn-sm @(_confirmAction == "delete" ? "btn-danger" : "btn-primary")"
                        @onclick="ConfirmActionAsync">
                    @(_confirmAction == "delete" ? "Delete" : (_confirmAction == "archive" ? "Archive" : "Unarchive"))
                </button>
            </div>
        </div>
    </div>
}
