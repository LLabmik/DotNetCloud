@namespace DotNetCloud.Modules.Tracks.UI
@implements IAsyncDisposable

@* ── Undo Toast Component ──
   Shows a temporary message with an "Undo" button.
   Like Gmail's "Message deleted. Undo?" feature.
   Automatically disappears after the timeout. ── *@

@if (_isVisible)
{
    <div class="undo-toast @(_isLeaving ? "undo-toast--leaving" : "")">
        <div class="undo-toast-content">
            <span class="undo-toast-icon">✓</span>
            <span class="undo-toast-message">@Message</span>
            @if (HasUndoAction)
            {
                <button class="undo-toast-btn" @onclick="HandleUndo" disabled="@_isUndoing">
                    @(_isUndoing ? "Undoing..." : "Undo")
                </button>
            }
            <button class="undo-toast-dismiss" @onclick="Dismiss" title="Dismiss">✕</button>
        </div>
    </div>
}

<style>
    .undo-toast {
        position: fixed; bottom: 24px; left: 50%; transform: translateX(-50%);
        z-index: 10000;
        background: var(--color-surface-inverse, #1a1a2e);
        color: #fff;
        border-radius: 8px;
        box-shadow: 0 8px 24px rgba(0,0,0,0.25);
        animation: undo-toast-in 0.25s ease-out;
        max-width: 90vw;
    }
    .undo-toast--leaving {
        animation: undo-toast-out 0.2s ease-in forwards;
    }
    .undo-toast-content {
        display: flex; align-items: center; gap: 12px;
        padding: 12px 20px;
    }
    .undo-toast-icon {
        width: 24px; height: 24px; border-radius: 50%;
        background: #22c55e; color: #fff;
        display: flex; align-items: center; justify-content: center;
        font-size: 13px; font-weight: bold; flex-shrink: 0;
    }
    .undo-toast-message { font-size: 0.875rem; white-space: nowrap; }
    .undo-toast-btn {
        background: none; border: 1px solid rgba(255,255,255,0.4);
        color: #fff; padding: 4px 14px; border-radius: 4px;
        cursor: pointer; font-size: 0.8125rem; font-weight: 600;
        transition: background 0.15s, border-color 0.15s;
        flex-shrink: 0;
    }
    .undo-toast-btn:hover { background: rgba(255,255,255,0.15); border-color: rgba(255,255,255,0.6); }
    .undo-toast-btn:disabled { opacity: 0.5; cursor: not-allowed; }
    .undo-toast-dismiss {
        background: none; border: none; color: rgba(255,255,255,0.5);
        cursor: pointer; font-size: 14px; padding: 4px; line-height: 1;
        flex-shrink: 0;
    }
    .undo-toast-dismiss:hover { color: #fff; }

    @@keyframes undo-toast-in {
        from { opacity: 0; transform: translateX(-50%) translateY(12px); }
        to { opacity: 1; transform: translateX(-50%) translateY(0); }
    }
    @@keyframes undo-toast-out {
        from { opacity: 1; transform: translateX(-50%) translateY(0); }
        to { opacity: 0; transform: translateX(-50%) translateY(12px); }
    }
</style>

@code {
    /// <summary>The message to show (e.g., "Product deleted.").</summary>
    [Parameter] public string Message { get; set; } = "";

    /// <summary>How long the toast stays visible (in milliseconds). Default: 10 seconds.</summary>
    [Parameter] public int DurationMs { get; set; } = 10_000;

    /// <summary>Called when the user clicks "Undo". If null, no Undo button is shown.</summary>
    [Parameter] public Func<Task>? OnUndo { get; set; }

    /// <summary>Called when the toast is dismissed (timeout or manual close).</summary>
    [Parameter] public EventCallback OnDismissed { get; set; }

    private bool _isVisible;
    private bool _isLeaving;
    private bool _isUndoing;
    private CancellationTokenSource? _timerCts;

    private bool HasUndoAction => OnUndo is not null;

    /// <summary>Shows the toast. Call this after performing the action.</summary>
    public async Task ShowAsync()
    {
        _isVisible = true;
        _isLeaving = false;
        _isUndoing = false;
        StateHasChanged();

        // Auto-dismiss after timeout
        _timerCts?.Cancel();
        _timerCts = new CancellationTokenSource();
        try
        {
            await Task.Delay(DurationMs, _timerCts.Token);
            await DismissInternalAsync();
        }
        catch (OperationCanceledException)
        {
            // Timer was cancelled (user clicked something)
        }
    }

    private async Task HandleUndo()
    {
        if (OnUndo is null || _isUndoing) return;

        _isUndoing = true;
        _timerCts?.Cancel(); // Stop auto-dismiss

        try
        {
            await OnUndo();
        }
        finally
        {
            _isVisible = false;
            _isUndoing = false;
            await OnDismissed.InvokeAsync();
        }
    }

    private async Task Dismiss()
    {
        _timerCts?.Cancel();
        await DismissInternalAsync();
    }

    private async Task DismissInternalAsync()
    {
        if (!_isVisible) return;
        _isLeaving = true;
        StateHasChanged();
        await Task.Delay(200); // Match animation duration
        _isVisible = false;
        _isLeaving = false;
        await OnDismissed.InvokeAsync();
    }

    /// <inheritdoc />
    public async ValueTask DisposeAsync()
    {
        _timerCts?.Cancel();
        _timerCts?.Dispose();
        await Task.CompletedTask;
    }
}
