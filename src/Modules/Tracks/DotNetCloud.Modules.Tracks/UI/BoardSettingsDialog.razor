@namespace DotNetCloud.Modules.Tracks.UI

<DncModal Title="Board Settings" OnClose="OnClose" StartVisible="true" Wide="true">
    <div class="tracks-settings">
        @* ── General ── *@
        <div class="tracks-settings-section">
            <h4>General</h4>
            <div class="form-group">
                <label>Title</label>
                <input type="text" class="form-control" @bind="_title" />
            </div>
            <div class="form-group">
                <label>Description</label>
                <textarea class="form-control" rows="3" @bind="_description"></textarea>
            </div>
            <div class="form-group">
                <label>Color</label>
                <div class="tracks-color-picker">
                    @foreach (var color in _colors)
                    {
                        <button type="button"
                                class="tracks-color-swatch @(_color == color ? "selected" : "")"
                                style="background: @color;"
                                @onclick="() => _color = color">
                        </button>
                    }
                </div>
            </div>
            <button class="btn btn-primary" @onclick="SaveGeneralAsync">Save Changes</button>
        </div>

        @* ── Members ── *@
        <div class="tracks-settings-section">
            <h4>Members</h4>
            <div class="tracks-members-list">
                @foreach (var member in Board.Members)
                {
                    <div class="tracks-member-row">
                        <span class="tracks-avatar-sm">@GetInitials(member.DisplayName)</span>
                        <span class="tracks-member-name">@(member.DisplayName ?? member.UserId.ToString()[..8])</span>
                        <select class="form-control form-control-sm tracks-role-select"
                                value="@member.Role"
                                @onchange="e => UpdateMemberRoleAsync(member.UserId, e)">
                            <option value="Viewer">Viewer</option>
                            <option value="Member">Member</option>
                            <option value="Admin">Admin</option>
                            <option value="Owner">Owner</option>
                        </select>
                        <button class="tracks-icon-btn" title="Remove member"
                                @onclick="() => RemoveMemberAsync(member.UserId)">×</button>
                    </div>
                }
            </div>
            <div class="tracks-add-member">
                <input type="text" class="form-control form-control-sm"
                       placeholder="User ID to add..." @bind="_addMemberInput" />
                <button class="btn btn-sm btn-primary" @onclick="AddMemberAsync">Add</button>
            </div>
        </div>

        @* ── Labels ── *@
        <div class="tracks-settings-section">
            <h4>Labels</h4>
            @foreach (var label in Board.Labels)
            {
                <div class="tracks-label-row">
                    <span class="tracks-label-pill" style="background: @label.Color;">@label.Title</span>
                    <button class="tracks-icon-btn" @onclick="() => DeleteLabelAsync(label.Id)">×</button>
                </div>
            }
            <div class="tracks-add-label">
                <input type="text" class="form-control form-control-sm" placeholder="Label name"
                       @bind="_newLabelTitle" />
                <div class="tracks-color-picker-sm">
                    @foreach (var c in _labelColors)
                    {
                        <button type="button"
                                class="tracks-color-swatch-sm @(_newLabelColor == c ? "selected" : "")"
                                style="background: @c;"
                                @onclick="() => _newLabelColor = c">
                        </button>
                    }
                </div>
                <button class="btn btn-sm btn-primary" @onclick="CreateLabelAsync">Add Label</button>
            </div>
        </div>

        @* ── Transfer to Team ── *@
        <div class="tracks-settings-section">
            <h4>Team</h4>
            @if (Board.TeamId.HasValue)
            {
                var currentTeam = Teams.FirstOrDefault(t => t.Id == Board.TeamId.Value);
                <p>This board belongs to team <strong>@(currentTeam?.Name ?? "Unknown")</strong>.</p>
                <button class="btn btn-outline btn-sm" @onclick="MakePersonalAsync">
                    Make Personal
                </button>
            }
            else
            {
                <p>This is a personal board.</p>
            }
            @if (Teams.Count > 0)
            {
                <div class="tracks-transfer-row">
                    <select class="form-control form-control-sm" @bind="_selectedTeamId">
                        <option value="">Transfer to team…</option>
                        @foreach (var team in Teams.Where(t => t.Id != Board.TeamId))
                        {
                            <option value="@team.Id">@team.Name</option>
                        }
                    </select>
                    <button class="btn btn-sm btn-primary"
                            disabled="@string.IsNullOrEmpty(_selectedTeamId)"
                            @onclick="TransferToTeamAsync">
                        Transfer
                    </button>
                </div>
            }
            @if (!string.IsNullOrEmpty(_transferError))
            {
                <p class="tracks-transfer-error">@_transferError</p>
            }
        </div>

        @* ── Team Members (inherited access) ── *@
        @if (Board.TeamId.HasValue)
        {
            var currentTeam = Teams.FirstOrDefault(t => t.Id == Board.TeamId.Value);
            if (currentTeam is not null && currentTeam.Members.Count > 0)
            {
                <div class="tracks-settings-section">
                    <h4>Team Members (@currentTeam.Members.Count)</h4>
                    <p class="tracks-team-members-hint">These users have access via the <strong>@currentTeam.Name</strong> team.</p>
                    <div class="tracks-team-members-list">
                        @foreach (var tm in currentTeam.Members)
                        {
                            <div class="tracks-team-member-row">
                                <span class="tracks-avatar-sm">@GetInitials(tm.DisplayName)</span>
                                <span class="tracks-member-name">@(tm.DisplayName ?? tm.UserId.ToString()[..8])</span>
                                <span class="tracks-team-role-badge">@GetEffectiveRoleLabel(tm.Role)</span>
                            </div>
                        }
                    </div>
                </div>
            }
        }

        @* ── Archive / Delete ── *@
        <div class="tracks-settings-section tracks-settings-danger">
            <h4>Danger Zone</h4>
            <button class="btn btn-outline" @onclick="ShowArchiveConfirm">
                @(Board.IsArchived ? "Unarchive Board" : "Archive Board")
            </button>
            <button class="btn btn-danger" @onclick="ShowDeleteConfirm">Delete Board</button>

            @if (_showArchiveConfirm)
            {
                <div class="tracks-confirm-dialog">
                    <div class="tracks-confirm-content">
                        <p><strong>@(Board.IsArchived ? "Unarchive" : "Archive") this board?</strong></p>
                        <p class="text-muted">
                            @(Board.IsArchived
                                ? "This board will become active again and visible to all members."
                                : "Archived boards are hidden from the board list. You can unarchive it later.")
                        </p>
                        <div class="tracks-confirm-actions">
                            <button class="btn btn-outline btn-sm" @onclick="ArchiveBoardAsync">
                                @(Board.IsArchived ? "Yes, Unarchive" : "Yes, Archive")
                            </button>
                            <button class="btn btn-sm" @onclick="HideArchiveConfirm">Cancel</button>
                        </div>
                    </div>
                </div>
            }

            @if (_showDeleteConfirm)
            {
                <div class="tracks-confirm-dialog">
                    <div class="tracks-confirm-content">
                        <p><strong>Permanently delete this board?</strong></p>
                        <p class="text-muted">This action cannot be undone. All lists, cards, and activity for this board will be permanently deleted.</p>
                        <div class="tracks-confirm-actions">
                            <button class="btn btn-danger btn-sm" @onclick="DeleteBoardAsync">
                                Delete Permanently
                            </button>
                            <button class="btn btn-sm" @onclick="HideDeleteConfirm">Cancel</button>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</DncModal>
