@namespace DotNetCloud.Modules.Tracks.UI
@using DotNetCloud.UI.Shared.Components.Editors
@using DotNetCloud.UI.Shared.Services
@inject IMarkdownRenderer MarkdownRenderer

@if (_isLoading)
{
    <div class="tracks-fullscreen-loading">
        <DncLoadingIndicator />
    </div>
}
else if (_accessDenied)
{
    <div class="tracks-fullscreen-denied">
        <div class="tracks-denied-card">
            <div class="tracks-denied-icon">🔒</div>
            <h2>Access Denied</h2>
            <p>You don't have permission to view this card. You may need to be added as a member of the board this card belongs to.</p>
            <a href="/apps/tracks" class="btn btn-primary">Go to Tracks</a>
        </div>
    </div>
}
else if (_notFound)
{
    <div class="tracks-fullscreen-denied">
        <div class="tracks-denied-card">
            <div class="tracks-denied-icon">🔍</div>
            <h2>Card Not Found</h2>
            <p>This card may have been deleted or the link may be invalid.</p>
            <a href="/apps/tracks" class="btn btn-primary">Go to Tracks</a>
        </div>
    </div>
}
else if (_card is not null && _board is not null)
{
    <div class="tracks-fullscreen-wrapper">
        <CardDetailPanel Card="_card"
                         Board="_board"
                         OnClose="NavigateBack"
                         OnCardUpdated="HandleCardUpdated"
                         OnCardDeleted="HandleCardDeleted" />
    </div>
}
