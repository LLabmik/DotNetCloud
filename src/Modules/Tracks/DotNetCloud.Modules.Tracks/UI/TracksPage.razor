@namespace DotNetCloud.Modules.Tracks.UI

<div class="tracks-layout">
    @* ── Sidebar ── *@
    <div class="tracks-sidebar @(_sidebarCollapsed ? "collapsed" : "")">
        <div class="tracks-sidebar-header">
            @if (!_sidebarCollapsed)
            {
                <h3>Tracks</h3>
            }
            <button class="tracks-sidebar-toggle" @onclick="() => _sidebarCollapsed = !_sidebarCollapsed"
                    title="@(_sidebarCollapsed ? "Expand sidebar" : "Collapse sidebar")">
                <span>@(_sidebarCollapsed ? "▶" : "◀")</span>
            </button>
        </div>

        <nav class="tracks-nav">
            <button class="tracks-nav-item @(_view == TracksView.Boards ? "active" : "")"
                    @onclick="ShowBoardSwimlane" title="My Boards">
                <span class="tracks-nav-icon">📋</span>
                @if (!_sidebarCollapsed) { <span class="tracks-nav-text">My Boards</span> }
            </button>
            <button class="tracks-nav-item @(_view == TracksView.Teams ? "active" : "")"
                    @onclick="ShowTeams" title="Teams">
                <span class="tracks-nav-icon">👥</span>
                @if (!_sidebarCollapsed) { <span class="tracks-nav-text">Teams</span> }
            </button>
        </nav>

        @if (_view == TracksView.Board && _selectedBoard is not null)
        {
            <div class="tracks-sidebar-section">
                @if (!_sidebarCollapsed)
                {
                    <div class="tracks-sidebar-section-header">
                        <span>Board</span>
                    </div>
                }
                <button class="tracks-nav-item active" @onclick="() => {}" title="@_selectedBoard.Title">
                    @if (!string.IsNullOrEmpty(_selectedBoard.Color))
                    {
                        <span class="tracks-board-dot" style="background: @_selectedBoard.Color;"></span>
                    }
                    @if (!_sidebarCollapsed) { <span class="tracks-nav-text">@_selectedBoard.Title</span> }
                </button>
                <button class="tracks-nav-item @(_showSprints ? "active" : "")"
                        @onclick="ToggleSprints" title="Sprints">
                    <span class="tracks-nav-icon">🏃</span>
                    @if (!_sidebarCollapsed) { <span class="tracks-nav-text">Sprints</span> }
                </button>
                @{
                    var plannable = _sprints.FirstOrDefault(s => s.Status is SprintStatus.Planning or SprintStatus.Active);
                }
                @if (plannable is not null)
                {
                    <button class="tracks-nav-item @(_view == TracksView.Planning ? "active" : "")"
                            @onclick="() => OpenSprintPlanning(plannable)" title="Sprint Planning">
                        <span class="tracks-nav-icon">📊</span>
                        @if (!_sidebarCollapsed) { <span class="tracks-nav-text">Planning</span> }
                    </button>
                }
                <button class="tracks-nav-item"
                        @onclick="ShowBoardSettings" title="Settings">
                    <span class="tracks-nav-icon">⚙</span>
                    @if (!_sidebarCollapsed) { <span class="tracks-nav-text">Settings</span> }
                </button>
                <button class="tracks-nav-item" @onclick="ShowBoardSwimlane" title="All Boards">
                    <span class="tracks-nav-icon">←</span>
                    @if (!_sidebarCollapsed) { <span class="tracks-nav-text">All Boards</span> }
                </button>
            </div>
        }

        @if (_teams.Count > 0)
        {
            <div class="tracks-sidebar-section">
                @if (!_sidebarCollapsed)
                {
                    <div class="tracks-sidebar-section-header">
                        <span>Teams</span>
                    </div>
                }
                @foreach (var team in _teams.Take(5))
                {
                    <button class="tracks-nav-item"
                            @onclick="() => SelectTeam(team.Id)" title="@team.Name">
                        <span class="tracks-nav-icon">👥</span>
                        @if (!_sidebarCollapsed) { <span class="tracks-nav-text">@team.Name</span> }
                    </button>
                }
            </div>
        }
    </div>

    @* ── Main Content ── *@
    <div class="tracks-main">
        @if (_isLoading)
        {
            <div class="tracks-loading">
                <DncLoadingIndicator />
            </div>
        }
        else if (_errorMessage is not null)
        {
            <DncErrorDisplay Message="@_errorMessage" />
        }
        else
        {
            @switch (_view)
            {
                case TracksView.Boards:
                    <BoardListView Boards="_boards"
                                   Teams="_teams"
                                   InitialTeamFilter="@_initialTeamFilter"
                                   OnBoardSelected="SelectBoard"
                                   OnBoardCreated="HandleBoardCreated"
                                   OnBoardDeleted="HandleBoardDeleted" />
                    break;

                case TracksView.Board:
                    @if (_selectedBoard is not null)
                    {
                        <div class="tracks-board-area">
                            <KanbanBoard Board="_selectedBoard"
                                         Swimlanes="_boardSwimlanes"
                                         CardsBySwimlane="_cardsBySwimlane"
                                         Sprints="_sprints"
                                         OnCardSelected="SelectCard"
                                         OnCardMoved="HandleCardMoved"
                                         OnCardCreated="HandleCardCreated"
                                         OnSwimlaneCreated="HandleSwimlaneCreated"
                                         OnSwimlaneDeleted="HandleSwimlaneDeleted"
                                         OnRefreshRequested="RefreshBoardAsync" />

                            @if (_showSprints)
                            {
                                <SprintPanel BoardId="_selectedBoard.Id"
                                             Sprints="_sprints"
                                             OnSprintChanged="RefreshSprintsAsync"
                                             OnCardSelected="SelectCard"
                                             OnPlanSprint="OpenSprintPlanning" />
                            }
                        </div>

                        @if (_selectedCard is not null)
                        {
                            <CardDetailPanel Card="_selectedCard"
                                             Board="_selectedBoard"
                                             OnClose="CloseCardDetail"
                                             OnCardUpdated="HandleCardUpdated"
                                             OnCardDeleted="HandleCardDeleted" />
                        }

                        @if (_showBoardSettings)
                        {
                            <BoardSettingsDialog Board="_selectedBoard"
                                                 Teams="_teams"
                                                 OnClose="CloseBoardSettings"
                                                 OnBoardUpdated="HandleBoardUpdated"
                                                 OnBoardDeleted="HandleBoardDeletedFromSettings" />
                        }
                    }
                    break;

                case TracksView.Teams:
                    <TeamManagement Teams="_teams"
                                    OnTeamSelected="SelectTeam"
                                    OnRefreshRequested="RefreshTeamsAsync" />
                    break;

                case TracksView.Planning:
                    @if (_selectedBoard is not null && _planningSprint is not null)
                    {
                        <SprintPlanningView BoardId="_selectedBoard.Id"
                                            Sprint="_planningSprint"
                                            OnClose="ClosePlanning"
                                            OnCardSelected="SelectCard"
                                            OnSprintChanged="RefreshSprintsAsync" />

                        @if (_selectedCard is not null)
                        {
                            <CardDetailPanel Card="_selectedCard"
                                             Board="_selectedBoard"
                                             OnClose="CloseCardDetail"
                                             OnCardUpdated="HandleCardUpdated"
                                             OnCardDeleted="HandleCardDeleted" />
                        }
                    }
                    break;
            }
        }
    </div>
</div>
