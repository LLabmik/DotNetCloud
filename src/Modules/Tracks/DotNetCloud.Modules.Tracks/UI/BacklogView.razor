@namespace DotNetCloud.Modules.Tracks.UI

<div class="tracks-backlog">
    @* ── Header ── *@
    <div class="tracks-backlog-header">
        <div class="tracks-backlog-title-area">
            <h2>📋 Backlog</h2>
            <div class="tracks-backlog-stats">
                <span class="tracks-backlog-stat">@_backlogItems.Count items</span>
                @{
                    var totalSp = _backlogItems.Where(i => i.StoryPoints.HasValue).Sum(i => i.StoryPoints!.Value);
                }
                @if (totalSp > 0)
                {
                    <span class="tracks-backlog-stat">@totalSp SP</span>
                }
            </div>
        </div>
        <div class="tracks-backlog-toolbar">
            <div class="tracks-filter-group">
                <input type="text" class="tracks-search-input" placeholder="Filter cards..."
                       @bind="_filterText" @bind:event="oninput" />
                <select class="tracks-filter-select" @bind="_priorityFilter">
                    <option value="">All priorities</option>
                    <option value="Urgent">🔴 Urgent</option>
                    <option value="High">🟠 High</option>
                    <option value="Medium">🟡 Medium</option>
                    <option value="Low">🟢 Low</option>
                </select>
            </div>
            <div class="tracks-backlog-actions">
                @if (_selectedItemIds.Count > 0 && Sprints.Count > 0)
                {
                    <div class="tracks-backlog-bulk">
                        <select class="tracks-filter-select" @bind="_bulkTargetSprintId">
                            <option value="">Assign to sprint...</option>
                            @foreach (var sprint in Sprints.Where(s => s.Status != SprintStatus.Completed))
                            {
                                <option value="@sprint.Id">@sprint.Title</option>
                            }
                        </select>
                        <button class="btn btn-sm btn-primary" @onclick="BulkAssignToSprintAsync"
                                disabled="@(string.IsNullOrEmpty(_bulkTargetSprintId) || _isBulkAssigning)">
                            @(_isBulkAssigning ? "Assigning..." : $"Assign {_selectedItemIds.Count} items")
                        </button>
                    </div>
                }
                <button class="btn btn-sm btn-outline" @onclick="RefreshBacklogAsync">↻ Refresh</button>
                <button class="btn btn-sm btn-primary" @onclick="ToggleAddCard">＋ New Card</button>
            </div>
        </div>
    </div>

    @* ── Add Card Form ── *@
    @if (_isAddingCard)
    {
        <div class="tracks-backlog-add-card">
            <div class="tracks-backlog-add-card-row">
                <input type="text" class="tracks-search-input tracks-backlog-add-title"
                       placeholder="Item title..." @bind="_newCardTitle" @bind:event="oninput"
                       @onkeydown="HandleNewCardKeyDown" />
                @if (Swimlanes.Count > 0)
                {
                    <select class="tracks-filter-select" @bind="_newCardSwimlaneId">
                        @foreach (var lane in Swimlanes)
                        {
                            <option value="@lane.Id">@lane.Title</option>
                        }
                    </select>
                }
                <select class="tracks-filter-select" @bind="_newCardPriority">
                    <option value="">No priority</option>
                    <option value="Low">🟢 Low</option>
                    <option value="Medium">🟡 Medium</option>
                    <option value="High">🟠 High</option>
                    <option value="Urgent">🔴 Urgent</option>
                </select>
            </div>
            <div class="tracks-backlog-add-card-actions">
                <button class="btn btn-sm btn-primary" @onclick="SubmitNewCardAsync"
                        disabled="@(string.IsNullOrWhiteSpace(_newCardTitle) || _isSubmittingCard)">
                    @(_isSubmittingCard ? "Creating..." : "Add Card")
                </button>
                <button class="btn btn-sm btn-secondary" @onclick="CancelAddCard">Cancel</button>
            </div>
        </div>
    }

    @* ── Content ── *@
    @if (_isLoading)
    {
        <div class="tracks-backlog-loading">
            <DncLoadingIndicator />
        </div>
    }
    else if (_backlogItems.Count == 0 && string.IsNullOrEmpty(_filterText) && string.IsNullOrEmpty(_priorityFilter))
    {
        <div class="tracks-backlog-empty">
            <div class="tracks-backlog-empty-icon">📭</div>
            <h3>Backlog is empty</h3>
            <p>Items not assigned to any sprint will appear here.</p>
            @if (Swimlanes.Count > 0)
            {
                <button class="btn btn-sm btn-primary" style="margin-top: 12px;" @onclick="ToggleAddCard">＋ Create your first item</button>
            }
        </div>
    }
    else
    {
        @* ── Select All ── *@
        <div class="tracks-backlog-select-all">
            <label class="tracks-backlog-checkbox-label">
                <input type="checkbox" checked="@_selectAll" @onchange="ToggleSelectAll" />
                <span>Select all (@GetFilteredItems().Count)</span>
            </label>
        </div>

        @* ── Card List ── *@
        <div class="tracks-backlog-list">
            @foreach (var item in GetFilteredItems())
            {
                <div class="tracks-backlog-card @GetPriorityClass(item.Priority) @(_selectedItemIds.Contains(item.Id) ? "selected" : "")"
                     @onclick="() => OnWorkItemSelected.InvokeAsync(item.Id)">
                    <div class="tracks-backlog-card-check" @onclick:stopPropagation>
                        <input type="checkbox" checked="@_selectedItemIds.Contains(item.Id)"
                               @onchange="() => ToggleItemSelection(item.Id)" />
                    </div>
                    <div class="tracks-backlog-card-content">
                        <div class="tracks-backlog-card-top">
                            <span class="tracks-backlog-card-number">#@item.ItemNumber</span>
                            <span class="tracks-backlog-card-title">@item.Title</span>
                            @if (item.Priority != Priority.None)
                            {
                                <span class="tracks-card-priority-badge" title="@item.Priority">@GetPriorityIcon(item.Priority)</span>
                            }
                        </div>
                        <div class="tracks-backlog-card-meta">
                            @if (item.StoryPoints.HasValue)
                            {
                                <span class="tracks-card-badge">@item.StoryPoints SP</span>
                            }
                            @if (item.Labels.Count > 0)
                            {
                                @foreach (var label in item.Labels.Take(3))
                                {
                                    <span class="tracks-card-label-pill"
                                          style="background: @label.Color; color: @GetContrastTextColor(label.Color);">@label.Title</span>
                                }
                            }
                            @if (item.Assignments.Count > 0)
                            {
                                <span class="tracks-card-badge">👤 @item.Assignments.Count</span>
                            }
                            @if (item.DueDate.HasValue)
                            {
                                <span class="tracks-card-badge">📅 @item.DueDate.Value.ToString("MMM d")</span>
                            }
                            @if (item.CommentCount > 0)
                            {
                                <span class="tracks-card-badge">💬 @item.CommentCount</span>
                            }
                        </div>
                    </div>
                    @if (Sprints.Count > 0)
                    {
                        <div class="tracks-backlog-card-assign" @onclick:stopPropagation>
                            <select class="tracks-backlog-sprint-select"
                                    @onchange="(e) => AssignItemToSprintAsync(item.Id, e)">
                                <option value="">Sprint...</option>
                                @foreach (var sprint in Sprints.Where(s => s.Status != SprintStatus.Completed))
                                {
                                    <option value="@sprint.Id">@sprint.Title</option>
                                }
                            </select>
                        </div>
                    }
                </div>
            }
        </div>

        @if (GetFilteredItems().Count == 0)
        {
            <div class="tracks-backlog-empty">
                <p>No items match the current filters.</p>
            </div>
        }
    }
</div>
