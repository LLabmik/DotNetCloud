{
  "id": "dotnetcloud.tracks",
  "name": "Tracks",
  "version": "1.0.0",
  "description": "Hierarchical product management with epics, features, items, sub-items, swimlanes, labels, sprints, time tracking, dependencies, and integrated planning poker.",
  "author": "DotNetCloud",
  "requiredCapabilities": [
    "INotificationService",
    "IUserDirectory",
    "ICurrentUserContext",
    "IAuditLogger",
    "IRealtimeBroadcaster"
  ],
  "publishedEvents": [
    "ProductCreatedEvent",
    "ProductDeletedEvent",
    "WorkItemCreatedEvent",
    "WorkItemMovedEvent",
    "WorkItemUpdatedEvent",
    "WorkItemDeletedEvent",
    "WorkItemAssignedEvent",
    "WorkItemCommentAddedEvent",
    "SprintStartedEvent",
    "SprintCompletedEvent",
    "PokerSessionStartedEvent",
    "PokerSessionRevealedEvent",
    "PokerSessionCompletedEvent"
  ],
  "subscribedEvents": [
    "FileDeletedEvent"
  ],
  "minCoreVersion": "1.0.0"
}
