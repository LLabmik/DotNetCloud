@namespace DotNetCloud.Modules.Chat.UI

@*
    Channel header - Displays channel name, topic, member count, and actions.
    Code-behind: ChannelHeader.razor.cs
*@

<div class="chat-channel-header">
    @if (Channel is not null)
    {
        <div class="channel-info">
            <span class="channel-icon">@(Channel.Type == "Private" ? "🔒" : Channel.Type is "DirectMessage" or "Group" ? "💬" : "#")</span>
            <h2 class="channel-name">@Channel.Name</h2>
            @if (!string.IsNullOrEmpty(Channel.Topic))
            {
                <span class="channel-topic">@Channel.Topic</span>
            }
        </div>

        <div class="channel-actions">
            <span class="member-count" title="Channel members">👥 @Channel.MemberCount</span>
            <button class="btn btn-sm" @onclick="OnTogglePinClick" title="@(Channel.IsPinned ? "Unpin this channel from the top of the sidebar" : "Pin this channel to the top of the sidebar")">
                @(Channel.IsPinned ? "📌 Unpin" : "📌 Pin")
            </button>
            <button class="btn btn-sm @(Channel.IsMuted ? "btn-muted" : "")" @onclick="OnToggleMuteClick" title="@(Channel.IsMuted ? "Unmute notifications for this channel" : "Mute notifications for this channel")">
                @(Channel.IsMuted ? "🔇 Muted" : "🔔 Mute")
            </button>
            @if (IsAdminOrOwner)
            {
                <button class="btn btn-sm" @onclick="OnArchiveClick" title="Archive this channel — hides it from the sidebar (can be restored later)">
                    🗄️ Archive
                </button>
                <button class="btn btn-sm" @onclick="OnEditClick" title="Edit channel name, topic, and settings">
                    ✏️ Edit
                </button>
            }
            @if (IsAdminOrOwner && Channel!.Type == "Private")
            {
                <button class="btn btn-sm" @onclick="OnInviteClick" title="Invite a user to this channel">
                    ➕ Invite
                </button>
            }
            @if (Channel!.Type is "DirectMessage" or "Group")
            {
                <button class="btn btn-sm" @onclick="OnAddPeopleClick" title="Add people to this conversation">
                    👥 Add People
                </button>
            }
            <button class="btn btn-sm btn-call" @onclick="OnAudioCallClick" title="Start audio call">
                📞 Call
            </button>
            <button class="btn btn-sm btn-call" @onclick="OnVideoCallClick" title="Start video call">
                📹 Video
            </button>
            @if (HasActiveCall)
            {
                <button class="btn btn-sm btn-call-active" @onclick="OnJoinCallClick" title="Join active call">
                    🟢 Join Call
                </button>
            }
            <button class="btn btn-sm" @onclick="OnCallHistoryClick" title="View call history">
                📋 Calls
            </button>
            <button class="btn btn-sm" @onclick="OnSearchClick" title="Search messages in this channel">
                🔍
            </button>
            <button class="btn btn-sm" @onclick="ToggleMemberList" title="View and manage channel members">
                👤 Members
            </button>
            @if (!string.Equals(Channel!.Name, "Public", StringComparison.OrdinalIgnoreCase))
            {
                <button class="btn btn-sm btn-danger" @onclick="OnLeaveClick" title="Leave this channel">
                    Leave
                </button>
            }

            <div class="help-wrapper">
                <button class="btn btn-sm btn-help" @onclick="ToggleHelp" title="What do these buttons do?">
                    ?
                </button>
                @if (_showHelp)
                {
                    <div class="help-popover">
                        <div class="help-popover-header">
                            <strong>Channel Actions</strong>
                            <button class="btn-close-sm" @onclick="ToggleHelp">✕</button>
                        </div>
                        <dl class="help-list">
                            <dt>📌 Pin / Unpin</dt>
                            <dd>Pin this channel to the top of your sidebar for quick access.</dd>
                            <dt>🔔 Mute / 🔇 Muted</dt>
                            <dd>Mute or unmute notifications for this channel. Muted channels won't show toast notifications.</dd>
                            <dt>🗄️ Archive</dt>
                            <dd>Hide this channel from the sidebar. Messages are preserved and it can be restored later.</dd>
                            <dt>✏️ Edit</dt>
                            <dd>Change the channel name, topic, and settings.</dd>
                            <dt>🔍 Search</dt>
                            <dd>Search through messages in this channel.</dd>
                            <dt>👥 Add People</dt>
                            <dd>Add more users to a DM or group conversation.</dd>
                            <dt>� Call / 📹 Video</dt>
                            <dd>Start an audio or video call with channel members.</dd>
                            <dt>📋 Calls</dt>
                            <dd>View the call history for this channel.</dd>
                            <dt>�👤 Members</dt>
                            <dd>View who's in this channel and manage membership.</dd>
                            <dt>Leave</dt>
                            <dd>Leave this channel. You can rejoin later.</dd>
                        </dl>
                    </div>
                }
            </div>
        </div>
    }
    else
    {
        <div class="channel-info">
            <h2 class="channel-name">Select a channel</h2>
        </div>
    }
</div>
