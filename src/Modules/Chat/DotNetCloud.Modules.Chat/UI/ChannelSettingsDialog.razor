@namespace DotNetCloud.Modules.Chat.UI

@*
    Channel settings dialog — edit channel metadata, manage members, notifications, archive/delete.
    Code-behind: ChannelSettingsDialog.razor.cs
*@

@if (IsVisible)
{
    <div class="dialog-overlay" @onclick="Close">
        <div class="dialog channel-settings-dialog" @onclick:stopPropagation="true">
            <div class="dialog-header">
                <h2>Channel Settings</h2>
                <button class="btn btn-sm" @onclick="Close">✕</button>
            </div>

            <div class="dialog-body">
                <div class="settings-section">
                    <label>Channel Name</label>
                    <input type="text" @bind="EditName" />
                </div>

                <div class="settings-section">
                    <label>Topic</label>
                    <input type="text" @bind="EditTopic" placeholder="Set a topic" />
                </div>

                <div class="settings-section">
                    <label>Description</label>
                    <textarea @bind="EditDescription" rows="3" placeholder="Describe this channel"></textarea>
                </div>

                <div class="settings-section">
                    <label>Notifications</label>
                    <select @bind="NotificationPref">
                        <option value="All">All messages</option>
                        <option value="Mentions">Mentions only</option>
                        <option value="None">None</option>
                    </select>
                </div>

                <div class="settings-section">
                    <label>Members</label>
                    <div class="member-management-list">
                        @foreach (var member in Members)
                        {
                            <div class="member-row">
                                <span>@member.DisplayName</span>
                                <select value="@member.Role" @onchange="(e) => ChangeMemberRole(member.UserId, e.Value?.ToString())">
                                    <option value="Owner">Owner</option>
                                    <option value="Admin">Admin</option>
                                    <option value="Member">Member</option>
                                </select>
                                @if (member.Role != "Owner")
                                {
                                    <button class="btn btn-sm btn-danger" @onclick="() => RemoveMember(member.UserId)">Remove</button>
                                }
                            </div>
                        }
                    </div>

                    <div class="add-member-row">
                        <input type="text" @bind="NewMemberIdInput" placeholder="User ID to add" />
                        <button class="btn btn-sm" @onclick="AddMember">Add Member</button>
                    </div>
                </div>

                <div class="settings-section channel-metadata">
                    <label>Channel Metadata</label>
                    <div>Created: @CreatedAt.ToString("yyyy-MM-dd HH:mm") UTC</div>
                    <div>Creator: @CreatedByDisplayName</div>
                </div>

                <div class="settings-actions">
                    <button class="btn btn-primary" @onclick="SaveChanges">Save</button>
                    <button class="btn btn-warning" @onclick="ArchiveChannel">Archive</button>
                    <button class="btn btn-danger" @onclick="DeleteChannel">Delete</button>
                </div>
            </div>
        </div>
    </div>
}
