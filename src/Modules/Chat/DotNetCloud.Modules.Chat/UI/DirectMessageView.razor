@namespace DotNetCloud.Modules.Chat.UI

@*
    Direct message view — a streamlined chat view for 1:1 or small group conversations.
    Code-behind: DirectMessageView.razor.cs
*@

<div class="chat-dm-view">

    @* ── Header ───────────────────────────────────────────────── *@
    <div class="dm-header">
        @if (OtherUser is not null)
        {
            <div class="dm-header-user">
                <div class="dm-avatar-wrapper">
                    @if (!string.IsNullOrEmpty(OtherUser.AvatarUrl))
                    {
                        <img class="dm-avatar" src="@OtherUser.AvatarUrl" alt="@OtherUser.DisplayName" />
                    }
                    else
                    {
                        <span class="avatar-placeholder">@GetInitials(OtherUser.DisplayName)</span>
                    }
                    <span class="status-dot @(OtherUser.Status == "Online" ? "online" : "offline")"
                          title="@OtherUser.Status"></span>
                </div>
                <div class="dm-user-info">
                    <span class="dm-user-name">
                        @OtherUser.DisplayName
                        @if (IsGroupConversation)
                        {
                            <span class="dm-group-badge">· @EffectiveMemberCount members</span>
                        }
                    </span>
                    <span class="dm-user-status">@OtherUser.Status</span>
                </div>
            </div>
            <div class="dm-header-actions">
                @if (OtherUser is not null)
                {
                    <button class="dm-action-btn @(IsAddPeoplePickerVisible ? "active" : "")"
                            @onclick="ToggleAddPeoplePicker"
                            title="Add people to this conversation"
                            aria-label="Add people">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                             stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" />
                            <circle cx="8.5" cy="7" r="4" />
                            <line x1="20" y1="8" x2="20" y2="14" />
                            <line x1="23" y1="11" x2="17" y2="11" />
                        </svg>
                    </button>
                }
                <button class="dm-action-btn @(IsDmSearchVisible ? "active" : "")"
                        @onclick="ToggleDmSearch"
                        title="New direct message"
                        aria-label="New direct message">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                         stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z" />
                        <line x1="12" y1="8" x2="12" y2="14" />
                        <line x1="9" y1="11" x2="15" y2="11" />
                    </svg>
                </button>
            </div>
        }
        else
        {
            <div class="dm-header-empty-title">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                     stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z" />
                </svg>
                <span>New Direct Message</span>
            </div>
        }
    </div>

    @* ── New DM search panel ──────────────────────────────────── *@
    @if (IsDmSearchVisible)
    {
        <div class="dm-search-panel">
            <div class="dm-search-label">
                <span>@(OtherUser is not null ? "Start a new conversation" : "Who would you like to message?")</span>
                @if (OtherUser is not null)
                {
                    <button class="dm-search-close" @onclick="ToggleDmSearch" aria-label="Close search">✕</button>
                }
            </div>
            <div class="dm-search-input-wrapper">
                <svg class="dm-search-icon" width="14" height="14" viewBox="0 0 24 24" fill="none"
                     stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="11" cy="11" r="8" />
                    <line x1="21" y1="21" x2="16.65" y2="16.65" />
                </svg>
                <input type="text"
                       class="dm-search-input"
                       placeholder="Search by name or username…"
                       @bind="DmUserSearchQuery"
                       @bind:event="oninput"
                       aria-label="Search users for a direct message" />
            </div>

            @if (!string.IsNullOrWhiteSpace(DmSearchError))
            {
                <div class="dm-search-error">@DmSearchError</div>
            }

            @if (FilteredDmUserSuggestions.Count > 0)
            {
                <div class="dm-search-results">
                    @foreach (var user in FilteredDmUserSuggestions)
                    {
                        <button type="button"
                                class="dm-search-result-item"
                                disabled="@IsCreatingDm"
                                title="Message @user.DisplayName"
                                @onclick="() => SelectDmUserAsync(user)">
                            <span class="dm-result-avatar">@GetInitials(user.DisplayName)</span>
                            <span class="dm-result-body">
                                <span class="dm-result-name">@user.DisplayName</span>
                                @if (!string.IsNullOrWhiteSpace(user.Username))
                                {
                                    <span class="dm-result-username">@("@" + user.Username)</span>
                                }
                            </span>
                            <svg class="dm-result-arrow" width="14" height="14" viewBox="0 0 24 24"
                                 fill="none" stroke="currentColor" stroke-width="2.5"
                                 stroke-linecap="round" stroke-linejoin="round">
                                <polyline points="9 18 15 12 9 6" />
                            </svg>
                        </button>
                    }
                </div>
            }
            else if (!string.IsNullOrWhiteSpace(DmUserSearchQuery))
            {
                <p class="dm-search-empty">No users found matching "<strong>@DmUserSearchQuery</strong>"</p>
            }
        </div>
    }

    @* ── Add people panel ─────────────────────────────────────── *@
    @if (IsAddPeoplePickerVisible && OtherUser is not null)
    {
        <div class="dm-search-panel">
            <div class="dm-search-label">
                <span>Add people to this conversation</span>
                <button class="dm-search-close" @onclick="ToggleAddPeoplePicker" aria-label="Close">✕</button>
            </div>
            <div class="dm-search-input-wrapper">
                <svg class="dm-search-icon" width="14" height="14" viewBox="0 0 24 24" fill="none"
                     stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="11" cy="11" r="8" />
                    <line x1="21" y1="21" x2="16.65" y2="16.65" />
                </svg>
                <input type="text"
                       class="dm-search-input"
                       placeholder="Search by name or username…"
                       @bind="AddPeopleSearchQuery"
                       @bind:event="oninput"
                       aria-label="Search people to add to the direct message" />
            </div>

            @if (!string.IsNullOrWhiteSpace(AddPeopleError))
            {
                <div class="dm-search-error">@AddPeopleError</div>
            }

            @if (FilteredAddPeopleSuggestions.Count > 0)
            {
                <div class="dm-search-results">
                    @foreach (var user in FilteredAddPeopleSuggestions)
                    {
                        <button type="button"
                                class="dm-search-result-item"
                                disabled="@IsAddingMember"
                                title="Add @user.DisplayName to this conversation"
                                @onclick="() => AddGroupMemberAsync(user)">
                            <span class="dm-result-avatar">@GetInitials(user.DisplayName)</span>
                            <span class="dm-result-body">
                                <span class="dm-result-name">@user.DisplayName</span>
                                @if (!string.IsNullOrWhiteSpace(user.Username))
                                {
                                    <span class="dm-result-username">@("@" + user.Username)</span>
                                }
                            </span>
                            <svg class="dm-result-add-icon" width="14" height="14" viewBox="0 0 24 24"
                                 fill="none" stroke="currentColor" stroke-width="2.5"
                                 stroke-linecap="round" stroke-linejoin="round">
                                <line x1="12" y1="5" x2="12" y2="19" />
                                <line x1="5" y1="12" x2="19" y2="12" />
                            </svg>
                        </button>
                    }
                </div>
            }
            else if (!string.IsNullOrWhiteSpace(AddPeopleSearchQuery))
            {
                <p class="dm-search-empty">No users found matching "<strong>@AddPeopleSearchQuery</strong>"</p>
            }
        </div>
    }

    @* ── Messages / empty state ───────────────────────────────── *@
    @if (OtherUser is not null)
    {
        <div class="dm-messages">
            <MessageList Messages="@Messages"
                         IsLoading="@IsLoading"
                         ErrorMessage="@MessageError"
                         HasMoreMessages="@HasMoreMessages"
                         TypingUsers="@TypingUsers"
                         OnLoadMore="@OnLoadMore"
                         OnReactionToggle="@OnReactionToggle" />
        </div>

        <div class="dm-composer">
            <MessageComposer ChannelName="@OtherUser.DisplayName"
                             MentionSuggestions="@ComposerMentionSuggestions"
                             ReplyToMessage="@ReplyToMessage"
                             OnSend="@OnSend"
                             OnCancelReply="@OnCancelReply"
                             OnTyping="@OnTyping"
                             OnAttach="@OnAttach"
                             OnPasteImage="@OnPasteImage" />
        </div>
    }
    else
    {
        <div class="dm-empty-state">
            <div class="dm-empty-icon">
                <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                     stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z" />
                </svg>
            </div>
            <p class="dm-empty-heading">Send a direct message</p>
            <p class="dm-empty-subtext">Search for someone above to start a private conversation.</p>
        </div>
    }

</div>
