@namespace DotNetCloud.Modules.Chat.UI

@*
    Call controls toolbar - Mute, camera, screen share, hang up, participant count, timer.
    Code-behind: CallControls.razor.cs
*@

<div class="call-controls">
    <div class="call-controls-left">
        <span class="call-timer">@FormattedDuration</span>
        <span class="participant-count" title="Participants in call">👥 @ParticipantCount</span>
    </div>

    <div class="call-controls-center">
        <button class="control-btn @(IsMuted ? "control-active" : "")"
                @onclick="HandleToggleMute"
                title="@(IsMuted ? "Unmute microphone" : "Mute microphone")"
                disabled="@IsDisabled">
            <span class="control-icon">@(IsMuted ? "🔇" : "🎤")</span>
            <span class="control-label">@(IsMuted ? "Unmute" : "Mute")</span>
        </button>

        <button class="control-btn @(IsCameraOff ? "control-active" : "")"
                @onclick="HandleToggleCamera"
                title="@(IsCameraOff ? "Turn on camera" : "Turn off camera")"
                disabled="@IsDisabled">
            <span class="control-icon">@(IsCameraOff ? "📷" : "📹")</span>
            <span class="control-label">@(IsCameraOff ? "Start Video" : "Stop Video")</span>
        </button>

        @if (IsBlurSupported)
        {
            <div class="blur-control-group">
                @* Blur toggle — standalone button *@
                <button class="control-btn @(IsBackgroundBlurred ? "control-active blur-active" : "")"
                        @onclick="HandleToggleBackgroundBlur"
                        title="@(IsBackgroundBlurred ? "Disable background blur" : "Enable background blur")"
                        disabled="@IsDisabled">
                    <span class="control-icon">🔲</span>
                    <span class="control-label">@(IsBackgroundBlurred ? "Blur On" : "Blur")</span>
                </button>

                @* Blur intensity slider — shown directly below blur button when blur is active *@
                @if (IsBackgroundBlurred)
                {
                    <div class="blur-inline-slider" @onclick:stopPropagation="true">
                        <input type="range"
                               class="blur-slider"
                               min="1" max="50" step="1"
                               value="@BlurIntensity"
                               disabled="@IsDisabled"
                               @oninput="HandleBlurIntensityInput" />
                        <span class="blur-value">@(BlurIntensity)px</span>
                    </div>
                }
            </div>

            @* Effects button — opens virtual background picker *@
            <button class="control-btn @(HasVirtualBackground ? "control-active vbg-active" : "") @(_showEffectsPanel ? "control-active" : "")"
                    @onclick="ToggleEffectsPanel"
                    title="Video effects settings"
                    disabled="@IsDisabled">
                <span class="control-icon">🖼️</span>
                <span class="control-label">Effects</span>
            </button>

            @if (_showEffectsPanel)
            {
                <div class="effects-panel" @onclick:stopPropagation="true">
                    <div class="effects-panel-header">Video Effects</div>

                    <div class="effects-section">
                        <div class="effects-section-label">Virtual Background</div>
                        <div class="vbg-grid">
                            <button class="vbg-option @(ActiveVirtualBackgroundUrl is null && !HasVirtualBackground ? "vbg-selected" : "")"
                                    @onclick="HandleClearVirtualBackground"
                                    disabled="@IsDisabled"
                                    title="No virtual background">
                                <span class="vbg-option-label">None</span>
                            </button>
                            @foreach (var bg in VirtualBackgrounds)
                            {
                                <button class="vbg-option @(ActiveVirtualBackgroundUrl == bg.Url ? "vbg-selected" : "")"
                                        @onclick="() => HandleSelectVirtualBackground(bg.Url)"
                                        disabled="@IsDisabled"
                                        title="@bg.Name">
                                    @if (!string.IsNullOrEmpty(bg.ThumbnailUrl))
                                    {
                                        <img class="vbg-thumb" src="@bg.ThumbnailUrl" alt="@bg.Name" loading="lazy" />
                                    }
                                    else
                                    {
                                        <span class="vbg-option-label">@bg.Name</span>
                                    }
                                </button>
                            }
                        </div>
                    </div>
                </div>
            }
        }

        <button class="control-btn @(IsScreenSharing ? "control-active screen-share-active" : "")"
                @onclick="HandleToggleScreenShare"
                title="@(IsScreenSharing ? "Stop sharing screen" : "Share your screen")"
                disabled="@IsDisabled">
            <span class="control-icon">🖥️</span>
            <span class="control-label">@(IsScreenSharing ? "Stop Share" : "Share Screen")</span>
        </button>

        @if (CanAddPeople)
        {
            <button class="control-btn"
                    @onclick="HandleAddPeople"
                    title="Invite more people to this call"
                    disabled="@IsDisabled">
                <span class="control-icon">👥</span>
                <span class="control-label">Add People</span>
            </button>
        }

        <button class="control-btn control-hangup"
                @onclick="HandleHangUp"
                title="Leave call"
            disabled="@IsHangUpDisabled">
            <span class="control-icon">📞</span>
            <span class="control-label">Hang Up</span>
        </button>
    </div>

    <div class="call-controls-right">
        @if (!string.IsNullOrEmpty(ConnectionQuality))
        {
            <span class="connection-quality quality-@ConnectionQuality.ToLowerInvariant()" title="Connection quality: @ConnectionQuality">
                @GetQualityIndicator()
            </span>
        }
    </div>
</div>
