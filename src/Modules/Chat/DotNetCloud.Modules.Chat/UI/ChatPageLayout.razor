@namespace DotNetCloud.Modules.Chat.UI

@*
    Chat page layout orchestrator - Composes ChannelList, ChannelHeader,
    MessageList, MessageComposer, MemberListPanel, ChannelSettingsDialog,
    and AnnouncementBanner into a full chat experience.
    Code-behind: ChatPageLayout.razor.cs
*@

<div class="chat-layout">
    <div class="chat-sidebar">
        <ChannelList Channels="@_channels"
                     IsLoading="@_isLoadingChannels"
                     ErrorMessage="@_channelErrorMessage"
                     OnChannelSelected="@HandleChannelSelected"
                     OnCreateChannel="@HandleCreateChannel"
                     OnChannelReordered="@HandleChannelReordered"
                     OnNewDm="@HandleOpenDmUserPicker" />
    </div>

    <div class="chat-main">
        @if (_activeAnnouncement is not null)
        {
            <AnnouncementBanner Announcement="@_activeAnnouncement"
                                IsAcknowledged="false"
                                OnAcknowledge="@HandleAcknowledgeAnnouncement"
                                OnDismiss="@HandleDismissAnnouncement" />
        }

        <ChannelHeader Channel="@_selectedChannel"
                       IsAdminOrOwner="@_currentUserIsAdminOrOwner"
                       HasActiveCall="@_hasActiveCall"
                       OnPinChanged="@HandlePinChanged"
                       OnEditChannel="@HandleEditChannel"
                       OnArchiveChannel="@HandleArchiveChannel"
                       OnLeaveChannel="@HandleLeaveChannel"
                       OnToggleMemberList="@HandleToggleMemberList"
                       OnSearch="@HandleSearch"
                       OnInvite="@HandleOpenInviteDialog"
                       OnAddPeople="@HandleOpenChannelAddPeoplePicker"
                       OnAudioCall="@HandleStartAudioCall"
                       OnVideoCall="@HandleStartVideoCall"
                       OnJoinCall="@HandleJoinActiveCall"
                       OnCallHistory="@HandleToggleCallHistory" />

        @if (_isSearchOpen && _selectedChannel is not null)
        {
            <div class="chat-search-panel">
                <div class="search-input-row">
                    <input type="text" class="search-input" placeholder="Search messages..." @bind="_searchQuery" @bind:event="oninput" />
                    <button class="btn btn-sm btn-primary" @onclick="() => HandleSearchSubmit(_searchQuery)">Search</button>
                    <button class="btn btn-sm" @onclick="HandleCloseSearch" title="Close search">✕</button>
                </div>
                @if (_isSearching)
                {
                    <div class="search-loading">Searching...</div>
                }
                else if (_searchResults.Count > 0)
                {
                    <div class="search-results">
                        @foreach (var result in _searchResults)
                        {
                            <div class="search-result-item" @onclick="() => HandleChannelSelected(_selectedChannel)">
                                <span class="search-result-sender">@result.SenderName</span>
                                <span class="search-result-time">@result.SentAt.ToString("MMM d, HH:mm")</span>
                                <div class="search-result-content">@result.Content</div>
                            </div>
                        }
                    </div>
                }
                else if (!string.IsNullOrEmpty(_searchQuery))
                {
                    <div class="search-empty">No results found.</div>
                }
            </div>
        }

        <div class="chat-content-area">
            <div class="chat-messages-wrapper">
                <MessageList Messages="@_messages"
                             IsLoading="@_isLoadingMessages"
                             ErrorMessage="@_messageErrorMessage"
                             HasMoreMessages="@_hasMoreMessages"
                             TypingUsers="@_typingUsers"
                             ChannelSelected="@(_selectedChannel is not null)"
                             CurrentUserId="@_currentUserId"
                             EditingMessage="@_editingMessage"
                             OnLoadMore="@HandleLoadMoreMessages"
                             OnReactionToggle="@HandleReactionToggle"
                             OnEditMessage="@HandleStartEditMessage"
                             OnDeleteMessage="@HandleDeleteMessage"
                             OnReplyToMessage="@HandleReplyToMessage" />

                @if (_selectedChannel is not null)
                {
                    <MessageComposer ChannelName="@_selectedChannel.Name"
                                     ChannelType="@_selectedChannel.Type"
                                     ReplyToMessage="@_replyToMessage"
                                     EditingMessage="@_editingMessage"
                                     MentionSuggestions="@_memberSuggestions"
                                     OnSend="@HandleSendMessage"
                                     OnEditSend="@HandleEditMessage"
                                     OnCancelReply="@HandleCancelReply"
                                     OnCancelEdit="@HandleCancelEditMessage"
                                     OnTyping="@HandleTyping"
                                     OnAttach="@HandleAttach" />
                }
            </div>

            @if (_showMemberPanel)
            {
                <MemberListPanel Members="@_members"
                                 CanManageMembers="@_currentUserIsAdminOrOwner"
                                 CurrentUserId="@_currentUserId"
                                 OnClose="@HandleCloseMemberPanel"
                                 OnPromoteMember="@HandlePromoteMember"
                                 OnDemoteMember="@HandleDemoteMember"
                                 OnRemoveMember="@HandleRemoveMember"
                                 OnAddPeople="@HandleOpenChannelAddPeoplePicker"
                                 OnAudioCallUser="@HandleAudioCallUser"
                                 OnVideoCallUser="@HandleVideoCallUser" />
            }

            @if (_showCallHistoryPanel)
            {
                <CallHistoryPanel Calls="@_callHistory"
                                  IsLoading="@_isLoadingCallHistory"
                                  IsLoadingMore="@_isLoadingMoreCallHistory"
                                  HasMore="@_hasMoreCallHistory"
                                  OnClose="@HandleCloseCallHistory"
                                  OnLoadMore="@HandleLoadMoreCallHistory"
                                  OnCallBack="@HandleCallBack" />
            }
        </div>
    </div>
</div>

@if (_showSettingsDialog && _selectedChannel is not null)
{
    <ChannelSettingsDialog IsVisible="@_showSettingsDialog"
                           Channel="@_selectedChannel"
                           Members="@_members"
                           CanManageChannel="@_currentUserIsAdminOrOwner"
                           OnSave="@HandleSaveChannelSettings"
                           OnNotificationPrefChanged="@HandleNotificationPrefChanged"
                           OnArchive="@(() => HandleArchiveChannel(_selectedChannel))"
                           OnDelete="@HandleDeleteChannel"
                           OnClose="@HandleCloseSettingsDialog"
                           OnAddMember="@HandleAddMember"
                           OnRemoveMember="@HandleRemoveMember"
                           OnChangeMemberRole="@HandleChangeMemberRole" />
}

@if (_showAnnouncementEditor)
{
    <AnnouncementEditor IsVisible="@_showAnnouncementEditor"
                        IsEditing="@_isEditingAnnouncement"
                        OnSave="@HandleSaveAnnouncement"
                        OnCancel="@HandleCloseAnnouncementEditor" />
}

@if (_showInviteDialog && _selectedChannel is not null)
{
    <div class="dialog-overlay" @onclick="HandleCloseInviteDialog">
        <div class="dialog invite-dialog" @onclick:stopPropagation="true">
            <div class="dialog-header">
                <h2>Invite to #@_selectedChannel.Name</h2>
                <button class="btn btn-sm" @onclick="HandleCloseInviteDialog">✕</button>
            </div>
            <div class="dialog-body">
                <div class="settings-section">
                    <label>Username</label>
                    <input type="text" @bind="_inviteUsername" placeholder="Enter username" disabled="@_isInviting" />
                </div>
                <div class="settings-section">
                    <label>Message (optional)</label>
                    <input type="text" @bind="_inviteMessage" placeholder="Add a note to your invite" disabled="@_isInviting" />
                </div>

                @if (_inviteErrorMessage is not null)
                {
                    <div class="invite-feedback error">@_inviteErrorMessage</div>
                }
                @if (_inviteSuccessMessage is not null)
                {
                    <div class="invite-feedback success">@_inviteSuccessMessage</div>
                }

                <div class="settings-actions">
                    <button class="btn btn-primary" @onclick="HandleSendInvite" disabled="@(_isInviting || string.IsNullOrWhiteSpace(_inviteUsername))">
                        @(_isInviting ? "Sending..." : "Send Invite")
                    </button>
                    <button class="btn" @onclick="HandleCloseInviteDialog">Cancel</button>
                </div>
            </div>
        </div>
    </div>
}

@if (_showDmUserPicker)
{
    <div class="dialog-overlay" @onclick="HandleCloseDmUserPicker">
        <div class="dialog dm-user-picker-dialog" @onclick:stopPropagation="true">
            <div class="dialog-header">
                <h2>New Direct Message</h2>
                <button class="btn btn-sm" @onclick="HandleCloseDmUserPicker">✕</button>
            </div>
            <div class="dialog-body">
                <div class="settings-section">
                    <label>Search users</label>
                    <input type="text"
                           @bind="_dmSearchTerm"
                           @bind:event="oninput"
                           @bind:after="() => SearchUsersForDmAsync(_dmSearchTerm)"
                           placeholder="Search by name or email..."
                           class="search-input" />
                </div>

                @if (_isDmSearching)
                {
                    <div class="search-loading">Searching...</div>
                }
                else if (_dmSearchResults.Count > 0)
                {
                    <div class="dm-user-results">
                        @foreach (var user in _dmSearchResults)
                        {
                            <div class="dm-user-result-item" @onclick="() => StartDmWithUserAsync(user.UserId)">
                                <div class="dm-user-info">
                                    <span class="dm-user-name">@user.DisplayName</span>
                                    <span class="dm-user-email">@user.Email</span>
                                </div>
                                <div class="dm-user-actions">
                                    <button class="btn btn-sm btn-icon" title="Audio call"
                                            @onclick="@(() => CallUserDirectlyAsync(user.UserId, "Audio"))"
                                            @onclick:stopPropagation="true">📞</button>
                                    <button class="btn btn-sm btn-icon" title="Video call"
                                            @onclick="@(() => CallUserDirectlyAsync(user.UserId, "Video"))"
                                            @onclick:stopPropagation="true">📹</button>
                                </div>
                            </div>
                        }
                    </div>
                }
                else if (!string.IsNullOrWhiteSpace(_dmSearchTerm))
                {
                    <div class="search-empty">No users found.</div>
                }
            </div>
        </div>
    </div>
}

@if (_showChannelAddPeoplePicker && _selectedChannel is not null)
{
    <div class="dialog-overlay" @onclick="HandleCloseChannelAddPeoplePicker">
        <div class="dialog dm-user-picker-dialog" @onclick:stopPropagation="true">
            <div class="dialog-header">
                <h2>Add People to @_selectedChannel.Name</h2>
                <button class="btn btn-sm" @onclick="HandleCloseChannelAddPeoplePicker">✕</button>
            </div>
            <div class="dialog-body">
                <div class="settings-section">
                    <label>Search users</label>
                    <input type="text"
                           @bind="_channelAddPeopleSearchTerm"
                           @bind:event="oninput"
                           @bind:after="() => SearchUsersForChannelAddAsync(_channelAddPeopleSearchTerm)"
                           placeholder="Search by name or email..."
                           class="search-input" />
                </div>

                @if (_isChannelAddPeopleSearching)
                {
                    <div class="search-loading">Searching...</div>
                }
                else if (_channelAddPeopleResults.Count > 0)
                {
                    <div class="dm-user-results">
                        @foreach (var user in _channelAddPeopleResults)
                        {
                            <div class="dm-user-result-item" @onclick="() => AddUserToCurrentChannelAsync(user.UserId)">
                                <div class="dm-user-info">
                                    <span class="dm-user-name">@user.DisplayName</span>
                                    <span class="dm-user-email">@user.Email</span>
                                </div>
                                <div class="dm-user-actions">
                                    <button class="btn btn-sm btn-primary">Add</button>
                                </div>
                            </div>
                        }
                    </div>
                }
                else if (!string.IsNullOrWhiteSpace(_channelAddPeopleSearchTerm))
                {
                    <div class="search-empty">No matching users to add.</div>
                }
            </div>
        </div>
    </div>
}

<VideoCallDialog IsVisible="@_showVideoCallDialog"
                 ChannelName="@(_selectedChannel?.Name ?? "")"
                 CallState="@_currentCallState"
                 LocalDisplayName="@_currentUserDisplayName"
                 LocalAvatarUrl="@(_avatarUrlCache.GetValueOrDefault(_currentUserId))"
                 CurrentUserId="@_currentUserId"
                 HostUserId="@(_currentCallHostUserId ?? Guid.Empty)"
                 RemoteParticipants="@_remoteParticipants"
                 IsMuted="@_isCallMuted"
                 IsCameraOff="@_isCallCameraOff"
                 IsScreenSharing="@_isCallScreenSharing"
                 DurationSeconds="@_callDurationSeconds"
                 ConnectionQuality="@_callConnectionQuality"
                 ShowAddPeoplePicker="@_showCallAddPeoplePicker"
                 AddPeopleSearchTerm="@_callAddPeopleSearchTerm"
                 IsAddPeopleSearching="@_isCallAddPeopleSearching"
                 AddPeopleSearchResults="@_callAddPeopleResults"
                 OnToggleMute="@HandleCallToggleMute"
                 OnToggleCamera="@HandleCallToggleCamera"
                 OnToggleScreenShare="@HandleCallToggleScreenShare"
                 OnAddPeople="@HandleOpenCallAddPeoplePicker"
                 OnCloseAddPeoplePicker="@HandleCloseCallAddPeoplePicker"
                 OnAddPeopleSearchChanged="@SearchUsersForCallAddAsync"
                 OnInviteToCall="@InviteUserToCurrentCallAsync"
                 OnTransferHost="@TransferHostAsync"
                 OnHangUp="@HandleCallHangUp"
                 OnMinimize="@HandleCallMinimize"
                 OnPipClick="@HandleCallPipClick" />

<IncomingCallNotification IsVisible="@_showIncomingCall"
                          CallerName="@_incomingCallerName"
                          CallerAvatarUrl="@(_incomingCallInitiatorId.HasValue ? _avatarUrlCache.GetValueOrDefault(_incomingCallInitiatorId.Value) : null)"
                          ChannelName="@_incomingCallChannelName"
                          MediaType="@_incomingCallMediaType"
                          RemainingSeconds="@_incomingCallRemainingSeconds"
                          IsRinging="@_isIncomingCallRinging"
                          IsMidCallInvite="@_incomingIsMidCallInvite"
                          ParticipantCount="@_incomingCallParticipantCount"
                          OnAcceptVideo="@HandleAcceptCallVideo"
                          OnAcceptAudio="@HandleAcceptCallAudio"
                          OnReject="@HandleRejectCall" />
