@namespace DotNetCloud.Modules.Chat.UI

@*
    Message list - Displays messages in the selected channel with reactions and attachments.
    Code-behind: MessageList.razor.cs
*@

<div class="chat-message-list" @ref="MessageListRef">
    @if (IsLoading)
    {
        <div class="loading-state" role="status" aria-live="polite">
            <p>Loading messages...</p>
        </div>
    }
    else if (!string.IsNullOrWhiteSpace(ErrorMessage))
    {
        <div class="error-state" role="alert">
            <p>Unable to load messages right now.</p>
            <p class="text-muted">@ErrorMessage</p>
        </div>
    }
    else if (Messages.Count == 0)
    {
        <div class="empty-state">
            @if (ChannelSelected)
            {
                <p>No messages yet.</p>
                <p class="text-muted">Start the conversation by sending the first message.</p>
            }
            else
            {
                <p>Select a channel</p>
                <p class="text-muted">Choose a channel from the sidebar to start chatting.</p>
            }
        </div>
    }
    else
    {
        @* Sentinel element: IntersectionObserver watches this to trigger loading older messages *@
        @if (HasMoreMessages || IsLoadingMore)
        {
            <div id="scroll-sentinel" class="scroll-sentinel"></div>
        }

        @if (IsLoadingMore)
        {
            <div class="loading-more" role="status" aria-live="polite">
                <span class="loading-more-spinner"></span>
                <span class="loading-more-text">Loading older messages…</span>
            </div>
        }

        @foreach (var message in Messages)
        {
            if (NewMessagesStartMessageId.HasValue && message.Id == NewMessagesStartMessageId.Value)
            {
                <div class="new-messages-divider">
                    <span>New messages</span>
                </div>
            }

            <div class="message-item @(message.Type == "System" ? "system-message" : "")">
                @if (message.Type == "System")
                {
                    <div class="system-content">@message.Content</div>
                }
                else
                {
                    <div class="message-avatar">
                        @if (!string.IsNullOrEmpty(message.SenderAvatarUrl))
                        {
                            <img src="@message.SenderAvatarUrl" alt="@message.SenderName" />
                        }
                        else
                        {
                            <span class="avatar-placeholder">@GetInitials(message.SenderName)</span>
                        }
                    </div>

                    <div class="message-body">
                        <div class="message-header">
                            <span class="sender-name">@message.SenderName</span>
                            <span class="message-time">@FormatTime(message.SentAt)</span>
                            @if (message.IsEdited)
                            {
                                <span class="edited-indicator">(edited)</span>
                            }

                            <div class="message-actions">
                                <button class="msg-action-btn" @onclick="() => RequestReply(message)" title="Reply">↩</button>
                                @if (message.Attachments.Count > 0)
                                {
                                    <a class="msg-action-btn msg-action-download"
                                       href="@(message.Attachments[0].ThumbnailUrl ?? string.Empty)"
                                       download="@message.Attachments[0].FileName"
                                       title="Download @message.Attachments[0].FileName">⬇</a>
                                }
                                @if (message.SenderUserId == CurrentUserId)
                                {
                                    <button class="msg-action-btn" @onclick="() => RequestEdit(message)" title="Edit">✏️</button>
                                    <button class="msg-action-btn msg-action-danger" @onclick="() => RequestDelete(message.Id)" title="Delete">🗑️</button>
                                }
                            </div>
                        </div>

                        @if (message.ReplyToMessageId.HasValue)
                        {
                            <div class="reply-indicator">
                                <span>↩ Reply</span>
                            </div>
                        }

                        <div class="message-content">@RenderMarkdown(message.Content)</div>

                        @if (message.Attachments.Count > 0)
                        {
                            <div class="message-attachments">
                                @foreach (var attachment in message.Attachments)
                                {
                                    <div class="attachment-item">
                                        <span class="attachment-icon">📎</span>
                                        <span class="attachment-name">@attachment.FileName</span>
                                        <span class="attachment-size">@FormatSize(attachment.FileSize)</span>
                                    </div>

                                    @if (IsInlinePreviewAttachment(attachment))
                                    {
                                        <div class="attachment-preview">
                                            @if (attachment.MimeType.StartsWith("image/", StringComparison.OrdinalIgnoreCase))
                                            {
                                                <img src="@(attachment.ThumbnailUrl ?? string.Empty)"
                                                     alt="@attachment.FileName"
                                                     class="image-preview"
                                                     @onclick="() => OpenImageLightbox(attachment.ThumbnailUrl ?? string.Empty, attachment.FileName)" />
                                            }
                                            else if (attachment.MimeType.Contains("pdf", StringComparison.OrdinalIgnoreCase))
                                            {
                                                <div class="document-preview">PDF preview available</div>
                                            }
                                            else
                                            {
                                                <div class="document-preview">Inline text preview available</div>
                                            }
                                        </div>
                                    }
                                }
                            </div>
                        }

                        @if (message.Reactions.Count > 0)
                        {
                            <div class="message-reactions">
                                @foreach (var reaction in message.Reactions)
                                {
                                    <button class="reaction-badge @(reaction.HasReacted ? "reacted" : "")"
                                            title="Toggle reaction @reaction.Emoji"
                                            aria-label="Toggle reaction @reaction.Emoji"
                                            @onclick="() => ToggleReaction(message.Id, reaction.Emoji)">
                                        @reaction.Emoji @reaction.Count
                                    </button>
                                }
                            </div>
                        }
                    </div>
                }
            </div>
        }
    }

    @if (TypingUsers.Count > 0)
    {
        <div class="typing-indicator">
            @GetTypingText()
        </div>
    }

    @if (_lightboxOpen)
    {
        <div class="chat-lightbox-overlay" @onclick="CloseLightbox">
            <div class="chat-lightbox-content" @onclick:stopPropagation="true">
                <button class="chat-lightbox-close" @onclick="CloseLightbox" title="Close" aria-label="Close">✕</button>
                <img src="@_lightboxImageUrl" alt="@_lightboxImageAlt" class="chat-lightbox-image" />
                @if (!string.IsNullOrEmpty(_lightboxImageAlt))
                {
                    <div class="chat-lightbox-caption">@_lightboxImageAlt</div>
                }
            </div>
        </div>
    }
</div>
