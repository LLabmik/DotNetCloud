@namespace DotNetCloud.Modules.Chat.UI

@*
    Message composer - Input area for composing and sending chat messages.
    Supports reply-to, file attachments, emoji, and @mention autocomplete.
    Code-behind: MessageComposer.razor.cs
*@

<div class="chat-message-composer">
    <div class="composer-toolbar" role="toolbar" aria-label="Formatting toolbar">
        <button class="btn btn-sm composer-fmt" @onclick='() => ApplyFormatAsync("**", "**")' title="Bold (Ctrl+B)"><strong>B</strong></button>
        <button class="btn btn-sm composer-fmt" @onclick='() => ApplyFormatAsync("_", "_")' title="Italic (Ctrl+I)"><em>I</em></button>
        <button class="btn btn-sm composer-fmt" @onclick='() => ApplyFormatAsync("`", "`")' title="Inline code"><code>` `</code></button>
        <button class="btn btn-sm composer-fmt" @onclick='() => ApplyFormatAsync("[" , "](url)")' title="Link">🔗</button>
    </div>

    @if (ReplyToMessage is not null)
    {
        <div class="reply-preview">
            <span class="reply-label">Replying to <strong>@ReplyToMessage.SenderName</strong></span>
            <span class="reply-content">@TruncateContent(ReplyToMessage.Content)</span>
            <button class="btn-close" @onclick="CancelReply" title="Cancel reply">✕</button>
        </div>
    }

    <div class="composer-input-row">
        <button class="btn btn-sm composer-action" @onclick="OnAttachClick" title="Attach file">
            📎
        </button>

        <div class="composer-input-wrapper">
            <textarea id="@TextareaElementId"
                      class="composer-input"
                      @bind="MessageText"
                      @bind:event="oninput"
                      @onkeydown="HandleKeyDown"
                      placeholder="@GetPlaceholder()"
                      rows="1"></textarea>

            @if (IsMentionDropdownVisible)
            {
                <div class="mention-suggestions list-group" role="listbox" aria-label="Mention suggestions">
                    @foreach (var member in VisibleMentionSuggestions)
                    {
                        <button type="button"
                                class="list-group-item list-group-item-action mention-suggestion"
                                title="Mention @member.DisplayName"
                                @onclick="() => SelectMentionAsync(member)">
                            <span class="mention-suggestion-name">@GetMentionLabel(member)</span>
                            @if (!string.IsNullOrWhiteSpace(member.Username))
                            {
                                <span class="mention-suggestion-username text-muted">@member.Username</span>
                            }
                        </button>
                    }
                </div>
            }
        </div>

        <button class="btn btn-sm composer-action" @onclick="ToggleEmojiPicker" title="Emoji">
            😀
        </button>

        <button class="btn btn-sm btn-primary composer-send"
                @onclick="SendMessage"
                disabled="@IsSendDisabled"
                title="Send message">
            ➤
        </button>
    </div>

    @if (IsShowEmojiPicker)
    {
        <div class="emoji-picker">
            @foreach (var emoji in CommonEmojis)
            {
                <button class="emoji-btn" @onclick="() => InsertEmoji(emoji)">@emoji</button>
            }
        </div>
    }
</div>
