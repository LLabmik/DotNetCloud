@namespace DotNetCloud.Modules.Chat.UI

@*
    Message composer — WYSIWYG rich-text editor for composing chat messages.
    Supports bold, italic, strikethrough, code, links, lists, quotes, headings,
    reply-to, file attachments, emoji, and @mention autocomplete.
    Code-behind: MessageComposer.razor.cs
*@

<div class="chat-message-composer">
    <div class="composer-toolbar" role="toolbar" aria-label="Formatting toolbar">
        @* ── Text formatting ── *@
        <button class="btn btn-sm composer-fmt fmt-bold" @onclick='() => FormatAsync("bold")' title="Bold (Ctrl+B)" aria-label="Bold"><strong>B</strong></button>
        <button class="btn btn-sm composer-fmt fmt-italic" @onclick='() => FormatAsync("italic")' title="Italic (Ctrl+I)" aria-label="Italic"><em>I</em></button>
        <button class="btn btn-sm composer-fmt fmt-strike" @onclick='() => FormatAsync("strikethrough")' title="Strikethrough" aria-label="Strikethrough"><s>S</s></button>
        <span class="toolbar-sep" aria-hidden="true"></span>

        @* ── Code ── *@
        <button class="btn btn-sm composer-fmt fmt-code" @onclick='() => FormatAsync("inlineCode")' title="Inline code" aria-label="Inline code">&lt;/&gt;</button>
        <button class="btn btn-sm composer-fmt fmt-codeblock" @onclick='() => FormatAsync("codeBlock")' title="Code block" aria-label="Code block">{ }</button>
        <span class="toolbar-sep" aria-hidden="true"></span>

        @* ── Link ── *@
        <button class="btn btn-sm composer-fmt fmt-link" @onclick='() => FormatAsync("link")' title="Link (Ctrl+K)" aria-label="Insert link">🔗</button>
        <span class="toolbar-sep" aria-hidden="true"></span>

        @* ── Lists ── *@
        <button class="btn btn-sm composer-fmt fmt-ul" @onclick='() => FormatAsync("bulletList")' title="Bullet list" aria-label="Bullet list">• —</button>
        <button class="btn btn-sm composer-fmt fmt-ol" @onclick='() => FormatAsync("numberedList")' title="Numbered list" aria-label="Numbered list">1.</button>
        <span class="toolbar-sep" aria-hidden="true"></span>

        @* ── Block ── *@
        <button class="btn btn-sm composer-fmt fmt-quote" @onclick='() => FormatAsync("blockquote")' title="Quote" aria-label="Blockquote">❝</button>
        <button class="btn btn-sm composer-fmt fmt-heading" @onclick='() => FormatAsync("heading")' title="Heading" aria-label="Heading"><strong>H</strong></button>
    </div>

    @if (EditingMessage is not null)
    {
        <div class="edit-preview">
            <span class="edit-label">✏️ Editing message</span>
            <span class="edit-content">@TruncateContent(EditingMessage.Content)</span>
            <button class="btn-close" @onclick="CancelEdit" title="Cancel edit">✕</button>
        </div>
    }
    else if (ReplyToMessage is not null)
    {
        <div class="reply-preview">
            <span class="reply-label">Replying to <strong>@ReplyToMessage.SenderName</strong></span>
            <span class="reply-content">@TruncateContent(ReplyToMessage.Content)</span>
            <button class="btn-close" @onclick="CancelReply" title="Cancel reply">✕</button>
        </div>
    }

    <div class="composer-input-row">
        <button class="btn btn-sm composer-action" @onclick="OnAttachClick" title="Attach a file">
            📎
        </button>

        <div class="composer-input-wrapper">
            <div id="@EditorElementId"
                 class="composer-editor"
                 contenteditable="true"
                 role="textbox"
                 aria-multiline="true"
                 aria-label="@GetPlaceholder()"
                 data-placeholder="@GetPlaceholder()">
            </div>

            @if (IsMentionDropdownVisible)
            {
                <div class="mention-suggestions list-group" role="listbox" aria-label="Mention suggestions">
                    @foreach (var member in VisibleMentionSuggestions)
                    {
                        <button type="button"
                                class="list-group-item list-group-item-action mention-suggestion"
                                title="Mention @member.DisplayName"
                                @onclick="() => SelectMentionAsync(member)">
                            <span class="mention-suggestion-name">@GetMentionLabel(member)</span>
                            @if (!string.IsNullOrWhiteSpace(member.Username))
                            {
                                <span class="mention-suggestion-username text-muted">@member.Username</span>
                            }
                        </button>
                    }
                </div>
            }
        </div>

        <button class="btn btn-sm composer-action" @onclick="ToggleEmojiPicker" title="Emoji">
            😀
        </button>

        <button class="btn btn-sm btn-primary composer-send"
                @onclick="SendMessage"
                disabled="@IsSendDisabled"
                title="Send message">
            ➤
        </button>
    </div>

    @if (IsShowEmojiPicker)
    {
        <div class="emoji-picker">
            @foreach (var emoji in CommonEmojis)
            {
                <button class="emoji-btn" @onclick="() => InsertEmoji(emoji)">@emoji</button>
            }
        </div>
    }
</div>
