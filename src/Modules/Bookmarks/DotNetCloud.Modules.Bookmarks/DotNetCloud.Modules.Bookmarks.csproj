<Project Sdk="Microsoft.NET.Sdk.Razor">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>DotNetCloud.Modules.Bookmarks</RootNamespace>
    <AssemblyName>DotNetCloud.Modules.Bookmarks</AssemblyName>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
  </PropertyGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="DotNetCloud.Modules.Bookmarks.Data" />
    <InternalsVisibleTo Include="DotNetCloud.Modules.Bookmarks.Tests" />
  </ItemGroup>

  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\..\Core\DotNetCloud.Core\DotNetCloud.Core.csproj" />
    <ProjectReference Include="..\..\..\UI\DotNetCloud.UI.Shared\DotNetCloud.UI.Shared.csproj" />
  </ItemGroup>

  <!-- Exclude manifest.json from publish: modules are discovered via a separate
       modules/ directory at runtime, not from the server publish output root. -->
  <ItemGroup>
    <Content Remove="manifest.json" />
    <None Include="manifest.json">
      <CopyToOutputDirectory>Never</CopyToOutputDirectory>
      <CopyToPublishDirectory>Never</CopyToPublishDirectory>
    </None>
  </ItemGroup>

</Project>
