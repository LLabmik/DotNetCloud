@namespace DotNetCloud.Modules.Notes.UI

@*
    Notes page layout — main UI entry point for the Notes module.
    Provides note list, folder navigation, search, and note editor.
    Full implementation in a future phase; this is the navigation-registered shell.
*@

<div class="notes-page-layout">
    <div class="notes-sidebar">
        <div class="notes-sidebar-header">
            <h3>Notes</h3>
            <button class="btn btn-sm btn-primary" @onclick="HandleCreateNote" title="New Note">
                <span>＋</span>
            </button>
        </div>
        <div class="notes-search">
            <input type="text" class="form-control form-control-sm"
                   placeholder="Search notes…"
                   @bind="_searchQuery"
                   @bind:event="oninput" />
        </div>
        <nav class="notes-nav">
            <a class="notes-nav-item @(_activeSection == "all" ? "active" : "")"
               @onclick='() => _activeSection = "all"'>
                All Notes
            </a>
            <a class="notes-nav-item @(_activeSection == "folders" ? "active" : "")"
               @onclick='() => _activeSection = "folders"'>
                Folders
            </a>
            <a class="notes-nav-item @(_activeSection == "tags" ? "active" : "")"
               @onclick='() => _activeSection = "tags"'>
                Tags
            </a>
            <a class="notes-nav-item @(_activeSection == "favorites" ? "active" : "")"
               @onclick='() => _activeSection = "favorites"'>
                Favorites
            </a>
            <a class="notes-nav-item @(_activeSection == "shared" ? "active" : "")"
               @onclick='() => _activeSection = "shared"'>
                Shared with Me
            </a>
        </nav>
    </div>
    <div class="notes-main">
        <div class="notes-placeholder">
            <p>Select a note or create a new one to get started.</p>
        </div>
    </div>
</div>

@code {
    private string _searchQuery = string.Empty;
    private string _activeSection = "all";

    private void HandleCreateNote()
    {
        // Placeholder — full implementation in future phase
    }
}
