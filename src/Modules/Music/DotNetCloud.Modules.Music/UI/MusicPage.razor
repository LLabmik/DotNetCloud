@namespace DotNetCloud.Modules.Music.UI

@using DotNetCloud.Core.DTOs
@using DotNetCloud.Core.Authorization
@using DotNetCloud.Modules.Music.Services
@inject IArtistService ArtistService
@inject IMusicAlbumService AlbumService
@inject ITrackService TrackService
@inject Music.Services.IPlaylistService PlaylistService
@inject IPlaybackService PlaybackService
@inject IRecommendationService RecommendationService
@inject IEqPresetService EqPresetService
@inject IMusicStreamingService StreamingService
@inject Microsoft.AspNetCore.Components.Authorization.AuthenticationStateProvider AuthenticationStateProvider
@inject Microsoft.AspNetCore.Components.NavigationManager Navigation
@inject IJSRuntime Js
@inject Microsoft.Extensions.Logging.ILogger<MusicPage> Logger

<div class="music-layout">
    @* ─── Sidebar ─── *@
    <aside class="music-sidebar">
        <div class="music-sidebar-header">
            <h2>Music</h2>
        </div>

        <nav class="music-nav">
            <button class="music-nav-item @(_section == Section.Library ? "active" : "")"
                    @onclick="() => SwitchSection(Section.Library)">
                <span class="nav-icon">🎵</span><span>Library</span>
            </button>
            <button class="music-nav-item @(_section == Section.Artists ? "active" : "")"
                    @onclick="() => SwitchSection(Section.Artists)">
                <span class="nav-icon">🎤</span><span>Artists</span>
            </button>
            <button class="music-nav-item @(_section == Section.Albums ? "active" : "")"
                    @onclick="() => SwitchSection(Section.Albums)">
                <span class="nav-icon">💿</span><span>Albums</span>
            </button>
            <button class="music-nav-item @(_section == Section.Genres ? "active" : "")"
                    @onclick="() => SwitchSection(Section.Genres)">
                <span class="nav-icon">🏷</span><span>Genres</span>
            </button>
        </nav>

        <div class="music-nav-separator"></div>

        <nav class="music-nav">
            <button class="music-nav-item @(_section == Section.Playlists ? "active" : "")"
                    @onclick="() => SwitchSection(Section.Playlists)">
                <span class="nav-icon">📃</span><span>Playlists</span>
            </button>
            <button class="music-nav-item @(_section == Section.Favorites ? "active" : "")"
                    @onclick="() => SwitchSection(Section.Favorites)">
                <span class="nav-icon">⭐</span><span>Favorites</span>
            </button>
            <button class="music-nav-item @(_section == Section.RecentlyPlayed ? "active" : "")"
                    @onclick="() => SwitchSection(Section.RecentlyPlayed)">
                <span class="nav-icon">🕐</span><span>Recently Played</span>
            </button>
        </nav>

        @* Playlists in sidebar *@
        @if (_section == Section.Playlists || _playlists.Count > 0)
        {
            <div class="sidebar-playlist-list">
                <div class="sidebar-playlist-header">
                    <span class="playlist-label">Your Playlists</span>
                    <button class="btn-icon" @onclick="BeginCreatePlaylist" title="New Playlist">+</button>
                </div>
                @foreach (var pl in _playlists)
                {
                    <button class="sidebar-playlist-item @(_selectedPlaylistId == pl.Id ? "active" : "")"
                            @onclick="() => SelectPlaylistAsync(pl.Id)">
                        <span class="playlist-icon">♫</span>
                        <span class="playlist-name">@pl.Name</span>
                        <span class="playlist-count">@pl.TrackCount</span>
                    </button>
                }
            </div>
        }
    </aside>

    @* ─── Main Content ─── *@
    <main class="music-main @(_nowPlaying is not null ? "has-player" : "")">
        @* Toolbar *@
        <div class="music-toolbar">
            <div class="toolbar-left">
                @if (_breadcrumb.Count > 0)
                {
                    @foreach (var crumb in _breadcrumb)
                    {
                        <button class="breadcrumb-item" @onclick="crumb.Action">@crumb.Label</button>
                        <span class="breadcrumb-sep">›</span>
                    }
                }
                <h3 class="section-title">@GetSectionTitle()</h3>
            </div>
            <div class="toolbar-right">
                <div class="search-box">
                    <input type="text" placeholder="Search music…"
                           @bind="_searchQuery" @bind:event="oninput"
                           @onkeyup="HandleSearchKeyUp" />
                </div>
            </div>
        </div>

        @if (_loading)
        {
            <div class="music-loading">
                <div class="loading-spinner"></div>
                <p>Loading…</p>
            </div>
        }
        else if (_errorMessage is not null)
        {
            <div class="music-error">
                <p>@_errorMessage</p>
                <button class="btn-retry" @onclick="LoadCurrentSectionAsync">Retry</button>
            </div>
        }
        else
        {
            @* ─── Library / Recently Played ─── *@
            @if (_section == Section.Library)
            {
                <div class="library-overview">
                    @if (_recentAlbums.Count > 0)
                    {
                        <section class="library-section">
                            <h4>Recently Added Albums</h4>
                            <div class="albums-row">
                                @foreach (var album in _recentAlbums.Take(8))
                                {
                                    <div class="album-card" @onclick="() => OpenAlbumDetail(album)">
                                        <div class="album-art">
                                            @if (album.HasCoverArt)
                                            {
                                                <img src="@GetAlbumArtUrl(album.Id)" alt="@album.Title" loading="lazy" />
                                            }
                                            else
                                            {
                                                <div class="album-art-placeholder">♫</div>
                                            }
                                            <button class="play-overlay" @onclick:stopPropagation="true"
                                                    @onclick="() => PlayAlbumAsync(album.Id)">▶</button>
                                        </div>
                                        <div class="album-card-info">
                                            <span class="album-card-title">@album.Title</span>
                                            <span class="album-card-artist">@album.ArtistName</span>
                                        </div>
                                    </div>
                                }
                            </div>
                        </section>
                    }

                    @if (_newTracks.Count > 0)
                    {
                        <section class="library-section">
                            <h4>New Additions</h4>
                            <div class="track-list">
                                @foreach (var (track, index) in _newTracks.Take(10).Select((t, i) => (t, i)))
                                {
                                    <div class="track-row @(_nowPlaying?.Id == track.Id ? "playing" : "")"
                                         @ondblclick="() => PlayTrackAsync(track)">
                                        <span class="track-num">@(index + 1)</span>
                                        <div class="track-info">
                                            <span class="track-title">@track.Title</span>
                                            <span class="track-artist">@track.ArtistName — @track.AlbumTitle</span>
                                        </div>
                                        <span class="track-duration">@FormatDuration(track.Duration)</span>
                                        <button class="track-action" @onclick="() => ToggleStarTrackAsync(track)" title="Star">
                                            @(track.IsStarred ? "★" : "☆")
                                        </button>
                                    </div>
                                }
                            </div>
                        </section>
                    }

                    @if (_recommendations.Count > 0)
                    {
                        <section class="library-section">
                            <h4>Recommended for You</h4>
                            <div class="track-list">
                                @foreach (var (track, index) in _recommendations.Take(10).Select((t, i) => (t, i)))
                                {
                                    <div class="track-row @(_nowPlaying?.Id == track.Id ? "playing" : "")"
                                         @ondblclick="() => PlayTrackAsync(track)">
                                        <span class="track-num">@(index + 1)</span>
                                        <div class="track-info">
                                            <span class="track-title">@track.Title</span>
                                            <span class="track-artist">@track.ArtistName — @track.AlbumTitle</span>
                                        </div>
                                        <span class="track-duration">@FormatDuration(track.Duration)</span>
                                    </div>
                                }
                            </div>
                        </section>
                    }

                    @if (_recentAlbums.Count == 0 && _newTracks.Count == 0)
                    {
                        <div class="music-empty">
                            <div class="empty-icon">🎵</div>
                            <h4>Your music library is empty</h4>
                            <p>Upload audio files through the Files module. Supported formats: MP3, FLAC, OGG, AAC, OPUS, WAV, WMA.</p>
                        </div>
                    }
                </div>
            }

            @* ─── Artists Grid ─── *@
            @if (_section == Section.Artists && _selectedArtist is null)
            {
                <div class="artists-grid">
                    @foreach (var artist in _artists)
                    {
                        <div class="artist-card" @onclick="() => OpenArtistDetail(artist)">
                            <div class="artist-avatar">@GetInitials(artist.Name)</div>
                            <span class="artist-name">@artist.Name</span>
                            <span class="artist-meta">@artist.AlbumCount albums · @artist.TrackCount tracks</span>
                        </div>
                    }
                </div>
            }

            @* ─── Artist Detail ─── *@
            @if (_section == Section.Artists && _selectedArtist is not null)
            {
                <div class="artist-detail">
                    <div class="artist-detail-header">
                        <div class="artist-detail-avatar">@GetInitials(_selectedArtist.Name)</div>
                        <div class="artist-detail-info">
                            <h3>@_selectedArtist.Name</h3>
                            <span>@_selectedArtist.AlbumCount albums · @_selectedArtist.TrackCount tracks</span>
                        </div>
                    </div>

                    @if (_artistAlbums.Count > 0)
                    {
                        <h4 class="section-subhead">Discography</h4>
                        <div class="albums-row">
                            @foreach (var album in _artistAlbums)
                            {
                                <div class="album-card" @onclick="() => OpenAlbumDetail(album)">
                                    <div class="album-art">
                                        @if (album.HasCoverArt)
                                        {
                                            <img src="@GetAlbumArtUrl(album.Id)" alt="@album.Title" loading="lazy" />
                                        }
                                        else
                                        {
                                            <div class="album-art-placeholder">♫</div>
                                        }
                                        <button class="play-overlay" @onclick:stopPropagation="true"
                                                @onclick="() => PlayAlbumAsync(album.Id)">▶</button>
                                    </div>
                                    <div class="album-card-info">
                                        <span class="album-card-title">@album.Title</span>
                                        <span class="album-card-year">@album.Year</span>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            }

            @* ─── Albums Grid ─── *@
            @if (_section == Section.Albums && _selectedAlbum is null)
            {
                <div class="albums-grid">
                    @foreach (var album in _albums)
                    {
                        <div class="album-card" @onclick="() => OpenAlbumDetail(album)">
                            <div class="album-art">
                                @if (album.HasCoverArt)
                                {
                                    <img src="@GetAlbumArtUrl(album.Id)" alt="@album.Title" loading="lazy" />
                                }
                                else
                                {
                                    <div class="album-art-placeholder">♫</div>
                                }
                                <button class="play-overlay" @onclick:stopPropagation="true"
                                        @onclick="() => PlayAlbumAsync(album.Id)">▶</button>
                            </div>
                            <div class="album-card-info">
                                <span class="album-card-title">@album.Title</span>
                                <span class="album-card-artist">@album.ArtistName</span>
                            </div>
                        </div>
                    }
                </div>
            }

            @* ─── Album Detail ─── *@
            @if (_section == Section.Albums && _selectedAlbum is not null)
            {
                <div class="album-detail">
                    <div class="album-detail-header">
                        <div class="album-detail-art">
                            @if (_selectedAlbum.HasCoverArt)
                            {
                                <img src="@GetAlbumArtUrl(_selectedAlbum.Id)" alt="@_selectedAlbum.Title" />
                            }
                            else
                            {
                                <div class="album-art-placeholder large">♫</div>
                            }
                        </div>
                        <div class="album-detail-info">
                            <span class="badge-album">ALBUM</span>
                            <h3>@_selectedAlbum.Title</h3>
                            <span class="album-detail-meta">
                                @_selectedAlbum.ArtistName · @_selectedAlbum.Year · @_selectedAlbum.TrackCount tracks · @FormatDuration(_selectedAlbum.TotalDuration)
                            </span>
                            <div class="album-detail-actions">
                                <button class="btn-play" @onclick="() => PlayAlbumAsync(_selectedAlbum.Id)">▶ Play</button>
                                <button class="btn-icon-action" @onclick="() => ToggleStarAlbumAsync(_selectedAlbum)" title="Star">
                                    @(_selectedAlbum.IsStarred ? "★" : "☆")
                                </button>
                            </div>
                        </div>
                    </div>

                    <div class="track-list album-tracks">
                        @foreach (var (track, index) in _albumTracks.Select((t, i) => (t, i)))
                        {
                            <div class="track-row @(_nowPlaying?.Id == track.Id ? "playing" : "")"
                                 @ondblclick="() => PlayTrackAsync(track)">
                                <span class="track-num">@(track.TrackNumber > 0 ? track.TrackNumber : index + 1)</span>
                                <div class="track-info">
                                    <span class="track-title">@track.Title</span>
                                    @if (track.ArtistName != _selectedAlbum.ArtistName)
                                    {
                                        <span class="track-artist">@track.ArtistName</span>
                                    }
                                </div>
                                <span class="track-duration">@FormatDuration(track.Duration)</span>
                                <button class="track-action" @onclick="() => ToggleStarTrackAsync(track)" title="Star">
                                    @(track.IsStarred ? "★" : "☆")
                                </button>
                                <div class="track-menu">
                                    <button class="btn-icon" @onclick="() => ShowTrackMenu(track)">⋯</button>
                                    @if (_trackMenuId == track.Id)
                                    {
                                        <div class="track-dropdown">
                                            <button @onclick="() => AddToQueueAsync(track)">Add to Queue</button>
                                            @foreach (var pl in _playlists)
                                            {
                                                <button @onclick="() => AddToPlaylistAsync(pl.Id, track.Id)">Add to @pl.Name</button>
                                            }
                                        </div>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }

            @* ─── Genres ─── *@
            @if (_section == Section.Genres)
            {
                <div class="genres-grid">
                    @foreach (var genre in _genres)
                    {
                        <button class="genre-chip @(_selectedGenre == genre ? "active" : "")"
                                @onclick="() => SelectGenreAsync(genre)">
                            @genre
                        </button>
                    }
                </div>

                @if (_selectedGenre is not null && _genreTracks.Count > 0)
                {
                    <div class="track-list" style="margin-top: 16px;">
                        @foreach (var (track, index) in _genreTracks.Select((t, i) => (t, i)))
                        {
                            <div class="track-row @(_nowPlaying?.Id == track.Id ? "playing" : "")"
                                 @ondblclick="() => PlayTrackAsync(track)">
                                <span class="track-num">@(index + 1)</span>
                                <div class="track-info">
                                    <span class="track-title">@track.Title</span>
                                    <span class="track-artist">@track.ArtistName — @track.AlbumTitle</span>
                                </div>
                                <span class="track-duration">@FormatDuration(track.Duration)</span>
                            </div>
                        }
                    </div>
                }
            }

            @* ─── Playlists ─── *@
            @if (_section == Section.Playlists && _selectedPlaylist is not null)
            {
                <div class="playlist-detail">
                    <div class="playlist-detail-header">
                        <h3>@_selectedPlaylist.Name</h3>
                        <span class="playlist-meta">@_selectedPlaylist.TrackCount tracks · @FormatDuration(_selectedPlaylist.TotalDuration)</span>
                        <div class="playlist-actions">
                            <button class="btn-play" @onclick="() => PlayPlaylistAsync(_selectedPlaylist.Id)">▶ Play</button>
                            <button class="btn-icon-action" @onclick="() => _showEditPlaylistDialog = true" title="Edit">✎</button>
                            <button class="btn-icon-action danger" @onclick="() => DeletePlaylistAsync(_selectedPlaylist.Id)" title="Delete">🗑</button>
                        </div>
                    </div>
                    <div class="track-list">
                        @foreach (var (track, index) in _playlistTracks.Select((t, i) => (t, i)))
                        {
                            <div class="track-row @(_nowPlaying?.Id == track.Id ? "playing" : "")"
                                 @ondblclick="() => PlayTrackAsync(track)">
                                <span class="track-num">@(index + 1)</span>
                                <div class="track-info">
                                    <span class="track-title">@track.Title</span>
                                    <span class="track-artist">@track.ArtistName — @track.AlbumTitle</span>
                                </div>
                                <span class="track-duration">@FormatDuration(track.Duration)</span>
                                <button class="track-action danger" @onclick="() => RemoveFromPlaylistAsync(_selectedPlaylist.Id, track.Id)" title="Remove">✕</button>
                            </div>
                        }
                    </div>
                </div>
            }

            @* ─── Favorites ─── *@
            @if (_section == Section.Favorites)
            {
                <div class="track-list">
                    @if (_starredTracks.Count == 0)
                    {
                        <div class="music-empty">
                            <div class="empty-icon">⭐</div>
                            <h4>No favorites yet</h4>
                            <p>Star tracks, albums, or artists to see them here.</p>
                        </div>
                    }
                    @foreach (var (track, index) in _starredTracks.Select((t, i) => (t, i)))
                    {
                        <div class="track-row @(_nowPlaying?.Id == track.Id ? "playing" : "")"
                             @ondblclick="() => PlayTrackAsync(track)">
                            <span class="track-num">@(index + 1)</span>
                            <div class="track-info">
                                <span class="track-title">@track.Title</span>
                                <span class="track-artist">@track.ArtistName — @track.AlbumTitle</span>
                            </div>
                            <span class="track-duration">@FormatDuration(track.Duration)</span>
                            <button class="track-action" @onclick="() => ToggleStarTrackAsync(track)" title="Unstar">★</button>
                        </div>
                    }
                </div>
            }

            @* ─── Recently Played ─── *@
            @if (_section == Section.RecentlyPlayed)
            {
                <div class="track-list">
                    @if (_recentlyPlayed.Count == 0)
                    {
                        <div class="music-empty">
                            <div class="empty-icon">🕐</div>
                            <h4>No play history</h4>
                            <p>Play some music and it will appear here.</p>
                        </div>
                    }
                    @foreach (var (track, index) in _recentlyPlayed.Select((t, i) => (t, i)))
                    {
                        <div class="track-row @(_nowPlaying?.Id == track.Id ? "playing" : "")"
                             @ondblclick="() => PlayTrackAsync(track)">
                            <span class="track-num">@(index + 1)</span>
                            <div class="track-info">
                                <span class="track-title">@track.Title</span>
                                <span class="track-artist">@track.ArtistName — @track.AlbumTitle</span>
                            </div>
                            <span class="track-duration">@FormatDuration(track.Duration)</span>
                        </div>
                    }
                </div>
            }

            @* ─── Search Results ─── *@
            @if (_searchResults is not null)
            {
                <div class="search-results">
                    <h4>Search Results for "@_searchQuery"</h4>
                    <div class="track-list">
                        @foreach (var (track, index) in _searchResults.Select((t, i) => (t, i)))
                        {
                            <div class="track-row @(_nowPlaying?.Id == track.Id ? "playing" : "")"
                                 @ondblclick="() => PlayTrackAsync(track)">
                                <span class="track-num">@(index + 1)</span>
                                <div class="track-info">
                                    <span class="track-title">@track.Title</span>
                                    <span class="track-artist">@track.ArtistName — @track.AlbumTitle</span>
                                </div>
                                <span class="track-duration">@FormatDuration(track.Duration)</span>
                            </div>
                        }
                    </div>
                </div>
            }
        }
    </main>

    @* ─── Now Playing Bar ─── *@
    @if (_nowPlaying is not null)
    {
        <div class="now-playing-bar">
            <div class="np-track-info">
                <div class="np-art">
                    @if (_nowPlaying.AlbumId.HasValue)
                    {
                        <img src="@GetAlbumArtUrl(_nowPlaying.AlbumId.Value)" alt="" />
                    }
                    else
                    {
                        <div class="np-art-placeholder">♫</div>
                    }
                </div>
                <div class="np-text">
                    <span class="np-title">@_nowPlaying.Title</span>
                    <span class="np-artist">@_nowPlaying.ArtistName</span>
                </div>
                <button class="np-star" @onclick="() => ToggleStarTrackAsync(_nowPlaying)">
                    @(_nowPlaying.IsStarred ? "★" : "☆")
                </button>
            </div>

            <div class="np-controls">
                <div class="np-buttons">
                    <button class="np-btn" @onclick="ToggleShuffle" title="Shuffle">
                        <span class="@(_shuffle ? "active-control" : "")">⇄</span>
                    </button>
                    <button class="np-btn" @onclick="PlayPreviousAsync" title="Previous">⏮</button>
                    <button class="np-btn play-pause" @onclick="TogglePlayPause" title="@(_isPlaying ? "Pause" : "Play")">
                        @(_isPlaying ? "⏸" : "▶")
                    </button>
                    <button class="np-btn" @onclick="PlayNextAsync" title="Next">⏭</button>
                    <button class="np-btn" @onclick="CycleRepeat" title="Repeat">
                        <span class="@(_repeat != RepeatMode.Off ? "active-control" : "")">
                            @(_repeat == RepeatMode.One ? "🔂" : "🔁")
                        </span>
                    </button>
                </div>
                <div class="np-progress">
                    <span class="np-time">@FormatDuration(_playbackPosition)</span>
                    <div class="np-progress-bar" @onclick="SeekAsync">
                        <div class="np-progress-fill" style="width: @GetProgressPercent()%"></div>
                    </div>
                    <span class="np-time">@FormatDuration(_nowPlaying.Duration)</span>
                </div>
            </div>

            <div class="np-extras">
                <button class="np-btn" @onclick="() => _showQueue = !_showQueue" title="Queue">
                    <span class="@(_showQueue ? "active-control" : "")">☰</span>
                </button>
                <button class="np-btn" @onclick="() => _showEqualizer = !_showEqualizer" title="Equalizer">
                    <span class="@(_showEqualizer ? "active-control" : "")">⚙</span>
                </button>
                <div class="np-volume">
                    <button class="np-btn" @onclick="ToggleMute" title="Volume">
                        @(_muted ? "🔇" : _volume > 50 ? "🔊" : "🔉")
                    </button>
                    <input type="range" min="0" max="100" @bind="_volume" @bind:event="oninput"
                           class="volume-slider" />
                </div>
            </div>
        </div>
    }

    @* ─── Queue Panel ─── *@
    @if (_showQueue)
    {
        <aside class="queue-panel">
            <div class="queue-header">
                <h4>Play Queue</h4>
                <button class="btn-icon" @onclick="() => _showQueue = false">✕</button>
            </div>
            <div class="queue-list">
                @if (_queue.Count == 0)
                {
                    <p class="queue-empty">Queue is empty</p>
                }
                @foreach (var (track, index) in _queue.Select((t, i) => (t, i)))
                {
                    <div class="queue-item @(_nowPlaying?.Id == track.Id ? "playing" : "")">
                        <span class="queue-num">@(index + 1)</span>
                        <div class="queue-info">
                            <span>@track.Title</span>
                            <span class="queue-artist">@track.ArtistName</span>
                        </div>
                        <button class="queue-remove" @onclick="() => RemoveFromQueueAsync(index)">✕</button>
                    </div>
                }
            </div>
        </aside>
    }

    @* ─── Equalizer Panel ─── *@
    @if (_showEqualizer)
    {
        <aside class="eq-panel">
            <div class="eq-header">
                <h4>Equalizer</h4>
                <button class="btn-icon" @onclick="() => _showEqualizer = false">✕</button>
            </div>
            <div class="eq-presets">
                @foreach (var preset in _eqPresets)
                {
                    <button class="eq-preset-btn @(_activePresetId == preset.Id ? "active" : "")"
                            @onclick="() => ApplyPresetAsync(preset)">@preset.Name</button>
                }
            </div>
            <div class="eq-bands">
                @for (int i = 0; i < _eqBands.Length; i++)
                {
                    var bandIndex = i;
                    <div class="eq-band">
                        <input type="range" min="-12" max="12" step="0.5"
                               @bind="_eqBands[bandIndex]" @bind:event="oninput"
                               orient="vertical" class="eq-slider" />
                        <span class="eq-label">@_bandLabels[bandIndex]</span>
                    </div>
                }
            </div>
        </aside>
    }

    @* ─── Create/Edit Playlist Dialog ─── *@
    @if (_showCreatePlaylistDialog || _showEditPlaylistDialog)
    {
        <div class="dialog-overlay" @onclick="ClosePlaylistDialog">
            <div class="dialog-panel" @onclick:stopPropagation="true">
                <h4>@(_showEditPlaylistDialog ? "Edit Playlist" : "Create Playlist")</h4>
                <div class="dialog-form">
                    <label>Name
                        <input type="text" @bind="_playlistName" placeholder="Playlist name" />
                    </label>
                    <label>Description
                        <textarea @bind="_playlistDescription" placeholder="Optional description" rows="2"></textarea>
                    </label>
                    <label class="checkbox-label">
                        <input type="checkbox" @bind="_playlistPublic" />
                        <span>Public playlist</span>
                    </label>
                </div>
                <div class="dialog-actions">
                    <button class="btn-cancel" @onclick="ClosePlaylistDialog">Cancel</button>
                    <button class="btn-primary" @onclick="SavePlaylistAsync">
                        @(_showEditPlaylistDialog ? "Save" : "Create")
                    </button>
                </div>
            </div>
        </div>
    }
</div>
