<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:DotNetCloud.Client.SyncTray.ViewModels"
        x:Class="DotNetCloud.Client.SyncTray.Views.SettingsWindow"
        Title="DotNetCloud Sync — Settings"
        Width="520"
        Height="480"
        MinWidth="400"
        MinHeight="340"
        WindowStartupLocation="CenterScreen"
        RequestedThemeVariant="Dark"
        Background="#0D1118"
        Foreground="#E6ECF5"
        CanResize="True">

    <Window.Styles>
        <Style Selector="TabControl">
            <Setter Property="Background" Value="#0D1118" />
        </Style>

        <Style Selector="TabControl#SettingsTabs > TabItem">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="Margin" Value="0,0,6,0" />
            <Setter Property="CornerRadius" Value="8,8,0,0" />
            <Setter Property="Background" Value="#141E2D" />
            <Setter Property="BorderBrush" Value="#2A3A54" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#B8C3D9" />
        </Style>

        <Style Selector="TabControl#SettingsTabs > TabItem:pointerover">
            <Setter Property="Background" Value="#1A273A" />
            <Setter Property="BorderBrush" Value="#355074" />
            <Setter Property="Foreground" Value="#DDE7F8" />
        </Style>

        <Style Selector="TabControl#SettingsTabs > TabItem:selected">
            <Setter Property="Background" Value="#1E2D44" />
            <Setter Property="BorderBrush" Value="#2F86CE" />
            <Setter Property="BorderThickness" Value="1,1,1,0" />
            <Setter Property="Foreground" Value="#F4F7FF" />
        </Style>

        <Style Selector="Border.card">
            <Setter Property="Background" Value="#151C29" />
            <Setter Property="BorderBrush" Value="#263247" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="12" />
        </Style>

        <Style Selector="TextBox, NumericUpDown, ComboBox">
            <Setter Property="Background" Value="#111A28" />
            <Setter Property="BorderBrush" Value="#2C3A52" />
            <Setter Property="Foreground" Value="#E6ECF5" />
        </Style>

        <Style Selector="Button">
            <Setter Property="Background" Value="#243146" />
            <Setter Property="BorderBrush" Value="#334663" />
            <Setter Property="Foreground" Value="#EFF4FF" />
            <Setter Property="Padding" Value="12,7" />
            <Setter Property="CornerRadius" Value="6" />
        </Style>

        <Style Selector="Button:pointerover">
            <Setter Property="Background" Value="#2D3E58" />
        </Style>

        <Style Selector="Button:pressed">
            <Setter Property="Background" Value="#1D2A3D" />
        </Style>

        <Style Selector="Button.primary">
            <Setter Property="Background" Value="#0E6CB8" />
            <Setter Property="BorderBrush" Value="#2193E6" />
        </Style>

        <Style Selector="Button.danger">
            <Setter Property="Background" Value="#5D2530" />
            <Setter Property="BorderBrush" Value="#8B3446" />
        </Style>
    </Window.Styles>

    <DockPanel>

        <!-- Tab strip -->
        <TabControl x:Name="SettingsTabs" DockPanel.Dock="Top" Margin="12"
                    SelectedIndex="{Binding SelectedSettingsTab}">

            <!-- ── Accounts ── -->
            <TabItem Header="Accounts">
                <DockPanel Margin="8">

                    <Border Classes="card" IsVisible="{Binding !HasAccount}">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Connect your DotNetCloud account"
                                       FontSize="16"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="This client supports one account per device profile."
                                       Foreground="#A4B1C7"
                                       FontSize="12" />
                            <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto" RowSpacing="8">
                                <TextBlock Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2"
                                           Text="Server URL"
                                           FontWeight="SemiBold"
                                           Foreground="#B7C4DA"
                                           FontSize="12" />
                                <TextBox Grid.Row="1" Grid.Column="0"
                                         Text="{Binding AddAccountServerUrl}"
                                         Watermark="https://cloud.example.com"
                                         IsEnabled="{Binding CanAddAccount}" />
                                <Button Grid.Row="1" Grid.Column="1"
                                        Classes="primary"
                                        Content="Connect"
                                        Margin="8,0,0,0"
                                        Command="{Binding ConnectCommand}"
                                        IsEnabled="{Binding CanAddAccount}" />
                                <TextBlock Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                                           Text="{Binding AddAccountError}"
                                           Foreground="#FF7B88"
                                           FontSize="12"
                                           IsVisible="{Binding AddAccountError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Classes="card" IsVisible="{Binding HasAccount}">
                        <ContentControl Content="{Binding PrimaryAccount}">
                            <ContentControl.ContentTemplate>
                                <DataTemplate DataType="vm:AccountViewModel">
                                    <StackPanel Spacing="12">

                                        <!-- Account identity -->
                                        <StackPanel Spacing="2">
                                            <TextBlock Text="{Binding DisplayName}"
                                                       FontSize="16"
                                                       FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding ServerBaseUrl}"
                                                       FontSize="11"
                                                       Foreground="#7A8BA4" />
                                        </StackPanel>

                                        <Separator Background="#263247" Margin="0,2" />

                                        <!-- Sync folder -->
                                        <StackPanel Spacing="4">
                                            <TextBlock Text="Sync Folder"
                                                       FontSize="12"
                                                       FontWeight="SemiBold"
                                                       Foreground="#9AACCA" />
                                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                                <Border Grid.Column="0"
                                                        Background="#0E1520"
                                                        BorderBrush="#263247"
                                                        BorderThickness="1"
                                                        CornerRadius="4"
                                                        Padding="8,6"
                                                        VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding LocalFolderPath}"
                                                               FontSize="12"
                                                               FontFamily="Consolas, Courier New, monospace"
                                                               Foreground="#C8D4E8"
                                                               TextTrimming="CharacterEllipsis"
                                                               ToolTip.Tip="{Binding LocalFolderPath}" />
                                                </Border>
                                                <Button Grid.Column="1"
                                                        Content="Open Folder"
                                                        Command="{Binding $parent[Window].DataContext.OpenSyncFolderCommand}"
                                                        CommandParameter="{Binding LocalFolderPath}" />
                                            </Grid>
                                        </StackPanel>

                                        <!-- Status -->
                                        <StackPanel Spacing="2">
                                            <TextBlock FontSize="12" Foreground="#9AACCA">
                                                <TextBlock.Text>
                                                    <MultiBinding StringFormat="Status: {0}">
                                                        <Binding Path="State" />
                                                    </MultiBinding>
                                                </TextBlock.Text>
                                            </TextBlock>
                                            <TextBlock Text="{Binding LastError}"
                                                       FontSize="12"
                                                       Foreground="#FF7B88"
                                                       TextWrapping="Wrap"
                                                       IsVisible="{Binding LastError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                                        </StackPanel>

                                        <Separator Background="#263247" Margin="0,2" />

                                        <!-- Actions -->
                                        <StackPanel Orientation="Horizontal" Spacing="8"
                                                    HorizontalAlignment="Right">
                                            <Button Content="Choose Folders"
                                                    Command="{Binding $parent[Window].DataContext.ChooseFoldersCommand}"
                                                    CommandParameter="{Binding ContextId}" />
                                            <Button Content="Remove Account"
                                                    Classes="danger"
                                                    Command="{Binding $parent[Window].DataContext.RemoveAccountCommand}"
                                                    CommandParameter="{Binding ContextId}" />
                                        </StackPanel>

                                    </StackPanel>
                                </DataTemplate>
                            </ContentControl.ContentTemplate>
                        </ContentControl>
                    </Border>

                </DockPanel>
            </TabItem>

            <!-- ── General ── -->
            <TabItem Header="General">
                <StackPanel Margin="8" Spacing="12">
                    <CheckBox Content="Start DotNetCloud Sync at graphical login"
                              ToolTip.Tip="Creates a Linux desktop-session autostart entry for SyncTray. SyncTray starts SyncService automatically."
                              IsChecked="{Binding StartOnLogin}" />
                    <CheckBox Content="Mute chat notifications"
                              ToolTip.Tip="Suppress desktop chat popups from chat messages and mentions"
                              IsChecked="{Binding IsMuteChatNotifications}" />
                    <Separator />
                    <TextBlock Text="Bandwidth limits" FontWeight="SemiBold" />
                    <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto" RowSpacing="6">
                        <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Text="Upload (KB/s, 0 = unlimited)" Margin="0,0,12,0" />
                        <NumericUpDown Grid.Row="0" Grid.Column="1"
                                       Value="{Binding UploadLimitKbps}"
                                       Minimum="0" Maximum="100000" />
                        <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Text="Download (KB/s, 0 = unlimited)" Margin="0,0,12,0" />
                        <NumericUpDown Grid.Row="1" Grid.Column="1"
                                       Value="{Binding DownloadLimitKbps}"
                                       Minimum="0" Maximum="100000" />
                    </Grid>
                </StackPanel>
            </TabItem>

            <!-- ── Ignored Files ── -->
            <TabItem Header="Ignored Files">
                <DockPanel Margin="8">

                    <!-- Test path input -->
                    <Border DockPanel.Dock="Bottom"
                            Background="{DynamicResource SubtleFillColorSecondaryBrush}"
                            CornerRadius="4" Padding="8" Margin="0,8,0,0">
                        <StackPanel Spacing="4">
                            <TextBlock Text="Test a path" FontWeight="SemiBold" />
                            <TextBlock Text="Type a relative path to check whether it would be ignored."
                                       FontSize="11"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                            <TextBox Text="{Binding IgnoreTestPath}"
                                     Watermark="e.g. build/output.log" />
                            <TextBlock Text="{Binding IgnoreTestResult}"
                                       FontSize="11"
                                       IsVisible="{Binding IgnoreTestResult, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                        </StackPanel>
                    </Border>

                    <!-- Add pattern row -->
                    <Border DockPanel.Dock="Bottom"
                            Padding="0,6,0,0">
                        <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="6">
                            <TextBox Grid.Column="0"
                                     Text="{Binding NewIgnorePattern}"
                                     Watermark="Add pattern (e.g. *.log, build/)" />
                            <Button Grid.Column="1"
                                    Content="Add"
                                    Command="{Binding AddIgnorePatternCommand}" />
                            <Button Grid.Column="2"
                                    Content="Edit .syncignore"
                                    Command="{Binding EditSyncIgnoreFileCommand}" />
                        </Grid>
                    </Border>

                    <!-- Rule lists -->
                    <ScrollViewer>
                        <StackPanel Spacing="8">

                            <!-- User rules -->
                            <TextBlock Text="Your rules" FontWeight="SemiBold" />
                            <TextBlock Text="(none — all built-in defaults are active)"
                                       FontSize="11"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       IsVisible="{Binding UserIgnorePatterns.Count, Converter={x:Static ObjectConverters.IsNull}}" />
                            <ItemsControl ItemsSource="{Binding UserIgnorePatterns}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid ColumnDefinitions="*,Auto" Margin="0,2">
                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding}"
                                                       VerticalAlignment="Center"
                                                       FontFamily="Monospace" />
                                            <Button Grid.Column="1"
                                                    Content="✕"
                                                    Padding="4,2"
                                                    Command="{Binding $parent[Window].DataContext.RemoveIgnorePatternCommand}"
                                                    CommandParameter="{Binding}" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <Separator Margin="0,4" />

                            <!-- Built-in defaults (read-only) -->
                            <TextBlock Text="System defaults (read-only)" FontWeight="SemiBold" />
                            <ItemsControl ItemsSource="{Binding BuiltInIgnorePatterns}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}"
                                                   FontFamily="Monospace"
                                                   FontStyle="Italic"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                   Margin="0,1" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                        </StackPanel>
                    </ScrollViewer>

                </DockPanel>
            </TabItem>

            <!-- ── Transfers ── -->
            <TabItem Header="Transfers">
                <DockPanel Margin="8">

                    <!-- Empty state -->
                    <TextBlock DockPanel.Dock="Top"
                               Text="No active transfers."
                               FontSize="11"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               Margin="0,4,0,0"
                               IsVisible="{Binding ActiveTransfers.Count, Converter={x:Static ObjectConverters.IsNull}}" />

                    <ScrollViewer>
                        <ItemsControl ItemsSource="{Binding ActiveTransfers}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="vm:ActiveTransferViewModel">
                                    <Border BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}"
                                            BorderThickness="0,0,0,1"
                                            Padding="0,8">
                                        <Grid ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto,Auto,Auto" RowSpacing="3">

                                            <!-- Direction glyph -->
                                            <TextBlock Grid.Row="0" Grid.Column="0"
                                                       Text="{Binding DirectionGlyph}"
                                                       FontSize="16"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,8,0" />

                                            <!-- File name -->
                                            <TextBlock Grid.Row="0" Grid.Column="1"
                                                       Text="{Binding FileName}"
                                                       FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis" />

                                            <!-- Speed / Done -->
                                            <TextBlock Grid.Row="0" Grid.Column="2"
                                                       Text="{Binding SpeedLabel}"
                                                       FontSize="11"
                                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                       IsVisible="{Binding !IsComplete}"
                                                       HorizontalAlignment="Right" />
                                            <TextBlock Grid.Row="0" Grid.Column="2"
                                                       Text="✓ Done"
                                                       FontSize="11"
                                                       Foreground="Green"
                                                       IsVisible="{Binding IsComplete}"
                                                       HorizontalAlignment="Right" />

                                            <!-- Progress bar -->
                                            <ProgressBar Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3"
                                                         Value="{Binding PercentComplete}"
                                                         Minimum="0" Maximum="100"
                                                         Height="6"
                                                         IsVisible="{Binding !IsComplete}" />

                                            <!-- Bytes / ETA -->
                                            <TextBlock Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                                                       Text="{Binding BytesLabel}"
                                                       FontSize="11"
                                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                       IsVisible="{Binding !IsComplete}" />
                                            <TextBlock Grid.Row="2" Grid.Column="2"
                                                       Text="{Binding Eta}"
                                                       FontSize="11"
                                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                       IsVisible="{Binding !IsComplete}"
                                                       HorizontalAlignment="Right" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                </DockPanel>
            </TabItem>

            <!-- ── Conflicts ── -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <TextBlock Text="Conflicts" />
                        <Border Background="#FFCC00"
                                CornerRadius="8"
                                Padding="4,1"
                                IsVisible="{Binding TrayVm.HasConflicts}">
                            <TextBlock Text="{Binding TrayVm.ConflictCount}"
                                       FontSize="10"
                                       FontWeight="Bold"
                                       Foreground="Black" />
                        </Border>
                    </StackPanel>
                </TabItem.Header>
                <DockPanel Margin="8">

                    <!-- Toolbar -->
                    <StackPanel DockPanel.Dock="Top"
                                Orientation="Horizontal"
                                Spacing="8"
                                Margin="0,0,0,8">
                        <Button Content="Refresh"
                                Command="{Binding RefreshConflictsCommand}" />
                        <ProgressBar IsIndeterminate="True"
                                     Width="80" Height="16"
                                     VerticalAlignment="Center"
                                     IsVisible="{Binding IsLoadingConflicts}" />
                    </StackPanel>

                    <!-- Sub-tabs: Active / History -->
                    <TabControl SelectedIndex="{Binding SelectedConflictsTab}">

                        <TabItem Header="Active">
                            <DockPanel>
                                <!-- Empty state -->
                                <TextBlock DockPanel.Dock="Top"
                                           Text="No unresolved conflicts."
                                           FontSize="11"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                           Margin="0,8"
                                           IsVisible="{Binding Conflicts.Count, Converter={x:Static ObjectConverters.IsNull}}" />

                                <ScrollViewer>
                                    <ItemsControl ItemsSource="{Binding Conflicts}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="vm:ConflictViewModel">
                                                <Border BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}"
                                                        BorderThickness="0,0,0,1"
                                                        Padding="0,8">
                                                    <StackPanel Spacing="4">
                                                        <!-- File name + timestamp -->
                                                        <TextBlock Text="{Binding FileName}"
                                                                   FontWeight="SemiBold"
                                                                   TextTrimming="CharacterEllipsis" />
                                                        <TextBlock Text="{Binding OriginalPath}"
                                                                   FontSize="11"
                                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                                   TextTrimming="CharacterEllipsis" />
                                                        <StackPanel Orientation="Horizontal" Spacing="12">
                                                            <TextBlock FontSize="11"
                                                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                                       Text="{Binding DetectedAt, StringFormat='Detected: {0:g}'}" />
                                                        </StackPanel>
                                                        <!-- Action buttons -->
                                                        <StackPanel Orientation="Horizontal" Spacing="6"
                                                                    IsVisible="{Binding !IsResolved}">
                                                            <Button Content="Merge"
                                                                    FontSize="11"
                                                                    FontWeight="SemiBold"
                                                                    Command="{Binding MergeCommand}"
                                                                    IsVisible="{Binding CanMerge}" />
                                                            <Button Content="Keep Local"
                                                                    FontSize="11"
                                                                    Command="{Binding KeepLocalCommand}" />
                                                            <Button Content="Keep Server"
                                                                    FontSize="11"
                                                                    Command="{Binding KeepServerCommand}" />
                                                            <Button Content="Keep Both"
                                                                    FontSize="11"
                                                                    Command="{Binding KeepBothCommand}" />
                                                            <Button Content="Open Folder"
                                                                    FontSize="11"
                                                                    Command="{Binding OpenFolderCommand}" />
                                                        </StackPanel>
                                                        <!-- Resolved label -->
                                                        <TextBlock FontSize="11"
                                                                   Foreground="Green"
                                                                   Text="{Binding ResolutionLabel, StringFormat='✓ Resolved: {0}'}"
                                                                   IsVisible="{Binding IsResolved}" />
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </DockPanel>
                        </TabItem>

                        <TabItem Header="History">
                            <ScrollViewer>
                                <ItemsControl ItemsSource="{Binding ConflictHistory}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="vm:ConflictViewModel">
                                            <Border BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}"
                                                    BorderThickness="0,0,0,1"
                                                    Padding="0,6">
                                                <StackPanel Spacing="2">
                                                    <TextBlock Text="{Binding FileName}"
                                                               FontWeight="SemiBold"
                                                               TextTrimming="CharacterEllipsis" />
                                                    <TextBlock Text="{Binding OriginalPath}"
                                                               FontSize="11"
                                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                               TextTrimming="CharacterEllipsis" />
                                                    <StackPanel Orientation="Horizontal" Spacing="12">
                                                        <TextBlock FontSize="11"
                                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                                   Text="{Binding DetectedAt, StringFormat='Detected: {0:g}'}" />
                                                        <TextBlock FontSize="11"
                                                                   Foreground="Green"
                                                                   Text="{Binding ResolutionLabel, StringFormat='Resolved: {0}'}"
                                                                   IsVisible="{Binding IsResolved}" />
                                                        <TextBlock FontSize="11"
                                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                                   Text="(auto)"
                                                                   IsVisible="{Binding AutoResolved}" />
                                                    </StackPanel>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </TabItem>
                    </TabControl>

                </DockPanel>
            </TabItem>

        </TabControl>

        <!-- Close button -->
        <Button DockPanel.Dock="Bottom"
                Content="Close"
                Classes="primary"
                HorizontalAlignment="Right"
                Margin="12"
                Click="OnCloseClick" />

    </DockPanel>
</Window>
