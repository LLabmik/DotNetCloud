<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:DotNetCloud.Client.SyncTray.Views"
        x:Class="DotNetCloud.Client.SyncTray.Views.FolderBrowserDialog"
        Title="Choose Folders to Sync"
        Width="420"
        Height="480"
        MinWidth="320"
        MinHeight="300"
        WindowStartupLocation="CenterScreen"
        CanResize="True">

    <DockPanel>
        <TextBlock DockPanel.Dock="Top"
                   Text="Select which folders to sync. Unchecked folders will be excluded."
                   FontSize="12"
                   Margin="12,12,12,0"
                   TextWrapping="Wrap"
                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />

        <StackPanel DockPanel.Dock="Bottom"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Spacing="8"
                    Margin="12">
            <Button Content="Sync All Folders"
                    Click="OnSkip" />
            <Button Content="Save"
                    Classes="accent"
                    Click="OnSave" />
        </StackPanel>

        <views:FolderBrowserView x:Name="BrowserView"
                                 Margin="4" />
    </DockPanel>
</Window>
