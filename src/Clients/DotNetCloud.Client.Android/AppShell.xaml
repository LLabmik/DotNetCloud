<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="DotNetCloud.Client.Android.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:DotNetCloud.Client.Android.Views"
    Shell.NavBarIsVisible="true"
    Shell.BackgroundColor="#1E293B"
    Shell.ForegroundColor="#F1F5F9"
    Shell.TitleColor="#F1F5F9"
    Shell.TabBarBackgroundColor="#1E293B"
    Shell.TabBarForegroundColor="#0EA5E9"
    Shell.TabBarTitleColor="#0EA5E9"
    Shell.TabBarUnselectedColor="#64748B">

    <!-- Unauthenticated route — shown before login -->
    <ShellContent
        Route="Login"
        ContentTemplate="{DataTemplate views:LoginPage}"
        Shell.NavBarIsVisible="false"
        Shell.TabBarIsVisible="false" />

    <!-- Authenticated tab bar -->
    <TabBar Route="Main">

        <ShellContent
            Route="ChannelList"
            Title="Chat"
            Icon="dotnet_bot.png"
            ContentTemplate="{DataTemplate views:ChannelListPage}" />

        <ShellContent
            Route="Files"
            Title="Files"
            Icon="dotnet_bot.png"
            ContentTemplate="{DataTemplate views:FileBrowserPage}" />

        <ShellContent
            Route="Settings"
            Title="Settings"
            Icon="dotnet_bot.png"
            ContentTemplate="{DataTemplate views:SettingsPage}" />

    </TabBar>

</Shell>

