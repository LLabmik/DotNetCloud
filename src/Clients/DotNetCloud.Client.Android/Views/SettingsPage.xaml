<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="DotNetCloud.Client.Android.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Settings"
    BackgroundColor="#0F172A">

    <ScrollView>
        <VerticalStackLayout Padding="12,12" Spacing="8">

            <!-- ═══ Update Available Banner ═══ -->
            <Border
                BackgroundColor="#422006"
                Stroke="#F59E0B"
                StrokeThickness="1"
                StrokeShape="RoundRectangle 16"
                Padding="20,16"
                IsVisible="{Binding IsUpdateAvailable}">

                <VerticalStackLayout Spacing="10">
                    <HorizontalStackLayout Spacing="10">
                        <Label
                            FontSize="20"
                            VerticalOptions="Center"
                            Text="🔔" />
                        <VerticalStackLayout VerticalOptions="Center" Spacing="2">
                            <Label
                                FontAttributes="Bold"
                                FontSize="15"
                                TextColor="#F59E0B"
                                Text="{Binding UpdateVersion, StringFormat='Version {0} Available'}" />
                            <Label
                                FontSize="12"
                                TextColor="#FDE68A"
                                LineBreakMode="TailTruncation"
                                MaxLines="2"
                                Text="{Binding UpdateReleaseNotes}" />
                        </VerticalStackLayout>
                    </HorizontalStackLayout>

                    <HorizontalStackLayout Spacing="10" HorizontalOptions="End">
                        <Border
                            BackgroundColor="Transparent"
                            StrokeThickness="0"
                            Padding="14,8">
                            <Label FontSize="13" TextColor="#94A3B8" Text="Dismiss" />
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding DismissUpdateCommand}" />
                            </Border.GestureRecognizers>
                        </Border>
                        <Border
                            BackgroundColor="#F59E0B"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 8"
                            Padding="16,8">
                            <Label FontSize="13" FontAttributes="Bold" TextColor="#0F172A" Text="Update" />
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding OpenUpdateCommand}" />
                            </Border.GestureRecognizers>
                        </Border>
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Border>

            <!-- Account card -->
            <Border
                BackgroundColor="#1E293B"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 16"
                Padding="20,20">

                <VerticalStackLayout Spacing="4">
                    <Label
                        FontAttributes="Bold"
                        FontSize="12"
                        TextColor="#64748B"
                        Text="ACCOUNT"
                        TextTransform="Uppercase"
                        Margin="0,0,0,12" />

                    <HorizontalStackLayout Spacing="14">
                        <Border
                            BackgroundColor="#0EA5E9"
                            HeightRequest="48"
                            WidthRequest="48"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 24">
                            <Label
                                FontSize="20"
                                FontAttributes="Bold"
                                HorizontalOptions="Center"
                                VerticalOptions="Center"
                                TextColor="White"
                                Text="👤" />
                        </Border>
                        <VerticalStackLayout VerticalOptions="Center" Spacing="2">
                            <Label
                                FontAttributes="Bold"
                                FontSize="16"
                                TextColor="#F1F5F9"
                                Text="{Binding AccountEmail}" />
                            <Label
                                FontSize="13"
                                TextColor="#64748B"
                                Text="{Binding ServerBaseUrl}" />
                        </VerticalStackLayout>
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Border>

            <!-- Server card -->
            <Border
                BackgroundColor="#1E293B"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 16"
                Padding="20,20">

                <VerticalStackLayout Spacing="4">
                    <Label
                        FontAttributes="Bold"
                        FontSize="12"
                        TextColor="#64748B"
                        Text="SERVER"
                        TextTransform="Uppercase"
                        Margin="0,0,0,12" />

                    <HorizontalStackLayout Spacing="14">
                        <Border
                            BackgroundColor="#334155"
                            HeightRequest="48"
                            WidthRequest="48"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 24">
                            <Label
                                FontSize="20"
                                HorizontalOptions="Center"
                                VerticalOptions="Center"
                                TextColor="#94A3B8"
                                Text="🖥" />
                        </Border>
                        <VerticalStackLayout VerticalOptions="Center" Spacing="2">
                            <Label
                                FontSize="15"
                                TextColor="#F1F5F9"
                                Text="{Binding ServerDisplayName}" />
                            <Label
                                FontSize="13"
                                TextColor="#64748B"
                                Text="{Binding ServerBaseUrl}" />
                        </VerticalStackLayout>
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Border>

            <!-- ═══ File Sync card ═══ -->
            <Border
                BackgroundColor="#1E293B"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 16"
                Padding="20,20">

                <VerticalStackLayout Spacing="4">
                    <Label
                        FontAttributes="Bold"
                        FontSize="12"
                        TextColor="#64748B"
                        Text="FILE SYNC"
                        TextTransform="Uppercase"
                        Margin="0,0,0,12" />

                    <!-- Auto-upload toggle -->
                    <Grid ColumnDefinitions="Auto,*,Auto" Padding="0,6">
                        <Border
                            Grid.Column="0"
                            BackgroundColor="#334155"
                            HeightRequest="40"
                            WidthRequest="40"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 12"
                            Margin="0,0,12,0">
                            <Label
                                FontSize="18"
                                HorizontalOptions="Center"
                                VerticalOptions="Center"
                                Text="🔄" />
                        </Border>
                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="1">
                            <Label FontSize="15" TextColor="#F1F5F9" Text="Auto-Upload Media" />
                            <Label FontSize="12" TextColor="#64748B"
                                   Text="Automatically upload new photos &amp; videos" />
                        </VerticalStackLayout>
                        <Switch
                            Grid.Column="2"
                            VerticalOptions="Center"
                            OnColor="#0EA5E9"
                            ThumbColor="#F1F5F9"
                            IsToggled="{Binding AutoUploadEnabled}" />
                    </Grid>

                    <BoxView HeightRequest="1" BackgroundColor="#334155" Margin="0,4" />

                    <!-- WiFi-only toggle -->
                    <Grid ColumnDefinitions="Auto,*,Auto" Padding="0,6">
                        <Border
                            Grid.Column="0"
                            BackgroundColor="#334155"
                            HeightRequest="40"
                            WidthRequest="40"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 12"
                            Margin="0,0,12,0">
                            <Label
                                FontSize="18"
                                HorizontalOptions="Center"
                                VerticalOptions="Center"
                                Text="📶" />
                        </Border>
                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="1">
                            <Label FontSize="15" TextColor="#F1F5F9" Text="WiFi Only" />
                            <Label FontSize="12" TextColor="#64748B"
                                   Text="Only upload when connected to WiFi" />
                        </VerticalStackLayout>
                        <Switch
                            Grid.Column="2"
                            VerticalOptions="Center"
                            OnColor="#0EA5E9"
                            ThumbColor="#F1F5F9"
                            IsToggled="{Binding WifiOnlyEnabled}" />
                    </Grid>

                    <BoxView HeightRequest="1" BackgroundColor="#334155" Margin="0,4" />

                    <!-- Organize by date toggle -->
                    <Grid ColumnDefinitions="Auto,*,Auto" Padding="0,6">
                        <Border
                            Grid.Column="0"
                            BackgroundColor="#334155"
                            HeightRequest="40"
                            WidthRequest="40"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 12"
                            Margin="0,0,12,0">
                            <Label
                                FontSize="18"
                                HorizontalOptions="Center"
                                VerticalOptions="Center"
                                Text="📅" />
                        </Border>
                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="1">
                            <Label FontSize="15" TextColor="#F1F5F9" Text="Organize by Date" />
                            <Label FontSize="12" TextColor="#64748B"
                                   Text="Group uploads into YYYY/MM folders" />
                        </VerticalStackLayout>
                        <Switch
                            Grid.Column="2"
                            VerticalOptions="Center"
                            OnColor="#0EA5E9"
                            ThumbColor="#F1F5F9"
                            IsToggled="{Binding OrganizeByDate}" />
                    </Grid>

                    <BoxView HeightRequest="1" BackgroundColor="#334155" Margin="0,4" />

                    <!-- Upload folder name -->
                    <Grid ColumnDefinitions="Auto,*,Auto" Padding="0,6">
                        <Border
                            Grid.Column="0"
                            BackgroundColor="#334155"
                            HeightRequest="40"
                            WidthRequest="40"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 12"
                            Margin="0,0,12,0">
                            <Label
                                FontSize="18"
                                HorizontalOptions="Center"
                                VerticalOptions="Center"
                                Text="📁" />
                        </Border>
                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="1">
                            <Label FontSize="15" TextColor="#F1F5F9" Text="Upload Folder" />
                            <Label FontSize="12" TextColor="#64748B"
                                   Text="{Binding UploadFolderName}" />
                        </VerticalStackLayout>
                        <Border
                            Grid.Column="2"
                            BackgroundColor="#334155"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 8"
                            Padding="12,6"
                            VerticalOptions="Center">
                            <Label FontSize="13" TextColor="#0EA5E9" Text="Change" />
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding ChangeUploadFolderCommand}" />
                            </Border.GestureRecognizers>
                        </Border>
                    </Grid>

                    <BoxView HeightRequest="1" BackgroundColor="#334155" Margin="0,4" />

                    <!-- Sync now button -->
                    <Border
                        BackgroundColor="#0EA5E9"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 12"
                        Padding="0"
                        Margin="0,8,0,0"
                        HeightRequest="44">
                        <Grid>
                            <Label
                                FontSize="15"
                                FontAttributes="Bold"
                                HorizontalOptions="Center"
                                VerticalOptions="Center"
                                TextColor="White"
                                IsVisible="{Binding IsBusy, Converter={StaticResource InvertBool}}"
                                Text="Sync Now" />
                            <ActivityIndicator
                                IsRunning="{Binding IsBusy}"
                                IsVisible="{Binding IsBusy}"
                                Color="White"
                                HeightRequest="24"
                                WidthRequest="24"
                                HorizontalOptions="Center"
                                VerticalOptions="Center" />
                        </Grid>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding SyncNowCommand}" />
                        </Border.GestureRecognizers>
                    </Border>
                </VerticalStackLayout>
            </Border>

            <!-- ═══ Battery Optimization card ═══ -->
            <Border
                BackgroundColor="#1E293B"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 16"
                Padding="20,20">

                <VerticalStackLayout Spacing="4">
                    <Label
                        FontAttributes="Bold"
                        FontSize="12"
                        TextColor="#64748B"
                        Text="BACKGROUND ACTIVITY"
                        TextTransform="Uppercase"
                        Margin="0,0,0,12" />

                    <Grid ColumnDefinitions="Auto,*,Auto" Padding="0,6">
                        <Border
                            Grid.Column="0"
                            BackgroundColor="#334155"
                            HeightRequest="40"
                            WidthRequest="40"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 12"
                            Margin="0,0,12,0">
                            <Label
                                FontSize="18"
                                HorizontalOptions="Center"
                                VerticalOptions="Center"
                                Text="🔋" />
                        </Border>
                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="1">
                            <Label FontSize="15" TextColor="#F1F5F9" Text="Battery Optimization" />
                            <Label FontSize="12" TextColor="{Binding BatteryStatusColor}"
                                   Text="{Binding BatteryStatusText}" />
                        </VerticalStackLayout>

                        <!-- Fix button — shown only when restricted -->
                        <Border
                            Grid.Column="2"
                            BackgroundColor="#F59E0B"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 8"
                            Padding="14,6"
                            VerticalOptions="Center"
                            IsVisible="{Binding IsBatteryOptimized}">
                            <Label FontSize="13" FontAttributes="Bold" TextColor="#0F172A" Text="Fix" />
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding RequestBatteryExemptionCommand}" />
                            </Border.GestureRecognizers>
                        </Border>
                    </Grid>

                    <!-- Explanatory note when restricted -->
                    <Border
                        BackgroundColor="#1C1917"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 8"
                        Padding="12,10"
                        Margin="0,8,0,0"
                        IsVisible="{Binding IsBatteryOptimized}">
                        <Label
                            FontSize="12"
                            TextColor="#A3A3A3"
                            LineBreakMode="WordWrap"
                            Text="Android may stop background sync to save battery. Tap 'Fix' to allow DotNetCloud to run reliably in the background." />
                    </Border>
                </VerticalStackLayout>
            </Border>

            <!-- ═══ Updates card ═══ -->
            <Border
                BackgroundColor="#1E293B"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 16"
                Padding="20,20">

                <VerticalStackLayout Spacing="4">
                    <Label
                        FontAttributes="Bold"
                        FontSize="12"
                        TextColor="#64748B"
                        Text="UPDATES"
                        TextTransform="Uppercase"
                        Margin="0,0,0,12" />

                    <!-- Check for updates button -->
                    <Border
                        BackgroundColor="#334155"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 12"
                        Padding="0"
                        HeightRequest="44">
                        <Grid>
                            <Label
                                FontSize="15"
                                HorizontalOptions="Center"
                                VerticalOptions="Center"
                                TextColor="#0EA5E9"
                                IsVisible="{Binding IsCheckingForUpdate, Converter={StaticResource InvertBool}}"
                                Text="Check for Updates" />
                            <ActivityIndicator
                                IsRunning="{Binding IsCheckingForUpdate}"
                                IsVisible="{Binding IsCheckingForUpdate}"
                                Color="#0EA5E9"
                                HeightRequest="24"
                                WidthRequest="24"
                                HorizontalOptions="Center"
                                VerticalOptions="Center" />
                        </Grid>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding CheckForUpdateCommand}" />
                        </Border.GestureRecognizers>
                    </Border>

                    <!-- Status message after manual check -->
                    <Label
                        FontSize="13"
                        HorizontalOptions="Center"
                        TextColor="#22C55E"
                        Margin="0,6,0,0"
                        IsVisible="{Binding UpdateCheckStatus, Converter={StaticResource IsNotNullOrEmpty}}"
                        Text="{Binding UpdateCheckStatus}" />
                </VerticalStackLayout>
            </Border>

            <!-- Actions card (Log Out) -->
            <Border
                BackgroundColor="#1E293B"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 16"
                Padding="0"
                Margin="0,8,0,0">

                <Grid Padding="20,16">
                    <Label
                        FontSize="15"
                        TextColor="#EF4444"
                        VerticalOptions="Center"
                        Text="Log Out" />
                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding LogOutCommand}" />
                    </Grid.GestureRecognizers>
                </Grid>
            </Border>

            <!-- App info -->
            <Label
                FontSize="12"
                HorizontalOptions="Center"
                HorizontalTextAlignment="Center"
                TextColor="#475569"
                Margin="0,20,0,0"
                Text="{Binding AppVersionText}" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
