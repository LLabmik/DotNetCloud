<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="DotNetCloud.Client.Android.Views.ChannelDetailsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:DotNetCloud.Client.Android.ViewModels"
    Title="Channel Details"
    BackgroundColor="#0F172A">

    <ScrollView>
        <VerticalStackLayout Spacing="0">

            <!-- Channel info card -->
            <Border
                BackgroundColor="#1E293B"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 16"
                Margin="12,12,12,0"
                Padding="20,24">

                <VerticalStackLayout Spacing="6">
                    <!-- Channel icon + name -->
                    <HorizontalStackLayout Spacing="12">
                        <Border
                            BackgroundColor="#334155"
                            HeightRequest="48"
                            WidthRequest="48"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 14">
                            <Label
                                FontSize="22"
                                HorizontalOptions="Center"
                                VerticalOptions="Center"
                                TextColor="#94A3B8"
                                Text="#" />
                        </Border>
                        <VerticalStackLayout VerticalOptions="Center" Spacing="2">
                            <Label
                                FontAttributes="Bold"
                                FontSize="20"
                                TextColor="#F1F5F9"
                                Text="{Binding ChannelName}" />
                            <Label
                                FontSize="13"
                                TextColor="#64748B"
                                Text="{Binding MemberCountDisplay}" />
                        </VerticalStackLayout>
                    </HorizontalStackLayout>

                    <Label
                        FontSize="14"
                        IsVisible="{Binding ChannelTopic, Converter={StaticResource IsNotNullOrEmpty}}"
                        TextColor="#94A3B8"
                        Margin="0,8,0,0"
                        Text="{Binding ChannelTopic}" />
                </VerticalStackLayout>
            </Border>

            <!-- Actions card -->
            <Border
                BackgroundColor="#1E293B"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 16"
                Margin="12,8,12,0"
                Padding="0">

                <VerticalStackLayout>
                    <!-- Notifications preference -->
                    <Grid
                        ColumnDefinitions="*,Auto"
                        Padding="20,16">
                        <Label
                            Grid.Column="0"
                            FontSize="15"
                            TextColor="#F1F5F9"
                            VerticalOptions="Center"
                            Text="Mute notifications" />
                        <Switch
                            Grid.Column="1"
                            IsToggled="{Binding IsMuted}"
                            OnColor="#0EA5E9"
                            VerticalOptions="Center" />
                    </Grid>

                    <BoxView HeightRequest="1" Margin="20,0" BackgroundColor="#334155" />

                    <!-- Leave channel -->
                    <Grid Padding="20,14">
                        <Label
                            FontSize="15"
                            TextColor="#EF4444"
                            Text="Leave channel" />
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding LeaveChannelCommand}" />
                        </Grid.GestureRecognizers>
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <!-- Members card -->
            <Border
                BackgroundColor="#1E293B"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 16"
                Margin="12,8,12,12"
                Padding="0">

                <VerticalStackLayout>
                    <Label
                        Margin="20,16,20,10"
                        FontAttributes="Bold"
                        FontSize="12"
                        TextColor="#64748B"
                        Text="{Binding MembersHeaderText}"
                        TextTransform="Uppercase" />

                    <CollectionView
                        ItemsSource="{Binding Members}"
                        SelectionMode="None">

                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="vm:ChannelMemberItemViewModel">
                                <Grid
                                    ColumnDefinitions="Auto,*,Auto"
                                    Padding="20,10">

                                    <!-- Avatar -->
                                    <Border
                                        Grid.Column="0"
                                        BackgroundColor="#0EA5E9"
                                        HeightRequest="38"
                                        WidthRequest="38"
                                        StrokeThickness="0"
                                        StrokeShape="RoundRectangle 19"
                                        Margin="0,0,12,0">
                                        <Label
                                            FontAttributes="Bold"
                                            FontSize="14"
                                            HorizontalOptions="Center"
                                            Text="{Binding Initials}"
                                            TextColor="White"
                                            VerticalOptions="Center" />
                                    </Border>

                                    <!-- Name and role -->
                                    <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="1">
                                        <Label
                                            FontSize="15"
                                            TextColor="#F1F5F9"
                                            Text="{Binding DisplayName}" />
                                        <Label
                                            FontSize="12"
                                            IsVisible="{Binding RoleLabel, Converter={StaticResource IsNotNullOrEmpty}}"
                                            TextColor="#64748B"
                                            Text="{Binding RoleLabel}" />
                                    </VerticalStackLayout>

                                    <!-- Online status indicator -->
                                    <Ellipse
                                        Grid.Column="2"
                                        Fill="{Binding IsOnline, Converter={StaticResource OnlineStatusToColor}}"
                                        HeightRequest="10"
                                        VerticalOptions="Center"
                                        WidthRequest="10" />

                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>

                        <CollectionView.EmptyView>
                            <Label
                                Margin="20,12"
                                FontSize="14"
                                TextColor="#64748B"
                                Text="No members." />
                        </CollectionView.EmptyView>

                    </CollectionView>

                    <!-- Loading indicator -->
                    <ActivityIndicator
                        HorizontalOptions="Center"
                        IsRunning="{Binding IsLoading}"
                        IsVisible="{Binding IsLoading}"
                        Margin="0,12"
                        Color="#0EA5E9" />

                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
