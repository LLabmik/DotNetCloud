<?xml version = "1.0" encoding = "UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:converters="clr-namespace:DotNetCloud.Client.Android.Converters"
             xmlns:local="clr-namespace:DotNetCloud.Client.Android"
             x:Class="DotNetCloud.Client.Android.App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Shared value converters used throughout the app -->
            <converters:InvertBoolConverter x:Key="InvertBool" />
            <converters:IsNotNullOrEmptyConverter x:Key="IsNotNullOrEmpty" />
            <converters:IsNotZeroConverter x:Key="IsNotZero" />
            <converters:UnreadToBoldConverter x:Key="UnreadToBold" />
            <converters:MentionToBadgeColorConverter x:Key="MentionToBadgeColor" />

        </ResourceDictionary>
    </Application.Resources>
</Application>

