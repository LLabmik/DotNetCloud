<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Note: For Android please see also Platforms\Android\Resources\values\colors.xml -->

    <!-- Brand accent — teal/cyan for a modern, professional look -->
    <Color x:Key="Primary">#0EA5E9</Color>
    <Color x:Key="PrimaryDark">#38BDF8</Color>
    <Color x:Key="PrimaryDarkText">#FFFFFF</Color>
    <Color x:Key="Secondary">#1E3A5F</Color>
    <Color x:Key="SecondaryDarkText">#94A3B8</Color>
    <Color x:Key="Tertiary">#0284C7</Color>
    <Color x:Key="Accent">#0EA5E9</Color>
    <Color x:Key="AccentLight">#38BDF8</Color>

    <!-- Core palette -->
    <Color x:Key="White">#FFFFFF</Color>
    <Color x:Key="Black">#000000</Color>

    <!-- Dark surfaces (Material Design 3 inspired elevation system) -->
    <Color x:Key="SurfaceBase">#0F172A</Color>
    <Color x:Key="Surface1">#1E293B</Color>
    <Color x:Key="Surface2">#334155</Color>
    <Color x:Key="Surface3">#475569</Color>
    <Color x:Key="OffBlack">#0F172A</Color>
    <Color x:Key="MidnightBlue">#0F172A</Color>
    <Color x:Key="Magenta">#0EA5E9</Color>

    <!-- Neutral text hierarchy -->
    <Color x:Key="TextPrimary">#F1F5F9</Color>
    <Color x:Key="TextSecondary">#94A3B8</Color>
    <Color x:Key="TextTertiary">#64748B</Color>

    <!-- Dividers / borders -->
    <Color x:Key="DividerDark">#1E293B</Color>
    <Color x:Key="DividerLight">#334155</Color>

    <!-- Semantic colors -->
    <Color x:Key="Success">#22C55E</Color>
    <Color x:Key="Warning">#F59E0B</Color>
    <Color x:Key="Error">#EF4444</Color>
    <Color x:Key="ErrorLight">#FCA5A5</Color>

    <!-- Grays (kept for Styles.xaml compatibility) -->
    <Color x:Key="Gray100">#F1F5F9</Color>
    <Color x:Key="Gray200">#CBD5E1</Color>
    <Color x:Key="Gray300">#94A3B8</Color>
    <Color x:Key="Gray400">#64748B</Color>
    <Color x:Key="Gray500">#475569</Color>
    <Color x:Key="Gray600">#334155</Color>
    <Color x:Key="Gray900">#1E293B</Color>
    <Color x:Key="Gray950">#0F172A</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource Primary}"/>
    <SolidColorBrush x:Key="SecondaryBrush" Color="{StaticResource Secondary}"/>
    <SolidColorBrush x:Key="TertiaryBrush" Color="{StaticResource Tertiary}"/>
    <SolidColorBrush x:Key="WhiteBrush" Color="{StaticResource White}"/>
    <SolidColorBrush x:Key="BlackBrush" Color="{StaticResource Black}"/>

    <SolidColorBrush x:Key="Gray100Brush" Color="{StaticResource Gray100}"/>
    <SolidColorBrush x:Key="Gray200Brush" Color="{StaticResource Gray200}"/>
    <SolidColorBrush x:Key="Gray300Brush" Color="{StaticResource Gray300}"/>
    <SolidColorBrush x:Key="Gray400Brush" Color="{StaticResource Gray400}"/>
    <SolidColorBrush x:Key="Gray500Brush" Color="{StaticResource Gray500}"/>
    <SolidColorBrush x:Key="Gray600Brush" Color="{StaticResource Gray600}"/>
    <SolidColorBrush x:Key="Gray900Brush" Color="{StaticResource Gray900}"/>
    <SolidColorBrush x:Key="Gray950Brush" Color="{StaticResource Gray950}"/>
</ResourceDictionary>
