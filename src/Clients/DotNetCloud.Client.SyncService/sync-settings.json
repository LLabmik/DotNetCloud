{
  "logging": {
    "retentionDays": 30,
    "maxFileSizeMB": 50,
    "minimumLevel": "Information"
  },
  "bandwidth": {
    "uploadLimitKbps": 0,
    "downloadLimitKbps": 0
  },
  "conflictResolution": {
    "autoResolveEnabled": true,
    "newerWinsThresholdMinutes": 5,
    "enabledStrategies": ["identical", "fast-forward", "clean-merge", "newer-wins", "append-only"]
  },
  "symlinks": {
    "mode": "ignore"
  }
}
